---
/**
 * Mobile navigation drawer — slides down from the header when toggled.
 *
 * Vanilla JS toggle (no framework), aria-expanded/aria-controls for
 * screen readers, and escape-to-close. The hamburger button lives in
 * the BaseLayout header as a sibling so that `aria-controls` can
 * reference this drawer by id.
 */

interface NavLink {
  label: string;
  href: string;
}

interface Props {
  links: NavLink[];
  currentPath: string;
}

const { links, currentPath } = Astro.props;
---
<div
  id="mobile-nav"
  class="fixed top-16 inset-x-0 z-40 bg-paper border-b border-rule hidden md:hidden"
  data-mobile-nav
>
  <nav class="page py-5 flex flex-col gap-1" aria-label="Mobile navigation">
    {links.map((link) => {
      const active = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
      return (
        <a
          href={link.href}
          class:list={[
            'px-3 py-2.5 rounded text-base transition-colors',
            active
              ? 'bg-paper-soft text-ink font-medium'
              : 'text-ink-muted hover:bg-paper-soft hover:text-ink',
          ]}
          aria-current={active ? 'page' : undefined}
        >
          {link.label}
        </a>
      );
    })}
    <a
      href="https://github.com/chrisjohnleah/emdashcms-org"
      target="_blank"
      rel="noopener noreferrer"
      class="mt-2 px-3 py-2.5 rounded text-base text-ink-muted hover:bg-paper-soft hover:text-ink transition-colors"
    >
      GitHub
    </a>
  </nav>
</div>

<script>
  const drawer = document.getElementById('mobile-nav');
  const toggle = document.querySelector<HTMLButtonElement>('[data-mobile-nav-toggle]');

  function closeDrawer() {
    if (!drawer || !toggle) return;
    drawer.classList.add('hidden');
    toggle.setAttribute('aria-expanded', 'false');
  }

  function openDrawer() {
    if (!drawer || !toggle) return;
    drawer.classList.remove('hidden');
    toggle.setAttribute('aria-expanded', 'true');
  }

  toggle?.addEventListener('click', () => {
    if (drawer?.classList.contains('hidden')) {
      openDrawer();
    } else {
      closeDrawer();
    }
  });

  // Escape key closes the drawer
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !drawer?.classList.contains('hidden')) {
      closeDrawer();
      toggle?.focus();
    }
  });

  // Clicking a nav link closes the drawer (important for in-page anchors)
  drawer?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeDrawer);
  });
</script>
