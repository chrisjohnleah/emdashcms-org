---
interface Props {
  status: string;
}

const { status } = Astro.props;

const variants: Record<string, { bg: string; text: string; border: string; label: string }> = {
  published: {
    bg: 'bg-success-soft',
    text: 'text-success',
    border: 'border-success/30',
    label: 'Published',
  },
  flagged: {
    bg: 'bg-warn-soft',
    text: 'text-warn',
    border: 'border-warn/35',
    label: 'Flagged',
  },
  pending: {
    bg: 'bg-paper-sunk',
    text: 'text-ink-muted',
    border: 'border-rule',
    label: 'Pending',
  },
  rejected: {
    bg: 'bg-danger-soft',
    text: 'text-danger',
    border: 'border-danger/35',
    label: 'Rejected',
  },
  revoked: {
    bg: 'bg-danger-soft',
    text: 'text-danger',
    border: 'border-danger/40',
    label: 'Revoked',
  },
  ok: {
    bg: 'bg-success-soft',
    text: 'text-success',
    border: 'border-success/30',
    label: 'Operational',
  },
  degraded: {
    bg: 'bg-warn-soft',
    text: 'text-warn',
    border: 'border-warn/35',
    label: 'Degraded',
  },
  outage: {
    bg: 'bg-danger-soft',
    text: 'text-danger',
    border: 'border-danger/35',
    label: 'Outage',
  },
};

const v = variants[status] || variants.pending;
---
<span
  class:list={['inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-medium border', v.bg, v.text, v.border]}
>
  {v.label}
</span>
