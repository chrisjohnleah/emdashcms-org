---
interface Props {
  status: string;
}

const { status } = Astro.props;

const variants: Record<string, { bg: string; text: string; border: string; label: string }> = {
  published: {
    bg: 'bg-emerald-950/40',
    text: 'text-emerald-400',
    border: 'border-emerald-800/60',
    label: 'Published',
  },
  flagged: {
    bg: 'bg-amber-950/40',
    text: 'text-amber-400',
    border: 'border-amber-800/60',
    label: 'Flagged',
  },
  pending: {
    bg: 'bg-zinc-800/40',
    text: 'text-zinc-400',
    border: 'border-zinc-700/60',
    label: 'Pending',
  },
  rejected: {
    bg: 'bg-red-950/40',
    text: 'text-red-400',
    border: 'border-red-800/60',
    label: 'Rejected',
  },
};

const v = variants[status] || variants.pending;
---
<span
  class:list={['inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium border', v.bg, v.text, v.border]}
>
  {v.label}
</span>
