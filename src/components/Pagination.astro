---
interface Props {
  nextCursor: string | null;
  count: number;
  label: string;
  baseUrl: string;
}

const { nextCursor, count, label, baseUrl } = Astro.props;
const currentParams = Astro.url.searchParams;

function buildLoadMoreHref(): string {
  const params = new URLSearchParams(currentParams);
  if (nextCursor) {
    params.set('cursor', nextCursor);
  }
  const qs = params.toString();
  return qs ? `${baseUrl}?${qs}` : baseUrl;
}
---
<div class="flex flex-col items-center gap-4 pt-10">
  <p class="text-sm text-ink-soft">Showing {count} {label}</p>
  {nextCursor && (
    <a
      href={buildLoadMoreHref()}
      class="inline-flex items-center rounded-md border border-rule-strong bg-paper-soft px-5 py-2.5 text-sm font-medium text-ink hover:bg-paper-sunk hover:border-ink transition-colors min-h-[44px]"
    >
      Load more {label}
    </a>
  )}
</div>
