---
interface Props {
  role: 'owner' | 'maintainer' | 'contributor';
}

const { role } = Astro.props;

const styles: Record<string, string> = {
  owner: 'bg-warn-soft text-warn border-warn/35',
  maintainer: 'bg-info-soft text-info border-info/35',
  contributor: 'bg-paper-sunk text-ink-muted border-rule',
};

const labels: Record<string, string> = {
  owner: 'Owner',
  maintainer: 'Maintainer',
  contributor: 'Contributor',
};
---
<span
  class:list={['inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-medium border', styles[role]]}
>
  {labels[role]}
</span>
