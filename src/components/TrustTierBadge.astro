---
/**
 * Visual trust tier badge shown on plugin cards and detail pages.
 *
 * Derived from `status` + `verdict`:
 *   - pending                     → Unreviewed
 *   - rejected                    → Rejected (never appears in browse)
 *   - published + AI verdict=pass → AI-reviewed
 *   - flagged   + AI verdict=warn → AI-reviewed (Caution)
 *   - published + no verdict      → Scanned (static-only pass)
 *   - flagged   + no verdict      → Scanned (Caution)
 *
 * See /docs/security for the end-user explanation of each tier.
 * Keep this derivation logic in sync with `deriveTrustTier()` in
 * src/lib/db/mappers.ts.
 */

type VersionStatus = "pending" | "published" | "flagged" | "rejected";
type Verdict = "pass" | "warn" | "fail" | null;

interface Props {
  status: VersionStatus;
  verdict?: Verdict;
  size?: "sm" | "md";
  showTooltip?: boolean;
}

const { status, verdict = null, size = "md", showTooltip = false } = Astro.props;

type Tier =
  | "unreviewed"
  | "scanned"
  | "scanned-caution"
  | "ai-reviewed"
  | "ai-reviewed-caution"
  | "rejected";

function deriveTier(s: VersionStatus, v: Verdict): Tier {
  if (s === "pending") return "unreviewed";
  if (s === "rejected") return "rejected";
  const hasAiVerdict = v !== null;
  if (s === "published") {
    return hasAiVerdict ? "ai-reviewed" : "scanned";
  }
  if (s === "flagged") {
    return hasAiVerdict ? "ai-reviewed-caution" : "scanned-caution";
  }
  return "unreviewed";
}

const tier = deriveTier(status, verdict);

interface TierVisual {
  label: string;
  bg: string;
  text: string;
  border: string;
  glyph: string | null;
  tooltip: string;
}

const tierVisuals: Record<Tier, TierVisual> = {
  unreviewed: {
    label: "Unreviewed",
    bg: "bg-paper-sunk",
    text: "text-ink-muted",
    border: "border-rule",
    glyph: null,
    tooltip: "Waiting on moderation — not yet reviewed.",
  },
  scanned: {
    label: "Scanned",
    bg: "bg-success-soft",
    text: "text-success",
    border: "border-success/30",
    glyph: null,
    tooltip: "Passed the static security scan.",
  },
  "scanned-caution": {
    label: "Scanned — Caution",
    bg: "bg-warn-soft",
    text: "text-warn",
    border: "border-warn/35",
    glyph: null,
    tooltip: "Published, but the scanner flagged findings to review.",
  },
  "ai-reviewed": {
    label: "AI-reviewed",
    bg: "bg-success-soft",
    text: "text-success",
    border: "border-success/30",
    glyph: "✦",
    tooltip: "Passed both the static scan and AI review.",
  },
  "ai-reviewed-caution": {
    label: "AI-reviewed — Caution",
    bg: "bg-warn-soft",
    text: "text-warn",
    border: "border-warn/35",
    glyph: "✦",
    tooltip: "AI review flagged findings to review before installing.",
  },
  rejected: {
    label: "Rejected",
    bg: "bg-danger-soft",
    text: "text-danger",
    border: "border-danger/35",
    glyph: null,
    tooltip: "Did not pass review.",
  },
};

const v = tierVisuals[tier];
const sizeClasses =
  size === "sm"
    ? "px-2 py-0.5 text-[10px]"
    : "px-2.5 py-0.5 text-[11px]";
---
<span
  class:list={[
    "inline-flex items-center gap-1 rounded-full border font-medium uppercase tracking-wide",
    sizeClasses,
    v.bg,
    v.text,
    v.border,
  ]}
  title={showTooltip ? v.tooltip : undefined}
  aria-label={`Trust tier: ${v.label}`}
>
  {v.glyph && <span aria-hidden="true">{v.glyph}</span>}
  {v.label}
</span>
