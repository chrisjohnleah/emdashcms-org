---
interface Props {
  source: 'github' | 'upload';
}

const { source } = Astro.props;
---
{source === 'github' && (
  <span
    class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium border bg-violet-950/40 text-violet-400 border-violet-800/60"
    aria-label="Submitted via GitHub"
  >
    GitHub
  </span>
)}
