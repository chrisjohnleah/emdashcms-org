---
import Button from './Button.astro';

interface Props {
  heading: string;
  body: string;
  linkHref?: string;
  linkText?: string;
}

const { heading, body, linkHref, linkText } = Astro.props;
---
<div class="text-center py-16">
  <h2 class="text-xl font-semibold text-zinc-100">{heading}</h2>
  <p class="mt-2 text-sm text-zinc-400">{body}</p>
  {linkHref && linkText && (
    <div class="mt-6 inline-block">
      <Button href={linkHref} variant="primary" size="lg">{linkText}</Button>
    </div>
  )}
</div>
