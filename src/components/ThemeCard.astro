---
import type { MarketplaceThemeSummary } from '../types/marketplace';

interface Props {
  theme: MarketplaceThemeSummary;
}

const { theme } = Astro.props;
const description = theme.shortDescription ?? theme.description;
---
<a
  href={`/themes/${theme.id}`}
  class="group block bg-paper-soft border border-rule rounded-md overflow-hidden transition-colors hover:bg-paper-sunk hover:border-rule-strong"
>
  {theme.thumbnailUrl ? (
    <div class="aspect-[16/10] bg-paper-sunk overflow-hidden border-b border-rule">
      <img
        src={theme.thumbnailUrl}
        alt=""
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
        loading="lazy"
      />
    </div>
  ) : (
    <div class="aspect-[16/10] bg-paper-sunk border-b border-rule flex items-center justify-center" aria-hidden="true">
      <span
        class="font-display text-accent-deep"
        style="font-size: clamp(4rem, 12vw, 7rem); line-height: 1; font-variation-settings: 'opsz' 144;"
      >—</span>
    </div>
  )}

  <div class="p-6">
    <div class="flex items-center gap-2 text-xs text-ink-soft">
      {theme.author.avatarUrl ? (
        <img src={theme.author.avatarUrl} alt="" class="w-4 h-4 rounded-full" loading="lazy" />
      ) : (
        <span class="w-4 h-4 rounded-full bg-paper-deep" aria-hidden="true"></span>
      )}
      <span>{theme.author.name}</span>
    </div>

    <h3
      class="font-display text-xl text-ink mt-3 leading-tight tracking-tight group-hover:text-accent-deep transition-colors"
      style="font-weight: 500;"
    >
      {theme.name}
    </h3>

    {description && (
      <p class="mt-2 text-sm text-ink-muted leading-relaxed line-clamp-2">
        {description}
      </p>
    )}

    {theme.keywords.length > 0 && (
      <div class="mt-5 flex items-center gap-2 flex-wrap">
        {theme.keywords.slice(0, 4).map((kw) => (
          <span class="rounded-full bg-paper-sunk border border-rule px-2 py-0.5 text-[11px] text-ink-muted">
            {kw}
          </span>
        ))}
      </div>
    )}
  </div>
</a>
