---
import type { MarketplaceThemeSummary } from '../types/marketplace';

interface Props {
  theme: MarketplaceThemeSummary;
}

const { theme } = Astro.props;
---
<a href={`/themes/${theme.id}`} class="block rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6 hover:border-zinc-700/60 hover:bg-zinc-900/60 transition-colors">
  <div class="aspect-video rounded-lg bg-zinc-800 mb-4 flex items-center justify-center">
    <svg class="w-8 h-8 text-zinc-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 0 0 5.304 0l6.401-6.402M6.75 21A3.75 3.75 0 0 1 3 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 0 0 3.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008Z" />
    </svg>
  </div>

  <div class="flex items-center gap-2">
    {theme.author.avatarUrl ? (
      <img src={theme.author.avatarUrl} alt={theme.author.name} class="w-4 h-4 rounded-full" />
    ) : (
      <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
      </svg>
    )}
    <span class="text-xs text-zinc-500">{theme.author.name}</span>
  </div>

  <h3 class="mt-3 text-sm font-semibold text-zinc-100">{theme.name}</h3>

  {theme.description && (
    <p class="mt-1 text-sm text-zinc-400 leading-relaxed line-clamp-2">{theme.description}</p>
  )}

  {theme.keywords.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-3">
      {theme.keywords.map((keyword) => (
        <span class="rounded-full bg-zinc-800 px-2 py-0.5 text-[11px] text-zinc-400">{keyword}</span>
      ))}
    </div>
  )}
</a>
