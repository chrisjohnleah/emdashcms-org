---
interface Props {
  type: 'success' | 'error';
  message: string;
}

const { type, message } = Astro.props;

const styles = {
  success: 'bg-success-soft border-success/30 text-success',
  error: 'bg-danger-soft border-danger/35 text-danger',
};
---
<div
  role="alert"
  class:list={['rounded-md border px-4 py-3 text-sm', styles[type]]}
>
  {message}
</div>
