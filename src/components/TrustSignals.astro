---
/**
 * Honest trust signal panel for plugin and theme detail pages.
 *
 * The marketplace verifies identity and integrity, not behaviour. This
 * component is the user-facing version of that posture: explicit checks
 * shown, with the disclaimer right next to them.
 */
import type { MarketplacePluginDetail } from '../types/marketplace';

interface Props {
  plugin: MarketplacePluginDetail;
  publisherVerified: boolean;
  repositoryUrl: string | null;
  bundleDownloadUrl: string | null;
}

const { plugin, publisherVerified, repositoryUrl, bundleDownloadUrl } = Astro.props;

const audit = plugin.latestVersion?.audit ?? null;
const checksum = plugin.latestVersion?.checksum ?? null;

type Tone = 'pass' | 'info' | 'warn';
interface Signal {
  tone: Tone;
  label: string;
  detail: string;
}

const signals: Signal[] = [];

signals.push({
  tone: publisherVerified ? 'pass' : 'info',
  label: 'Publisher',
  detail: publisherVerified
    ? `Verified GitHub account: ${plugin.author.name}`
    : `${plugin.author.name} (unverified)`,
});

if (checksum) {
  signals.push({
    tone: 'pass',
    label: 'Bundle integrity',
    detail: `SHA-256 ${checksum.slice(0, 12)}…${checksum.slice(-4)} — reproducible from R2`,
  });
}

if (repositoryUrl) {
  signals.push({
    tone: 'pass',
    label: 'Source available',
    detail: 'Public repository linked — read the code before installing',
  });
} else if (bundleDownloadUrl) {
  signals.push({
    tone: 'info',
    label: 'Source available',
    detail: 'Bundle downloadable from this page — no public repo linked',
  });
}

signals.push({
  tone: 'pass',
  label: 'Manifest validated',
  detail: `${plugin.capabilities.length} capabilities checked against the EmDash contract`,
});

const latestStatus = plugin.latestVersion?.status ?? null;

if (audit) {
  if (audit.verdict === 'pass') {
    signals.push({
      tone: 'pass',
      label: 'AI review',
      detail: `Passed (risk score ${audit.riskScore}/100)`,
    });
  } else if (audit.verdict === 'warn') {
    signals.push({
      tone: 'warn',
      label: 'AI review',
      detail: `Warnings (risk score ${audit.riskScore}/100) — see findings below`,
    });
  } else if (audit.verdict === 'fail') {
    signals.push({
      tone: 'warn',
      label: 'AI review',
      detail: `Failed (risk score ${audit.riskScore}/100) — see findings below`,
    });
  } else {
    signals.push({
      tone: 'info',
      label: 'Manual review',
      detail: 'Reviewed by an admin (no AI verdict)',
    });
  }
} else if (latestStatus === 'published' || latestStatus === 'flagged') {
  // Static-first path: version is live based on the static scanner alone.
  // No AI verdict yet, but also not "pending moderation".
  signals.push({
    tone: latestStatus === 'flagged' ? 'warn' : 'pass',
    label: 'Static scan',
    detail:
      latestStatus === 'flagged'
        ? 'Passed static checks with findings — review before installing'
        : 'Passed static checks — AI review not yet run',
  });
} else {
  signals.push({
    tone: 'info',
    label: 'Manual review',
    detail: 'Pending moderation',
  });
}

// High-impact capability badges (mirrors the static-scanner warnings)
const sensitiveCapabilities: { cap: string; label: string }[] = [
  { cap: 'network:fetch:any', label: 'Unrestricted network access' },
  { cap: 'read:users', label: 'Reads user data' },
  { cap: 'email:intercept', label: 'Intercepts outbound email' },
  { cap: 'write:content', label: 'Modifies your content' },
  { cap: 'write:media', label: 'Modifies your media' },
];
const sensitiveDeclared = sensitiveCapabilities.filter((s) =>
  plugin.capabilities.includes(s.cap),
);

const toneStyle: Record<Tone, string> = {
  pass: 'bg-emerald-500/10 text-emerald-300 border-emerald-700/40',
  info: 'bg-zinc-800/60 text-zinc-300 border-zinc-700/40',
  warn: 'bg-amber-500/10 text-amber-300 border-amber-700/40',
};

const toneIcon: Record<Tone, string> = {
  pass: '✓',
  info: '○',
  warn: '⚠',
};
---

<div class="rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-5">
  <h2 class="text-sm font-semibold text-zinc-100">Trust signals</h2>
  <p class="mt-1 text-xs text-zinc-500">
    What this registry actually checks. Identity and integrity, not behaviour.
  </p>

  <ul class="mt-4 space-y-2.5">
    {signals.map((sig) => (
      <li class="flex items-start gap-2.5">
        <span
          class:list={[
            'flex-shrink-0 inline-flex h-5 w-5 items-center justify-center rounded-md border text-[11px] font-semibold',
            toneStyle[sig.tone],
          ]}
          aria-hidden="true"
        >
          {toneIcon[sig.tone]}
        </span>
        <div class="flex-1 min-w-0">
          <p class="text-xs font-medium text-zinc-200">{sig.label}</p>
          <p class="text-[11px] text-zinc-500">{sig.detail}</p>
        </div>
      </li>
    ))}
  </ul>

  {sensitiveDeclared.length > 0 && (
    <div class="mt-4 border-t border-zinc-800/60 pt-4">
      <p class="text-[11px] font-semibold text-zinc-400 uppercase tracking-wide">Sensitive capabilities declared</p>
      <ul class="mt-2 space-y-1">
        {sensitiveDeclared.map((s) => (
          <li class="flex items-start gap-2 text-[11px] text-amber-300">
            <span aria-hidden="true">⚠</span>
            <span>
              <code class="font-mono text-amber-200">{s.cap}</code> — {s.label}
            </span>
          </li>
        ))}
      </ul>
    </div>
  )}

  <p class="mt-4 border-t border-zinc-800/60 pt-4 text-[11px] leading-relaxed text-zinc-500">
    Install at your own risk. The bundle is open and downloadable from this page — read the code before installing. emdashcms.org is a community registry that vets identity and integrity, not runtime behaviour.
  </p>
</div>
