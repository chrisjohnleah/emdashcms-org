---
interface Props {
  verdict: string | null;
}

const { verdict } = Astro.props;

const variants: Record<string, { bg: string; text: string; border: string; label: string; ariaLabel: string }> = {
  pass: {
    bg: 'bg-success-soft',
    text: 'text-success',
    border: 'border-success/30',
    label: 'Passed',
    ariaLabel: 'Audit: passed',
  },
  warn: {
    bg: 'bg-warn-soft',
    text: 'text-warn',
    border: 'border-warn/35',
    label: 'Warning',
    ariaLabel: 'Audit: warning',
  },
  fail: {
    bg: 'bg-danger-soft',
    text: 'text-danger',
    border: 'border-danger/35',
    label: 'Failed',
    ariaLabel: 'Audit: failed',
  },
};

const fallback = {
  bg: 'bg-paper-sunk',
  text: 'text-ink-muted',
  border: 'border-rule',
  label: 'Pending',
  ariaLabel: 'Audit: pending',
};

const v = (verdict && variants[verdict]) || fallback;
---
<span
  class:list={['inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-medium border', v.bg, v.text, v.border]}
  aria-label={v.ariaLabel}
>
  {v.label}
</span>
