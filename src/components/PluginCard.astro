---
import type { MarketplacePluginSummary } from '../types/marketplace';
import AuditBadge from './AuditBadge.astro';

interface Props {
  plugin: MarketplacePluginSummary;
}

const { plugin } = Astro.props;
---
<a href={`/plugins/${plugin.id}`} class="block rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6 hover:border-zinc-700/60 hover:bg-zinc-900/60 transition-colors">
  <div class="flex items-center gap-2">
    {plugin.author.avatarUrl ? (
      <img src={plugin.author.avatarUrl} alt={plugin.author.name} class="w-4 h-4 rounded-full" />
    ) : (
      <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
      </svg>
    )}
    <span class="text-xs text-zinc-500">{plugin.author.name}</span>
  </div>

  <h3 class="mt-3 text-sm font-semibold text-zinc-100">{plugin.name}</h3>

  {plugin.description && (
    <p class="mt-1 text-sm text-zinc-400 leading-relaxed line-clamp-2">{plugin.description}</p>
  )}

  <div class="mt-4 flex items-center gap-2 flex-wrap">
    {plugin.latestVersion?.audit && (
      <AuditBadge verdict={plugin.latestVersion.audit.verdict} />
    )}

    <span class="inline-flex items-center gap-1 text-xs text-zinc-500">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
      </svg>
      {plugin.installCount.toLocaleString()}
    </span>

    {plugin.capabilities.map((cap) => (
      <span class="rounded-full bg-zinc-800 px-2 py-0.5 text-[11px] text-zinc-400">{cap}</span>
    ))}
  </div>
</a>
