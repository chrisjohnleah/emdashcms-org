---
/**
 * Shared Button component — consolidates the 22+ hand-rolled primary button
 * implementations across the site into one type-safe surface.
 *
 * Variants:
 *   - primary       → bg-ink text-paper hover:bg-accent-deep
 *                     Dashboard + form CTAs. Yellow on hover is the brand moment.
 *   - secondary     → bg-paper-soft border-rule text-ink hover:bg-paper-sunk
 *                     Subordinate actions, outlines, cancel-ish buttons.
 *   - destructive   → bg-danger-soft border-danger/40 text-danger
 *                     Destructive actions (delete, reject, revoke, ban).
 *   - ghost         → transparent, text-ink-muted hover:text-ink
 *                     Text-only subdued actions.
 *   - hero          → bg-ink text-paper px-8 py-3.5, hover:bg-accent-deep
 *                     Large marketing CTAs on the homepage and docs.
 *
 * Sizes:
 *   - sm  → px-3 py-1.5 text-xs
 *   - md  → px-4 py-2 text-sm
 *   - lg  → px-5 py-2.5 text-sm font-semibold   (default)
 *
 * The `hero` variant always renders at `lg` with `py-3.5` regardless of the
 * requested size, because that's the size the marketing CTAs actually need.
 *
 * Focus rings come from the global `:focus-visible` outline rule in
 * global.css — no per-component ring styles.
 *
 * When `href` is provided, renders as `<a>`. Otherwise renders as `<button>`
 * with a configurable `type` (default 'button'). `fullWidth` spans the
 * available width. Any additional attributes are passed through via
 * `...Astro.props` spread so consumers can attach `data-*` hooks, `disabled`,
 * `title`, `aria-*`, etc. without special casing.
 */

type Variant = 'primary' | 'secondary' | 'destructive' | 'ghost' | 'hero';
type Size = 'sm' | 'md' | 'lg';

interface Props {
  variant?: Variant;
  size?: Size;
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  fullWidth?: boolean;
  target?: string;
  rel?: string;
  id?: string;
  title?: string;
  class?: string;
}

const {
  variant = 'primary',
  size = 'lg',
  href,
  type = 'button',
  disabled = false,
  fullWidth = false,
  target,
  rel,
  id,
  title,
  class: extraClass,
  ...rest
} = Astro.props;

const variantClass: Record<Variant, string> = {
  primary:
    'bg-ink text-paper hover:bg-accent-deep border border-ink hover:border-accent-deep',
  secondary:
    'bg-paper-soft border border-rule-strong text-ink hover:bg-paper-sunk hover:border-ink',
  destructive:
    'bg-danger-soft border border-danger/40 text-danger hover:bg-danger-soft hover:border-danger',
  ghost:
    'text-ink-muted hover:text-ink border border-transparent',
  hero:
    'bg-ink text-paper hover:bg-accent-deep border border-ink hover:border-accent-deep',
};

const sizeClass: Record<Size, string> = {
  sm: 'px-3 py-1.5 text-xs',
  md: 'px-4 py-2 text-sm',
  lg: 'px-5 py-2.5 text-sm font-semibold',
};

// Hero variant forces lg + taller padding regardless of requested size.
const finalSizeClass = variant === 'hero' ? 'px-7 py-3.5 text-sm font-semibold' : sizeClass[size];

const baseClass = [
  'inline-flex items-center justify-center gap-2 rounded transition-colors',
  disabled ? 'opacity-50 cursor-not-allowed' : 'cursor-pointer',
  fullWidth ? 'w-full' : '',
  variantClass[variant],
  finalSizeClass,
  extraClass ?? '',
]
  .filter(Boolean)
  .join(' ');
---
{href ? (
  <a
    href={disabled ? undefined : href}
    class={baseClass}
    target={target}
    rel={rel}
    id={id}
    title={title}
    aria-disabled={disabled || undefined}
    {...rest}
  >
    <slot />
  </a>
) : (
  <button
    type={type}
    disabled={disabled}
    class={baseClass}
    id={id}
    title={title}
    {...rest}
  >
    <slot />
  </button>
)}
