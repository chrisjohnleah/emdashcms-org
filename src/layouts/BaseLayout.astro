---
export const prerender = false;

import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;
const siteUrl = 'https://emdashcms.org';

const navLinks = [
  { label: 'Plugins', href: '/plugins' },
  { label: 'Themes', href: '/themes' },
  { label: 'Guide', href: '/guide' },
  { label: 'Dashboard', href: '/dashboard' },
];
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={siteUrl + currentPath} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl + currentPath} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" defer></script>
  </head>
  <body class="bg-obsidian text-silver antialiased font-sans selection:bg-white selection:text-black min-h-screen flex flex-col relative overflow-x-hidden">

    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[60] focus:rounded-lg focus:bg-zinc-100 focus:px-4 focus:py-2 focus:text-zinc-950 focus:text-sm focus:font-semibold">Skip to content</a>

    <header class="fixed top-0 inset-x-0 z-50 border-b border-white/5 bg-obsidian/60 backdrop-blur-md">
      <div class="mx-auto max-w-7xl flex items-center justify-between px-6 h-16">
        <div class="flex items-center gap-8">
          <a href="/" class="text-xl font-bold tracking-tighter flex items-center text-white hover:opacity-80 transition-opacity">
            em<span class="text-ash mx-[2px] font-mono font-light">&mdash;</span>dash
            <span class="text-xs text-ash ml-2 font-mono border border-white/10 px-1.5 py-0.5 rounded bg-white/5">org</span>
          </a>
          <nav class="hidden md:flex gap-6 text-sm font-medium text-ash">
            {navLinks.map((link) => (
              <a
                href={link.href}
                class:list={[
                  'transition-colors duration-200',
                  currentPath.startsWith(link.href)
                    ? 'text-white'
                    : 'hover:text-white',
                ]}
              >
                {link.label}
              </a>
            ))}
          </nav>
        </div>

        <div class="flex items-center gap-4">
          <a href="https://github.com/chrisjohnleah/emdashcms-org" target="_blank" rel="noopener noreferrer" class="hidden md:flex items-center gap-2 text-sm text-ash hover:text-white transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16"><path d="M8 .2a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38l-.01-1.49c-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.42 7.42 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48l-.01 2.2c0 .21.15.46.55.38A8.01 8.01 0 0 0 8 .2Z" /></svg>
            GitHub
          </a>
          <span class="hidden sm:inline-flex items-center rounded-full border border-amber-800/60 bg-amber-950/40 px-2.5 py-0.5 text-[11px] text-amber-400 font-medium tracking-wide uppercase">
            Under construction
          </span>
        </div>
      </div>
    </header>

    <main id="main" class="flex-grow">
      <slot />
    </main>

    <footer class="border-t border-white/5 bg-obsidian relative z-10 pt-16 pb-8">
      <div class="mx-auto max-w-7xl px-6 grid grid-cols-2 md:grid-cols-4 gap-10 mb-16 text-sm leading-loose">
        <div class="col-span-2 md:col-span-1">
          <a href="/" class="text-xl font-bold tracking-tighter text-white mb-4 block">
            em<span class="text-ash mx-[2px] font-mono font-light">&mdash;</span>dash
          </a>
          <p class="text-ash/60 text-xs max-w-xs leading-relaxed mb-4">
            Community marketplace for EmDash CMS. Not affiliated with Cloudflare or the EmDash project.
          </p>
          <div class="flex gap-4 text-ash">
            <a href="https://github.com/chrisjohnleah/emdashcms-org" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16"><path d="M8 .2a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38l-.01-1.49c-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.42 7.42 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48l-.01 2.2c0 .21.15.46.55.38A8.01 8.01 0 0 0 8 .2Z" /></svg>
            </a>
            <a href="https://x.com/chrisleah" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg>
            </a>
          </div>
        </div>

        <div>
          <h4 class="text-white mb-4 uppercase tracking-widest text-[10px]">Marketplace</h4>
          <ul class="text-ash space-y-2">
            <li><a href="/plugins" class="hover:text-white transition-colors">All Plugins</a></li>
            <li><a href="/themes" class="hover:text-white transition-colors">All Themes</a></li>
            <li><a href="/dashboard" class="hover:text-white transition-colors">Dashboard</a></li>
          </ul>
        </div>

        <div>
          <h4 class="text-white mb-4 uppercase tracking-widest text-[10px]">Project</h4>
          <ul class="text-ash space-y-2">
            <li><a href="https://emdashcms.com" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">EmDash CMS</a></li>
            <li><a href="https://github.com/chrisjohnleah/emdashcms-org" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">GitHub</a></li>
            <li><a href="https://x.com/chrisleah" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">@chrisleah</a></li>
          </ul>
        </div>

        <div>
          <h4 class="text-white mb-4 uppercase tracking-widest text-[10px]">Legal</h4>
          <ul class="text-ash space-y-2">
            <li><a href="/docs/security" class="hover:text-white transition-colors">Security &amp; Review Policy</a></li>
            <li><a href="https://github.com/chrisjohnleah/emdashcms-org/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">MIT License</a></li>
          </ul>
        </div>
      </div>

      <div class="mx-auto max-w-7xl px-6 border-t border-white/5 pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-ash/40 font-mono">
        <p>emdashcms.org &mdash; Community Marketplace for EmDash&nbsp;CMS</p>
        <p class="mt-4 md:mt-0">Built on Cloudflare Workers &middot; Open Source &middot; MIT</p>
      </div>
    </footer>

  </body>
</html>
