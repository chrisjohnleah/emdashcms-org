---
export const prerender = false;

import { env } from 'cloudflare:workers';
import '../styles/global.css';
import MobileNav from '../components/MobileNav.astro';
import DashboardBanner from '../components/DashboardBanner.astro';
import { hasAuthorBounced } from '../lib/notifications/settings-handlers';
import { resolveAuthorId } from '../lib/publishing/plugin-queries';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
const currentPath = Astro.url.pathname;
const siteUrl = 'https://emdashcms.org';

const navLinks = [
  { label: 'Plugins', href: '/plugins' },
  { label: 'Themes', href: '/themes' },
  { label: 'Publish', href: '/dashboard' },
  { label: 'Guide', href: '/guide' },
];

// Global notification-bounce banner (Plan 12-03, D-22).
//
// When an authenticated publisher is on a /dashboard/* page and their
// `authors.email_bounced_at` is set, surface a persistent warn banner
// with a link to the settings page where they can fix the override.
//
// Restrict the extra D1 read to authenticated dashboard paths only so
// public listings stay free-tier cheap. One indexed single-column
// SELECT per dashboard page load is comfortably within budget.
let showBounceBanner = false;
try {
  if (Astro.locals.author && currentPath.startsWith('/dashboard')) {
    const authorId = await resolveAuthorId(env.DB, Astro.locals.author.githubId);
    if (authorId) {
      showBounceBanner = await hasAuthorBounced(env.DB, authorId);
    }
  }
} catch (err) {
  // Banner is cosmetic — a transient D1 error should never 500 the page.
  console.error('[BaseLayout] bounce banner lookup failed:', err);
}
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={siteUrl + currentPath} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl + currentPath} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}

    <meta name="theme-color" content="#fbf8f1" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..600&family=Public+Sans:wght@300..700&display=swap"
      rel="stylesheet"
    />

    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" defer></script>
  </head>
  <body class="bg-paper text-ink antialiased min-h-screen flex flex-col">

    <a href="#main" class="skip-link">Skip to content</a>

    <header class="sticky top-0 z-50 bg-paper/90 backdrop-blur-sm border-b border-rule">
      <div class="page flex items-center justify-between h-16">

        <div class="flex items-center gap-10">
          <a
            href="/"
            class="font-display text-[1.6rem] leading-none tracking-tight text-ink hover:text-accent-deep transition-colors"
            style="font-variation-settings: 'opsz' 96; font-weight: 500;"
          >
            em—dash
          </a>

          <nav class="hidden md:flex items-baseline gap-7 text-sm" aria-label="Primary">
            {navLinks.map((link) => {
              const active = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
              return (
                <a
                  href={link.href}
                  class:list={[
                    'transition-colors',
                    active
                      ? 'text-ink font-medium'
                      : 'text-ink-muted hover:text-ink',
                  ]}
                  aria-current={active ? 'page' : undefined}
                >
                  {link.label}
                </a>
              );
            })}
          </nav>
        </div>

        <div class="flex items-center gap-5">
          <a
            href="https://github.com/chrisjohnleah/emdashcms-org"
            target="_blank"
            rel="noopener noreferrer"
            class="hidden md:inline-flex items-center gap-1.5 text-sm text-ink-muted hover:text-ink transition-colors"
            aria-label="GitHub repository"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M8 .2a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38l-.01-1.49c-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.42 7.42 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48l-.01 2.2c0 .21.15.46.55.38A8.01 8.01 0 0 0 8 .2Z" />
            </svg>
            GitHub
          </a>

          <button
            type="button"
            data-mobile-nav-toggle
            aria-expanded="false"
            aria-controls="mobile-nav"
            aria-label="Open navigation menu"
            class="md:hidden inline-flex items-center justify-center w-9 h-9 rounded text-ink hover:bg-paper-soft transition-colors"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </button>
        </div>

      </div>
    </header>

    <MobileNav links={navLinks} currentPath={currentPath} />

    <main id="main" class="flex-grow">
      {showBounceBanner && (
        <div class="page pt-4">
          <DashboardBanner
            type="warn"
            message="Your notification email is bouncing. Update it in your notification settings at /dashboard/settings to resume delivery."
          />
        </div>
      )}
      <slot />
    </main>

    <footer class="border-t border-rule mt-24">

      <div class="page py-16">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12">

          <div class="md:col-span-5">
            <a
              href="/"
              class="font-display text-2xl text-ink leading-none"
              style="font-variation-settings: 'opsz' 96; font-weight: 500;"
            >
              em—dash
            </a>
            <p class="mt-4 text-sm text-ink-muted leading-relaxed max-w-sm">
              A community marketplace for plugins and themes built on
              <a
                href="https://emdashcms.com"
                target="_blank"
                rel="noopener noreferrer"
                class="text-ink underline underline-offset-2 decoration-accent-deep decoration-1 hover:decoration-2"
              >EmDash CMS</a>.
              Free to publish, free to install, MIT licensed, audited.
            </p>
            <p class="mt-3 text-xs text-ink-soft">
              Independent community project. Not affiliated with Cloudflare or the EmDash project.
            </p>
          </div>

          <div class="md:col-span-2">
            <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-soft mb-4">Marketplace</h4>
            <ul class="space-y-2.5 text-sm">
              <li><a href="/plugins" class="text-ink-muted hover:text-ink transition-colors">Plugins</a></li>
              <li><a href="/themes" class="text-ink-muted hover:text-ink transition-colors">Themes</a></li>
              <li><a href="/guide" class="text-ink-muted hover:text-ink transition-colors">Install guide</a></li>
            </ul>
          </div>

          <div class="md:col-span-2">
            <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-soft mb-4">Publish</h4>
            <ul class="space-y-2.5 text-sm">
              <li><a href="/dashboard" class="text-ink-muted hover:text-ink transition-colors">Dashboard</a></li>
              <li><a href="/docs/contributors" class="text-ink-muted hover:text-ink transition-colors">Contributor guide</a></li>
              <li><a href="/docs/security" class="text-ink-muted hover:text-ink transition-colors">Security policy</a></li>
            </ul>
          </div>

          <div class="md:col-span-3">
            <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-soft mb-4">Project</h4>
            <ul class="space-y-2.5 text-sm">
              <li>
                <a href="https://emdashcms.com" target="_blank" rel="noopener noreferrer" class="text-ink-muted hover:text-ink transition-colors">EmDash CMS</a>
              </li>
              <li>
                <a href="https://github.com/chrisjohnleah/emdashcms-org" target="_blank" rel="noopener noreferrer" class="text-ink-muted hover:text-ink transition-colors">GitHub</a>
              </li>
              <li><a href="/code-of-conduct" class="text-ink-muted hover:text-ink transition-colors">Code of conduct</a></li>
              <li><a href="/privacy" class="text-ink-muted hover:text-ink transition-colors">Privacy</a></li>
              <li><a href="/terms" class="text-ink-muted hover:text-ink transition-colors">Terms</a></li>
            </ul>
          </div>

        </div>

        <div class="mt-16 pt-8 border-t border-rule flex flex-col md:flex-row items-start md:items-center justify-between gap-3 text-xs text-ink-soft">
          <p>
            emdashcms.org
            <span class="emdash-sep" aria-hidden="true"></span>
            Built on Cloudflare Workers
            <span class="emdash-sep" aria-hidden="true"></span>
            MIT
          </p>
          <p>
            <a href="https://github.com/chrisjohnleah/emdashcms-org/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="hover:text-ink transition-colors">View licence</a>
          </p>
        </div>
      </div>

    </footer>

  </body>
</html>
