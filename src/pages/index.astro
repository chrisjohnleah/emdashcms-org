---
// Force SSR to avoid miniflare queue consumer conflict during prerender build step.
// All pages in this project use SSR since we need Cloudflare bindings (D1, R2, KV, Queue).
export const prerender = false;

import '../styles/global.css';

const title = "emdashcms.org — Parked";
const description = "This domain was registered with the intention of building a community plugin marketplace for EmDash CMS. The official team already have one in progress, so this project is on hold.";
const url = "https://emdashcms.org";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-zinc-950 text-zinc-100 antialiased font-sans">

    <main class="min-h-screen flex items-center justify-center px-6">
      <div class="max-w-lg text-center">
        <p class="text-zinc-500 font-mono text-2xl mb-6" aria-hidden="true">&mdash;</p>
        <h1 class="text-xl sm:text-2xl font-semibold tracking-tight">
          emdashcms.org
        </h1>
        <div class="mt-8 space-y-4 text-sm text-zinc-400 leading-relaxed">
          <p>
            This domain was registered on the day <a href="https://emdashcms.com" target="_blank" rel="noopener noreferrer" class="text-zinc-300 hover:text-zinc-100 underline underline-offset-2 transition-colors">EmDash&nbsp;CMS</a> launched, with the intention of building a community plugin and theme marketplace.
          </p>
          <p>
            After a couple of days digging into the <a href="https://github.com/emdash-cms/emdash" target="_blank" rel="noopener noreferrer" class="text-zinc-300 hover:text-zinc-100 underline underline-offset-2 transition-colors">main&nbsp;repo</a>, it became clear the official team already have a marketplace in progress. No point duplicating that work.
          </p>
          <p>
            This project is parked for now. If a genuine community need emerges that the official project doesn't cover, this domain is here for it.
          </p>
        </div>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="https://github.com/emdash-cms/emdash" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 rounded-lg border border-zinc-800 bg-zinc-900 px-4 py-2 text-sm text-zinc-300 hover:bg-zinc-800 hover:text-zinc-100 transition-colors">
            Official EmDash repo
          </a>
          <a href="https://github.com/chrisjohnleah/emdashcms-org" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 rounded-lg border border-zinc-800 bg-zinc-900 px-4 py-2 text-sm text-zinc-300 hover:bg-zinc-800 hover:text-zinc-100 transition-colors">
            This repo
          </a>
        </div>
      </div>
    </main>

    <footer class="fixed bottom-0 inset-x-0 px-6 py-4">
      <div class="mx-auto max-w-lg flex items-center justify-between text-[11px] text-zinc-700">
        <span>Not affiliated with Cloudflare or EmDash</span>
        <a href="https://x.com/chrisleah" target="_blank" rel="noopener noreferrer" class="hover:text-zinc-500 transition-colors">@chrisleah</a>
      </div>
    </footer>

  </body>
</html>
