---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';

const title = "emdashcms.org — Community marketplace for EmDash CMS";
const description = "An open, community-driven plugin and theme marketplace for EmDash CMS. Browse, publish, and install plugins with automated security auditing. Built on Cloudflare.";
---
<BaseLayout title={title} description={description}>

  <!-- Ambient lighting -->
  <div class="ambient-glow bg-emerald-500 w-[600px] h-[600px] top-[-200px] left-[-100px]"></div>
  <div class="ambient-glow bg-blue-500 w-[500px] h-[500px] top-[20%] right-[-100px]"></div>

  <!-- Grid background -->
  <div class="absolute inset-0 bg-grid-pattern h-[800px] z-[-1] opacity-50"></div>

  <!-- Hero -->
  <section class="pt-32 pb-0 px-6">
    <div class="mx-auto max-w-7xl flex flex-col items-center text-center">

      <a href="https://github.com/chrisjohnleah/emdashcms-org" target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-ash hover:text-white hover:bg-white/10 transition-all mb-8 backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
        </span>
        Under active development &mdash; follow on GitHub
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
      </a>

      <h1 class="text-5xl md:text-7xl font-bold tracking-tighter leading-[1.1] mb-6 text-transparent bg-clip-text bg-gradient-to-b from-white to-ash">
        The community marketplace for<br />
        EmDash plugins and themes
      </h1>

      <p class="text-lg md:text-xl text-ash max-w-2xl font-light mb-10 leading-relaxed">
        Browse, discover, and install verified extensions for
        <a href="https://emdashcms.com" target="_blank" rel="noopener noreferrer" class="text-silver hover:text-white underline underline-offset-2 transition-colors">EmDash&nbsp;CMS</a>.
        Every submission is AI-audited, structurally validated, and ready for production.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mb-24 w-full sm:w-auto">
        <a href="/plugins"
           class="bg-white text-black px-8 py-3.5 rounded-lg font-medium hover:bg-gray-200 transition-all flex items-center justify-center gap-2 text-sm shadow-[0_0_20px_rgba(255,255,255,0.15)]">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 0 1-.657.643 48.39 48.39 0 0 1-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 0 1-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 0 0-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 0 1-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 0 0 .657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 0 1-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 0 0 5.427-.63 48.05 48.05 0 0 0 .582-4.717.532.532 0 0 0-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.96.401v0a.656.656 0 0 0 .657-.663 48.422 48.422 0 0 0-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 0 1-.61-.58v0Z" /></svg>
          Browse Plugins
        </a>
        <a href="/themes"
           class="relative bg-obsidian border border-white/20 text-white px-8 py-3.5 rounded-lg font-medium hover:bg-white/5 transition-all flex items-center justify-center gap-2 text-sm group">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-gray-500 to-gray-700 rounded-lg blur opacity-20 group-hover:opacity-40 transition duration-500 z-[-1]"></div>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 0 0 5.304 0l6.401-6.402M6.75 21A3.75 3.75 0 0 1 3 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 0 0 3.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008Z" /></svg>
          Browse Themes
        </a>
      </div>

      <!-- Floating preview cards -->
      <div class="relative w-full max-w-5xl h-[300px] md:h-[400px] flex justify-center">

        <!-- Left: Theme card -->
        <div class="absolute w-[280px] md:w-[320px] left-0 md:left-10 top-12 glass-card rounded-xl p-5 -rotate-6 animate-float-slow z-10 hidden sm:block">
          <div class="h-32 bg-tungsten rounded-lg mb-4 relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-purple-900/40 to-blue-900/40"></div>
            <div class="absolute top-2 right-2 bg-black/60 backdrop-blur-sm px-2 py-1 rounded text-[10px] font-mono border border-white/10 uppercase">Theme</div>
          </div>
          <div class="flex justify-between items-start mb-1">
            <h3 class="font-semibold text-white text-sm">Aura Minimalist</h3>
          </div>
          <p class="text-xs text-ash mb-3 text-left">A strictly typography-first portfolio theme.</p>
          <div class="flex items-center justify-between text-xs border-t border-white/10 pt-3">
            <span class="text-ash">@designco</span>
            <span class="text-ash font-mono">1.2k installs</span>
          </div>
        </div>

        <!-- Center: Plugin card (hero) -->
        <div class="absolute w-[300px] md:w-[350px] top-0 glass-card rounded-xl p-6 shadow-2xl scale-105 animate-float-medium z-30">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-500 to-teal-700 flex items-center justify-center mb-5 shadow-lg border border-white/20">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" /></svg>
          </div>
          <h3 class="font-bold text-lg text-white mb-1 text-left flex items-center gap-2">
            Stripe Commerce Bridge
            <svg class="w-4 h-4 text-blue-400 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0 1 12 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 0 1 3.498 1.307 4.491 4.491 0 0 1 1.307 3.497A4.49 4.49 0 0 1 21.75 12a4.49 4.49 0 0 1-1.549 3.397 4.491 4.491 0 0 1-1.307 3.497 4.491 4.491 0 0 1-3.497 1.307A4.49 4.49 0 0 1 12 21.75a4.49 4.49 0 0 1-3.397-1.549 4.49 4.49 0 0 1-3.498-1.306 4.491 4.491 0 0 1-1.307-3.498A4.49 4.49 0 0 1 2.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 0 1 1.307-3.497 4.49 4.49 0 0 1 3.497-1.307Zm7.007 6.387a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" /></svg>
          </h3>
          <p class="text-sm text-ash mb-5 text-left leading-relaxed">Full checkouts, webhook syncing, and product inventory management inside your CMS.</p>

          <div class="flex items-center gap-2 mb-5">
            <div class="bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-2 py-1 rounded text-xs flex items-center gap-1 font-medium">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12.516 2.17a.75.75 0 0 0-1.032 0 11.209 11.209 0 0 1-7.877 3.08.75.75 0 0 0-.722.515A12.74 12.74 0 0 0 2.25 9.75c0 5.942 4.064 10.933 9.563 12.348a.749.749 0 0 0 .374 0c5.499-1.415 9.563-6.406 9.563-12.348 0-1.39-.223-2.73-.635-3.985a.75.75 0 0 0-.722-.516l-.143.001c-2.996 0-5.717-1.17-7.734-3.08Zm3.094 8.016a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" /></svg>
              Safely Audited
            </div>
            <div class="bg-white/5 text-ash border border-white/10 px-2 py-1 rounded text-xs font-mono">
              v2.4.1
            </div>
          </div>

          <div class="w-full bg-white text-black py-2 rounded-md text-sm font-medium text-center">
            View Plugin
          </div>
        </div>

        <!-- Right: Plugin card -->
        <div class="absolute w-[280px] md:w-[320px] right-0 md:right-10 top-20 glass-card rounded-xl p-5 rotate-3 animate-float-fast z-20 hidden md:block">
          <div class="w-10 h-10 rounded-lg bg-carbon border border-white/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg>
          </div>
          <h3 class="font-semibold text-white text-sm mb-1">Algolia Search Sync</h3>
          <p class="text-xs text-ash mb-3 text-left">Push your content nodes directly to Algolia indices on publish.</p>
          <div class="flex items-center justify-between text-xs border-t border-white/10 pt-3">
            <span class="text-ash">@searchteam</span>
            <span class="text-ash font-mono text-emerald-400">Free</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Value propositions -->
  <section class="py-20 sm:py-32 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="mb-16">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">A catalog built on trust.</h2>
        <p class="text-ash max-w-2xl">A centralized, secure, and beautiful way to expand your EmDash site without compromising safety or performance.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Rich Discovery -->
        <div class="border-gradient md:col-span-2 p-8 md:p-10 flex flex-col md:flex-row gap-8 overflow-hidden group">
          <div class="flex-1 z-10 flex flex-col justify-center">
            <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25Z" /></svg>
            </div>
            <h3 class="text-xl md:text-2xl font-bold mb-3">Rich Discovery.</h3>
            <p class="text-ash text-sm leading-relaxed max-w-sm">
              Find exactly what you need. Filter by capability, search by keyword, or browse by author. Every listing includes descriptions, version history, and audit results.
            </p>
          </div>

          <div class="flex-1 relative translate-x-4 md:translate-x-10 translate-y-4 md:translate-y-10 group-hover:-translate-y-2 group-hover:-translate-x-2 transition-transform duration-500">
            <div class="bg-carbon border border-white/10 rounded-tl-xl p-4 h-full shadow-2xl flex flex-col gap-3">
              <div class="bg-tungsten border border-white/5 rounded-md p-2 flex gap-2 overflow-hidden mb-2">
                <span class="bg-white/10 text-white text-[10px] px-2 py-1 rounded">E-Commerce</span>
                <span class="bg-white/10 text-white text-[10px] px-2 py-1 rounded">v2.x</span>
                <span class="text-ash text-[10px] py-1">Type to filter...</span>
              </div>
              <div class="flex items-center gap-3 bg-white/5 rounded-md p-3 border border-white/5">
                <div class="w-8 h-8 rounded bg-purple-500/20 text-purple-400 flex items-center justify-center">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M4.5 3.75a3 3 0 0 0-3 3v.75h21v-.75a3 3 0 0 0-3-3h-15Z" /><path fill-rule="evenodd" d="M22.5 9.75h-21v7.5a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3v-7.5Zm-18 3.75a.75.75 0 0 1 .75-.75h6a.75.75 0 0 1 0 1.5h-6a.75.75 0 0 1-.75-.75Zm.75 2.25a.75.75 0 0 0 0 1.5h3a.75.75 0 0 0 0-1.5h-3Z" clip-rule="evenodd" /></svg>
                </div>
                <div>
                  <div class="text-xs font-semibold text-white">Stripe Checkout</div>
                  <div class="text-[10px] text-ash">Payment gateways</div>
                </div>
              </div>
              <div class="flex items-center gap-3 bg-white/5 rounded-md p-3 border border-white/5">
                <div class="w-8 h-8 rounded bg-blue-500/20 text-blue-400 flex items-center justify-center">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z" /><path d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z" /></svg>
                </div>
                <div>
                  <div class="text-xs font-semibold text-white">SendGrid Sync</div>
                  <div class="text-[10px] text-ash">Marketing</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- AI Auditing -->
        <div class="border-gradient p-8 flex flex-col group relative overflow-hidden">
          <div class="absolute -right-10 -bottom-10 w-[180px] h-[180px] text-emerald-500/5 rotate-12 group-hover:scale-110 transition-transform duration-700">
            <svg class="w-full h-full" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12.516 2.17a.75.75 0 0 0-1.032 0 11.209 11.209 0 0 1-7.877 3.08.75.75 0 0 0-.722.515A12.74 12.74 0 0 0 2.25 9.75c0 5.942 4.064 10.933 9.563 12.348a.749.749 0 0 0 .374 0c5.499-1.415 9.563-6.406 9.563-12.348 0-1.39-.223-2.73-.635-3.985a.75.75 0 0 0-.722-.516l-.143.001c-2.996 0-5.717-1.17-7.734-3.08Zm3.094 8.016a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" /></svg>
          </div>

          <div class="z-10 h-full flex flex-col pt-2">
            <div class="w-10 h-10 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>
            </div>
            <h3 class="text-xl md:text-2xl font-bold mb-3">Audited automatically.</h3>
            <p class="text-ash text-sm leading-relaxed mb-6 flex-grow">
              Every plugin and theme upload is AI-scanned for security vulnerabilities before it reaches the registry. Fail-closed &mdash; nothing publishes without passing audit.
            </p>

            <div class="bg-black/40 border border-white/5 rounded-lg p-3 space-y-2 mt-auto">
              <div class="flex justify-between items-center text-xs">
                <span class="text-white flex items-center gap-2">
                  <svg class="w-3.5 h-3.5 text-emerald-500" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" /></svg>
                  Code Quality
                </span>
                <span class="font-mono text-ash/60">PASS</span>
              </div>
              <div class="flex justify-between items-center text-xs">
                <span class="text-white flex items-center gap-2">
                  <svg class="w-3.5 h-3.5 text-emerald-500" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" /></svg>
                  Security Scan
                </span>
                <span class="font-mono text-ash/60">PASS</span>
              </div>
              <div class="flex justify-between items-center text-xs">
                <span class="text-white flex items-center gap-2">
                  <svg class="w-3.5 h-3.5 text-emerald-500" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" /></svg>
                  Dependencies
                </span>
                <span class="font-mono text-ash/60">CLEAN</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Open Infrastructure (full width) -->
        <div class="border-gradient md:col-span-3 p-8 md:p-10 flex flex-col md:flex-row items-center gap-10 group overflow-hidden">
          <div class="flex-1 z-10 w-full">
            <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" /></svg>
            </div>
            <h3 class="text-xl md:text-2xl font-bold mb-3">Open infrastructure. Community first.</h3>
            <p class="text-ash text-sm leading-relaxed max-w-lg mb-6">
              Built on Cloudflare Workers. Open source under MIT. Compatible with the EmDash marketplace API &mdash; point any EmDash site here and it just works.
            </p>
            <div class="flex gap-4">
              <div class="text-left border-l-2 border-white/10 pl-3">
                <div class="text-white font-bold text-xl mb-1">MIT</div>
                <div class="text-xs text-ash font-mono uppercase tracking-widest">Licensed</div>
              </div>
              <div class="text-left border-l-2 border-white/10 pl-3">
