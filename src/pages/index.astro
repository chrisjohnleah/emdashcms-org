---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';
import PluginCard from '../components/PluginCard.astro';
import { searchPlugins, searchThemes } from '../lib/db/queries';

const title = "emdashcms.org — Community marketplace for EmDash CMS";
const description = "An open, community-driven plugin and theme marketplace for EmDash CMS. Browse, publish, and install plugins with automated security auditing. Built on Cloudflare.";

const [latestResult, popularResult, themesResult] = await Promise.all([
  searchPlugins(env.DB, { query: '', category: null, capability: null, sort: 'created', cursor: null, limit: 6 }),
  searchPlugins(env.DB, { query: '', category: null, capability: null, sort: 'installs', cursor: null, limit: 6 }),
  searchThemes(env.DB, { query: '', category: null, keyword: null, sort: 'created', cursor: null, limit: 4 }),
]);

const popularWithInstalls = popularResult.items.filter(p => p.installCount > 0);

// OAuth callback redirects banned authors here with ?banned=1
const showBannedNotice = Astro.url.searchParams.get('banned') === '1';
---
<BaseLayout title={title} description={description}>

  {showBannedNotice && (
    <div class="bg-red-950/60 border-b border-red-800/60">
      <div class="mx-auto max-w-7xl px-6 py-4 flex items-start gap-3">
        <svg class="w-5 h-5 text-red-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
        </svg>
        <div class="flex-1">
          <p class="text-sm font-semibold text-red-300">Your account has been suspended from publishing</p>
          <p class="mt-1 text-xs text-red-300/80">
            You can still browse the marketplace but cannot register new plugins or themes or upload new versions.
            See our <a href="/code-of-conduct" class="underline hover:text-red-200">Code of Conduct</a> for the policies we enforce.
            If you believe this is a mistake, open an issue at
            <a href="https://github.com/chrisjohnleah/emdashcms-org/issues" target="_blank" rel="noopener noreferrer" class="underline hover:text-red-200">github.com/chrisjohnleah/emdashcms-org/issues</a>.
          </p>
        </div>
      </div>
    </div>
  )}

  <!-- Ambient lighting -->
  <div class="ambient-glow bg-emerald-500 w-[600px] h-[600px] top-[-200px] left-[-100px]"></div>
  <div class="ambient-glow bg-blue-500 w-[500px] h-[500px] top-[20%] right-[-100px]"></div>

  <!-- Grid background -->
  <div class="absolute inset-0 bg-grid-pattern h-[800px] z-[-1] opacity-50"></div>

  <!-- Hero -->
  <section class="pt-32 pb-20 px-6">
    <div class="mx-auto max-w-7xl flex flex-col items-center text-center">

      <a href="https://github.com/chrisjohnleah/emdashcms-org" target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-ash hover:text-white hover:bg-white/10 transition-all mb-8 backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
        </span>
        Under active development &mdash; follow on GitHub
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
      </a>

      <h1 class="text-5xl md:text-7xl font-bold tracking-tighter leading-[1.1] mb-6 text-transparent bg-clip-text bg-gradient-to-b from-white to-ash">
        The community marketplace for<br />
        EmDash plugins and themes
      </h1>

      <p class="text-lg md:text-xl text-ash max-w-2xl font-light mb-10 leading-relaxed">
        Browse, discover, and install verified extensions for
        <a href="https://emdashcms.com" target="_blank" rel="noopener noreferrer" class="text-silver hover:text-white underline underline-offset-2 transition-colors">EmDash&nbsp;CMS</a>.
        Every submission is AI-audited, structurally validated, and ready for production.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
        <a href="/plugins"
           class="bg-white text-black px-8 py-3.5 rounded-lg font-medium hover:bg-gray-200 transition-all flex items-center justify-center gap-2 text-sm shadow-[0_0_20px_rgba(255,255,255,0.15)]">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 0 1-.657.643 48.39 48.39 0 0 1-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 0 1-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 0 0-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 0 1-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 0 0 .657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 0 1-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 0 0 5.427-.63 48.05 48.05 0 0 0 .582-4.717.532.532 0 0 0-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.96.401v0a.656.656 0 0 0 .657-.663 48.422 48.422 0 0 0-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 0 1-.61-.58v0Z" /></svg>
          Browse Plugins
        </a>
        <a href="/themes"
           class="relative bg-obsidian border border-white/20 text-white px-8 py-3.5 rounded-lg font-medium hover:bg-white/5 transition-all flex items-center justify-center gap-2 text-sm group">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-gray-500 to-gray-700 rounded-lg blur opacity-20 group-hover:opacity-40 transition duration-500 z-[-1]"></div>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 0 0 5.304 0l6.401-6.402M6.75 21A3.75 3.75 0 0 1 3 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 0 0 3.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008Z" /></svg>
          Browse Themes
        </a>
      </div>

    </div>
  </section>

  <!-- Latest Plugins -->
  {latestResult.items.length > 0 && (
    <section class="py-20 px-6">
      <div class="mx-auto max-w-7xl">
        <div class="flex items-end justify-between mb-8">
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight">Latest Plugins</h2>
          <a href="/plugins" class="text-sm text-zinc-400 hover:text-white transition-colors flex items-center gap-1">
            View all plugins
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {latestResult.items.map((p) => (
            <PluginCard plugin={p} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Most Installed -->
  {popularWithInstalls.length > 0 && (
    <section class="py-20 px-6">
      <div class="mx-auto max-w-7xl">
        <div class="flex items-end justify-between mb-8">
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight">Most Installed</h2>
          <a href="/plugins" class="text-sm text-zinc-400 hover:text-white transition-colors flex items-center gap-1">
            View all plugins
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {popularWithInstalls.map((p) => (
            <PluginCard plugin={p} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Latest Themes -->
  {themesResult.items.length > 0 && (
    <section class="py-20 px-6">
      <div class="mx-auto max-w-7xl">
        <div class="flex items-end justify-between mb-8">
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight">Latest Themes</h2>
          <a href="/themes" class="text-sm text-zinc-400 hover:text-white transition-colors flex items-center gap-1">
            View all themes
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {themesResult.items.map((t) => (
            <a href={`/themes/${t.id}`} class="block rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6 hover:border-zinc-700/60 hover:bg-zinc-900/60 transition-colors">
              <div class="flex items-center gap-2 mb-3">
                {t.author.avatarUrl ? (
                  <img src={t.author.avatarUrl} alt={t.author.name} class="w-4 h-4 rounded-full" />
                ) : (
                  <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                  </svg>
                )}
                <span class="text-xs text-zinc-500">{t.author.name}</span>
              </div>
              <h3 class="text-sm font-semibold text-zinc-100">{t.name}</h3>
              {t.description && (
                <p class="mt-1 text-sm text-zinc-400 leading-relaxed line-clamp-2">{t.description}</p>
              )}
              {t.keywords.length > 0 && (
                <div class="mt-4 flex items-center gap-2 flex-wrap">
                  {t.keywords.map((kw) => (
                    <span class="rounded-full bg-zinc-800 px-2 py-0.5 text-[11px] text-zinc-400">{kw}</span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- How It Works -->
  <section class="py-20 px-6 border-t border-white/5">
    <div class="mx-auto max-w-7xl">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-12 text-center">How It Works</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mx-auto mb-5">
            <span class="text-lg font-bold text-white">1</span>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">Browse</h3>
          <p class="text-sm text-zinc-400 leading-relaxed max-w-xs mx-auto">Find plugins and themes in the marketplace. Filter by category, capability, or keyword.</p>
        </div>

        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mx-auto mb-5">
            <span class="text-lg font-bold text-white">2</span>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">Install</h3>
          <p class="text-sm text-zinc-400 leading-relaxed max-w-xs mx-auto">Download directly or point your EmDash instance at our registry. It just works.</p>
        </div>

        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mx-auto mb-5">
            <span class="text-lg font-bold text-white">3</span>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">Trust</h3>
          <p class="text-sm text-zinc-400 leading-relaxed max-w-xs mx-auto">Every plugin is AI-audited for security before publication. Fail-closed &mdash; nothing ships without passing.</p>
        </div>

      </div>

      <div class="mt-12 text-center">
        <a href="/guide" class="text-sm text-zinc-400 hover:text-white transition-colors inline-flex items-center gap-1">
          Read the installation guide
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Footer CTA -->
  <section class="py-20 px-6 border-t border-white/5">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-4">Built for the EmDash community</h2>
      <p class="text-zinc-400 mb-10 max-w-lg mx-auto leading-relaxed">
        An open-source, community-driven marketplace. MIT licensed, deployed on Cloudflare Workers, and compatible with the EmDash marketplace API.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/guide"
           class="bg-white text-black px-8 py-3.5 rounded-lg font-medium hover:bg-gray-200 transition-all inline-flex items-center justify-center gap-2 text-sm shadow-[0_0_20px_rgba(255,255,255,0.15)]">
          Installation Guide
        </a>
        <a href="https://github.com/chrisjohnleah/emdashcms-org" target="_blank" rel="noopener noreferrer"
           class="bg-transparent border border-white/20 text-white px-8 py-3.5 rounded-lg font-medium hover:bg-white/5 transition-all inline-flex items-center justify-center gap-2 text-sm">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16"><path d="M8 .2a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38l-.01-1.49c-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.42 7.42 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48l-.01 2.2c0 .21.15.46.55.38A8.01 8.01 0 0 0 8 .2Z" /></svg>
          View on GitHub
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
