---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';
import PluginCard from '../components/PluginCard.astro';
import ThemeCard from '../components/ThemeCard.astro';
import EmptyState from '../components/EmptyState.astro';
import Button from '../components/Button.astro';
import AuditBadge from '../components/AuditBadge.astro';
import { searchPlugins, searchThemes } from '../lib/db/queries';
import { buildOrganizationJsonLd } from '../lib/seo/json-ld';

const title = 'emdashcms.org — A community marketplace for EmDash plugins and themes';
const description =
  'Browse plugins and themes for EmDash CMS, published by the community. Free to install, free to publish, MIT licensed, and audited before every release.';

const [latestResult, popularResult, themesResult] = await Promise.all([
  searchPlugins(env.DB, { query: '', category: null, capability: null, sort: 'created', cursor: null, limit: 6 }),
  searchPlugins(env.DB, { query: '', category: null, capability: null, sort: 'installs', cursor: null, limit: 6 }),
  searchThemes(env.DB, { query: '', category: null, keyword: null, sort: 'created', cursor: null, limit: 4 }),
]);

const allPlugins = latestResult.items;
const featuredPlugin = allPlugins[0] ?? null;
const secondaryPlugins = allPlugins.slice(1, 4);
const mostInstalled = popularResult.items.filter((p) => p.installCount > 0).slice(0, 5);
const themes = themesResult.items;

const hasAnyContent = allPlugins.length > 0 || themes.length > 0;

// OAuth callback redirects banned authors here with ?banned=1
const showBannedNotice = Astro.url.searchParams.get('banned') === '1';

// Site-root Organization JSON-LD. Only emitted on the homepage so we
// don't assert marketplace identity on every page in the site.
const homepageJsonLd = buildOrganizationJsonLd();
---
<BaseLayout title={title} description={description} jsonLd={homepageJsonLd}>

  {showBannedNotice && (
    <div class="bg-danger-soft border-b border-danger/30">
      <div class="page py-4 flex items-start gap-3">
        <svg class="w-5 h-5 text-danger shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
        </svg>
        <div class="flex-1">
          <p class="text-sm font-semibold text-danger">Your account has been suspended from publishing.</p>
          <p class="mt-1 text-xs text-danger/90 leading-relaxed">
            You can still browse the marketplace but cannot register new plugins or themes or upload new versions.
            See our <a href="/code-of-conduct" class="underline underline-offset-2">Code of Conduct</a> for the policies we enforce.
            If you believe this is a mistake, open an issue at
            <a href="https://github.com/chrisjohnleah/emdashcms-org/issues" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2">github.com/chrisjohnleah/emdashcms-org/issues</a>.
          </p>
        </div>
      </div>
    </div>
  )}

  <!-- ───────────────────────────────────────────────
       Hero — asymmetric, editorial. Left column carries
       the message and the two audience CTAs. Right column
       hangs the giant em-dash glyph as the brand pulse.
       ─────────────────────────────────────────────── -->

  <section class="page pt-16 pb-20 md:pt-24 md:pb-28">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8 items-center">

      <div class="md:col-span-7">

        <p class="text-xs uppercase tracking-[0.18em] text-ink-soft mb-7">
          Open
          <span class="emdash-sep" aria-hidden="true"></span>
          Community
          <span class="emdash-sep" aria-hidden="true"></span>
          MIT licensed
        </p>

        <h1 class="font-display text-4xl sm:text-5xl md:text-[3.6rem] lg:text-[4.25rem] leading-[1.05] text-ink"
            style="font-weight: 400; font-variation-settings: 'opsz' 144; letter-spacing: -0.025em;">
          A community marketplace<br />
          for <span class="italic" style="font-weight: 300;">EmDash</span> plugins<br class="hidden sm:inline" />
          and themes.
        </h1>

        <p class="mt-7 text-lg text-ink-muted leading-relaxed max-w-xl">
          Browse what's been built. Publish what you've made.
          Every release is sandboxed, scanned, and AI-reviewed before it ships
          <span class="emdash-mark">—</span> never silently published.
        </p>

        <div class="mt-9 flex flex-wrap items-center gap-3">
          <Button href="/plugins" variant="hero">Browse plugins</Button>
          <Button href="/dashboard" variant="secondary" size="lg">Publish your work</Button>
        </div>

        <p class="mt-7 text-xs text-ink-soft">
          Under active development
          <span class="emdash-sep" aria-hidden="true"></span>
          <a
            href="https://github.com/chrisjohnleah/emdashcms-org"
            target="_blank"
            rel="noopener noreferrer"
            class="text-ink-muted hover:text-ink underline underline-offset-2 decoration-rule-strong hover:decoration-accent-deep transition-colors"
          >Follow on GitHub</a>
        </p>
      </div>

      <div class="md:col-span-5 flex justify-center md:justify-end" aria-hidden="true">
        <span class="hero-emdash">—</span>
      </div>

    </div>
  </section>

  {!hasAnyContent && (
    <section class="page pb-32">
      <EmptyState
        heading="The marketplace is just getting started."
        body="No plugins or themes have been published yet. If you've built something for EmDash, you'll be the first."
        linkHref="/docs/contributors"
        linkText="Read the contributor guide"
      />
    </section>
  )}

  {featuredPlugin && (
    <>
      <span class="emdash-divider" aria-hidden="true"></span>

      <!-- ───────────────────────────────────────────────
           Featured + secondary plugins. The featured card
           spans 7 of 12 columns. Three secondary plugins
           share the remaining width as a vertical strip
           on desktop, falling back to a grid on mobile.
           ─────────────────────────────────────────────── -->

      <section class="page" aria-labelledby="latest-heading">
        <div class="flex items-baseline justify-between mb-10">
          <h2 id="latest-heading" class="font-display text-3xl md:text-4xl text-ink"
              style="font-weight: 500; letter-spacing: -0.02em;">
            Latest plugins
          </h2>
          <a
            href="/plugins"
            class="text-sm text-ink-muted hover:text-ink transition-colors underline underline-offset-4 decoration-rule-strong hover:decoration-accent-deep"
          >
            All plugins →
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-5">
          <div class="md:col-span-7">
            <PluginCard plugin={featuredPlugin} featured />
          </div>

          {secondaryPlugins.length > 0 && (
            <div class="md:col-span-5 flex flex-col gap-5">
              {secondaryPlugins.map((p) => (
                <PluginCard plugin={p} />
              ))}
            </div>
          )}
        </div>
      </section>
    </>
  )}

  {mostInstalled.length > 0 && (
    <>
      <span class="emdash-divider" aria-hidden="true"></span>

      <!-- ───────────────────────────────────────────────
           Most installed — a denser, list-style layout.
           NOT another card grid. Reads like a chart or
           table of contents. The whole row is a link.
           ─────────────────────────────────────────────── -->

      <section class="page" aria-labelledby="popular-heading">
        <div class="flex items-baseline justify-between mb-10">
          <h2 id="popular-heading" class="font-display text-3xl md:text-4xl text-ink"
              style="font-weight: 500; letter-spacing: -0.02em;">
            Most installed
          </h2>
          <a
            href="/plugins?sort=installs"
            class="text-sm text-ink-muted hover:text-ink transition-colors underline underline-offset-4 decoration-rule-strong hover:decoration-accent-deep"
          >
            All popular →
          </a>
        </div>

        <ol class="border-t border-rule">
          {mostInstalled.map((p, i) => (
            <li class="border-b border-rule">
              <a
                href={`/plugins/${p.id}`}
                class="group grid grid-cols-12 items-center gap-4 py-5 hover:bg-paper-soft -mx-4 px-4 rounded transition-colors"
              >
                <span class="col-span-1 font-display text-xl text-ink-soft group-hover:text-accent-deep transition-colors tabular-nums" style="font-weight: 400;">
                  {String(i + 1).padStart(2, '0')}
                </span>

                <div class="col-span-11 md:col-span-6">
                  <h3 class="font-display text-xl text-ink leading-tight tracking-tight group-hover:text-accent-deep transition-colors" style="font-weight: 500;">
                    {p.name}
                  </h3>
                  <p class="mt-1 text-xs text-ink-soft">
                    {p.author.name}
                  </p>
                </div>

                <div class="hidden md:block md:col-span-3 text-sm text-ink-muted line-clamp-1">
                  {p.shortDescription ?? p.description ?? ''}
                </div>

                <div class="hidden md:flex md:col-span-2 items-center justify-end gap-3 text-xs text-ink-soft">
                  {p.latestVersion?.audit && (
                    <AuditBadge verdict={p.latestVersion.audit.verdict} />
                  )}
                  <span class="tabular-nums">
                    {p.installCount.toLocaleString()}
                  </span>
                </div>
              </a>
            </li>
          ))}
        </ol>
      </section>
    </>
  )}

  {themes.length > 0 && (
    <>
      <span class="emdash-divider" aria-hidden="true"></span>

      <!-- ───────────────────────────────────────────────
           Themes — image-led, two columns. Themes ARE
           visual, so let them be visual.
           ─────────────────────────────────────────────── -->

      <section class="page" aria-labelledby="themes-heading">
        <div class="flex items-baseline justify-between mb-10">
          <h2 id="themes-heading" class="font-display text-3xl md:text-4xl text-ink"
              style="font-weight: 500; letter-spacing: -0.02em;">
            Latest themes
          </h2>
          <a
            href="/themes"
            class="text-sm text-ink-muted hover:text-ink transition-colors underline underline-offset-4 decoration-rule-strong hover:decoration-accent-deep"
          >
            All themes →
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {themes.map((t) => (
            <ThemeCard theme={t} />
          ))}
        </div>
      </section>
    </>
  )}

  <span class="emdash-divider" aria-hidden="true"></span>

  <!-- ───────────────────────────────────────────────
       Trust — substance about what auditing actually
       means. Replaces the old 3-step "How It Works"
       template with concrete commitments.
       ─────────────────────────────────────────────── -->

  <section class="page" aria-labelledby="trust-heading">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12">
      <div class="md:col-span-5">
        <h2 id="trust-heading" class="font-display text-3xl md:text-4xl text-ink"
            style="font-weight: 500; letter-spacing: -0.02em;">
          Audited<br />before it ships.
        </h2>
        <p class="mt-5 text-base text-ink-muted leading-relaxed max-w-md">
          Every version that lands here has passed a fail-closed pipeline.
          If the audit can't run, the version doesn't publish.
          No silent escapes, no exceptions, no &ldquo;trust me&rdquo;.
        </p>
      </div>

      <div class="md:col-span-7">
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-9">
          <div>
            <dt class="font-display text-lg text-ink mb-1.5" style="font-weight: 500;">
              <span class="emdash-mark mr-2" aria-hidden="true">—</span>
              Sandboxed by default
            </dt>
            <dd class="text-sm text-ink-muted leading-relaxed">
              Plugins run in isolated Worker sandboxes. They declare what they touch in a manifest. Nothing else.
            </dd>
          </div>

          <div>
            <dt class="font-display text-lg text-ink mb-1.5" style="font-weight: 500;">
              <span class="emdash-mark mr-2" aria-hidden="true">—</span>
              Statically scanned
            </dt>
            <dd class="text-sm text-ink-muted leading-relaxed">
              Every uploaded archive is unpacked and scanned for the obvious failure modes before a human ever sees it.
            </dd>
          </div>

          <div>
            <dt class="font-display text-lg text-ink mb-1.5" style="font-weight: 500;">
              <span class="emdash-mark mr-2" aria-hidden="true">—</span>
              AI-reviewed in context
            </dt>
            <dd class="text-sm text-ink-muted leading-relaxed">
              A model reads the code against the manifest. If it can't parse the verdict, the version is rejected, not auto-passed.
            </dd>
          </div>

          <div>
            <dt class="font-display text-lg text-ink mb-1.5" style="font-weight: 500;">
              <span class="emdash-mark mr-2" aria-hidden="true">—</span>
              Open and inspectable
            </dt>
            <dd class="text-sm text-ink-muted leading-relaxed">
              The marketplace, the audit pipeline, and every verdict log live in a public MIT-licensed repository. Audit our auditing.
            </dd>
          </div>
        </dl>

        <div class="mt-9">
          <a
            href="/docs/security"
            class="text-sm text-ink hover:text-accent-deep transition-colors inline-flex items-center gap-2 underline underline-offset-4 decoration-rule-strong hover:decoration-accent-deep"
          >
            Read the full security policy →
          </a>
        </div>
      </div>
    </div>
  </section>

  <span class="emdash-divider" aria-hidden="true"></span>

  <!-- ───────────────────────────────────────────────
       Closing CTA — the warm voice gets the spotlight.
       Two paths home: install something or publish
       something. Both are valid first moves.
       ─────────────────────────────────────────────── -->

  <section class="page pb-32">
    <div class="page-narrow text-center">
      <h2 class="font-display text-3xl md:text-4xl text-ink"
          style="font-weight: 500; letter-spacing: -0.02em;">
        Built by the EmDash community.
      </h2>
      <p class="mt-5 text-base text-ink-muted leading-relaxed max-w-xl mx-auto">
        Free to install. Free to publish. MIT licensed and running on Cloudflare's free tier
        so the marketplace stays cheap to host and easy to fork.
      </p>
      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <Button href="/plugins" variant="hero">Find a plugin</Button>
        <Button href="/docs/contributors" variant="secondary" size="lg">Publish your first one</Button>
      </div>
    </div>
  </section>

</BaseLayout>
