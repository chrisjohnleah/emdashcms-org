---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import TurnstileWidget from '../../components/TurnstileWidget.astro';
import {
  createReport,
  type ReportCategory,
  type ReportEntityType,
} from '../../lib/db/report-queries';
import { verifyTurnstile } from '../../lib/turnstile/verify';
import { resolveAuthorId } from '../../lib/publishing/plugin-queries';

const rawTarget = Astro.params.target ?? '';
const parts = rawTarget.split('/').filter(Boolean);
const entityType = (parts[0] ?? '') as ReportEntityType;
const entityId = parts.slice(1).join('/');

const VALID_TYPES: ReportEntityType[] = ['plugin', 'theme'];
const invalidPath = !VALID_TYPES.includes(entityType) || !entityId;

let entityName: string | null = null;
if (!invalidPath) {
  const table = entityType === 'plugin' ? 'plugins' : 'themes';
  const row = await env.DB
    .prepare(`SELECT name FROM ${table} WHERE id = ?`)
    .bind(entityId)
    .first<{ name: string }>();
  entityName = row?.name ?? null;
}

const notFound = !invalidPath && !entityName;
if (invalidPath || notFound) {
  Astro.response.status = 404;
}

const categories: { value: ReportCategory; label: string; hint: string }[] = [
  { value: 'security', label: 'Security vulnerability', hint: 'Exfiltration, backdoor, malicious behaviour' },
  { value: 'abuse',    label: 'Abuse or spam',          hint: 'Harassment, deceptive behaviour, spam content' },
  { value: 'broken',   label: 'Broken or abandoned',    hint: 'Crashes, non-functional, no longer maintained' },
  { value: 'license',  label: 'License violation',      hint: 'Stolen code, trademark issue, GPL breach' },
  { value: 'other',    label: 'Other',                  hint: 'Anything else worth telling us about' },
];

let errorMessage = '';
let success = false;

if (Astro.request.method === 'POST' && !invalidPath && !notFound) {
  const form = await Astro.request.formData();
  const category = form.get('category') as string;
  const description = (form.get('description') as string)?.trim() ?? '';
  const turnstileToken = form.get('cf-turnstile-response') as string | null;

  if (!categories.find((c) => c.value === category)) {
    errorMessage = 'Please select a reason category.';
  } else if (description.length < 10) {
    errorMessage = 'Description must be at least 10 characters.';
  } else if (description.length > 2000) {
    errorMessage = 'Description must be 2000 characters or less.';
  } else {
    // Turnstile check only for anonymous reporters.
    let turnstileOk = true;
    if (!Astro.locals.author) {
      if (!turnstileToken) {
        errorMessage = 'Please complete the verification challenge.';
        turnstileOk = false;
      } else {
        const result = await verifyTurnstile(
          turnstileToken,
          (env as unknown as { TURNSTILE_SECRET_KEY: string }).TURNSTILE_SECRET_KEY,
        );
        if (!result.success) {
          errorMessage = 'Verification failed. Please try again.';
          turnstileOk = false;
        }
      }
    }

    if (turnstileOk && !errorMessage) {
      let reporterAuthorId: string | null = null;
      if (Astro.locals.author) {
        reporterAuthorId = await resolveAuthorId(env.DB, Astro.locals.author.githubId);
      }

      try {
        await createReport(env.DB, {
          entityType,
          entityId,
          reporterAuthorId,
          reasonCategory: category as ReportCategory,
          description,
        });
        success = true;
      } catch (err) {
        console.error('[report] failed to create report', err);
        errorMessage = 'Something went wrong saving your report. Please try again in a moment.';
      }
    }
  }
}

const title = notFound || invalidPath
  ? 'Not found — emdashcms.org'
  : `Report ${entityName} — emdashcms.org`;
---
<BaseLayout title={title} description="Report a plugin or theme to the emdashcms.org moderators.">
  <section class="page pt-12 pb-16 md:pt-16">
    <div class="page-narrow">

      {invalidPath || notFound ? (
        <>
          <h1 class="text-3xl text-ink" style="font-weight: 500; letter-spacing: -0.02em;">Nothing to report here</h1>
          <p class="mt-4 text-sm text-ink-muted max-w-prose">
            The entity you're trying to report doesn't exist. Go back to
            <a href="/plugins" class="underline hover:text-ink">Plugins</a> or
            <a href="/themes" class="underline hover:text-ink">Themes</a> and try again from the detail page.
          </p>
        </>
      ) : success ? (
        <>
          <h1 class="text-3xl text-ink" style="font-weight: 500; letter-spacing: -0.02em;">Report received</h1>
          <p class="mt-4 text-sm text-ink-muted max-w-prose">
            Thanks — a moderator will review your report. If the issue is a security vulnerability, we may
            restrict downloads of the affected version while we investigate.
          </p>
          <div class="mt-6">
            <a href={`/${entityType}s/${entityId}`} class="inline-flex items-center gap-2 text-sm text-ink-muted hover:text-ink">
              ← Back to {entityName}
            </a>
          </div>
        </>
      ) : (
        <>
          <a href={`/${entityType}s/${entityId}`} class="text-sm text-ink-muted hover:text-ink transition-colors">
            ← Back to {entityName}
          </a>

          <h1 class="mt-4 text-3xl text-ink leading-[1.15]" style="font-weight: 500; letter-spacing: -0.02em;">
            Report a problem
          </h1>
          <p class="mt-2 text-sm text-ink-muted max-w-prose">
            Reporting <strong class="text-ink">{entityName}</strong> (<code class="font-mono text-ink">{entityId}</code>).
            See our <a href="/docs/security" class="underline hover:text-ink">review policy</a> for what we check.
          </p>

          {errorMessage && (
            <div class="mt-6 rounded-lg border border-danger/35 bg-danger-soft p-4">
              <p class="text-sm text-danger">{errorMessage}</p>
            </div>
          )}

          <form method="POST" class="mt-8 space-y-6">
            <fieldset>
              <legend class="text-sm font-semibold text-ink">Reason</legend>
              <div class="mt-3 space-y-2">
                {categories.map((c) => (
                  <label class="flex items-start gap-3 rounded-lg border border-rule bg-paper-soft p-4 cursor-pointer hover:border-rule-strong transition-colors">
                    <input type="radio" name="category" value={c.value} required class="mt-1 accent-ink" />
                    <div>
                      <div class="text-sm font-medium text-ink">{c.label}</div>
                      <div class="text-xs text-ink-soft">{c.hint}</div>
                    </div>
                  </label>
                ))}
              </div>
            </fieldset>

            <div>
              <label for="description" class="block text-sm font-semibold text-ink">
                What did you observe? <span class="text-ink-soft font-normal">(required, 10–2000 chars)</span>
              </label>
              <textarea
                id="description"
                name="description"
                required
                minlength="10"
                maxlength="2000"
                rows="6"
                class="mt-2 w-full bg-paper-soft border border-rule text-ink rounded-lg px-3 py-2 text-sm focus:border-ink focus:outline-none focus:ring-1 focus:ring-ink"
                placeholder="Describe what you saw, any steps to reproduce, and the version number if relevant. Include links to evidence where possible."
              ></textarea>
            </div>

            {!Astro.locals.author && (
              <div>
                <p class="text-xs text-ink-soft mb-2">You're reporting anonymously — please complete this check:</p>
                <TurnstileWidget />
              </div>
            )}

            <div class="flex items-center justify-between">
              <p class="text-xs text-ink-soft">
                {Astro.locals.author
                  ? `Reporting as @${Astro.locals.author.username}`
                  : 'Reporting anonymously'}
              </p>
              <Button type="submit" variant="primary">
                Submit report
              </Button>
            </div>
          </form>
        </>
      )}

    </div>
  </section>
</BaseLayout>
