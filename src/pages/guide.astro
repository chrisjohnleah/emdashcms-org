---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Installation Guide - emdashcms.org";
const description = "How to install plugins and themes from the EmDash community marketplace";
---
<BaseLayout title={title} description={description}>

  <section class="pt-32 pb-16 px-6">
    <div class="mx-auto max-w-3xl">

      <!-- Page header -->
      <div class="mb-16">
        <h1 class="text-4xl md:text-5xl font-bold tracking-tighter text-white mb-4">
          Installation Guide
        </h1>
        <p class="text-lg text-zinc-400 font-light leading-relaxed">
          Two ways to install plugins from the community marketplace.
        </p>
      </div>

      <!-- Section 1: Download & Manual Install -->
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-zinc-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
          </div>
          <h2 class="text-2xl font-semibold tracking-tight text-white">Download &amp; Manual Install</h2>
        </div>

        <ol class="space-y-6 text-zinc-100/80 leading-relaxed">
          <li class="flex gap-4">
            <span class="shrink-0 w-7 h-7 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-xs font-mono text-zinc-400">1</span>
            <span>Find a plugin on the marketplace and click <strong class="text-white font-medium">"Download"</strong>.</span>
          </li>
          <li class="flex gap-4">
            <span class="shrink-0 w-7 h-7 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-xs font-mono text-zinc-400">2</span>
            <div>
              <span>Extract the <code class="text-zinc-300 bg-zinc-800/60 px-1.5 py-0.5 rounded text-sm font-mono">.tgz</code> archive to your EmDash plugins directory:</span>
              <div class="mt-3 bg-zinc-950 rounded-lg p-4 font-mono text-sm text-zinc-300 overflow-x-auto border border-white/5">
                tar -xzf plugin-name-1.0.0.tgz -C ./plugins/
              </div>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="shrink-0 w-7 h-7 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-xs font-mono text-zinc-400">3</span>
            <span>Restart your EmDash instance.</span>
          </li>
        </ol>

        <p class="mt-6 text-sm text-zinc-400 leading-relaxed pl-11">
          Only published versions that pass our AI security audit are available for download.
        </p>
      </section>

      <div class="border-t border-zinc-800"></div>

      <!-- Section 2: Use as Your Plugin Registry -->
      <section class="my-16">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-zinc-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="m6.75 7.5 3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0 0 21 18V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v12a2.25 2.25 0 0 0 2.25 2.25Z" />
            </svg>
          </div>
          <h2 class="text-2xl font-semibold tracking-tight text-white">Use as Your Plugin Registry</h2>
        </div>

        <p class="text-zinc-100/80 leading-relaxed mb-6">
          Point your EmDash CMS instance at this marketplace to browse and install plugins directly from the CLI.
        </p>

        <p class="text-sm text-zinc-400 mb-2">
          Add the marketplace URL to your EmDash configuration:
        </p>
        <div class="bg-zinc-950 rounded-lg p-4 font-mono text-sm text-zinc-300 overflow-x-auto border border-white/5 mb-6">
          <pre>{`{
  "marketplace": {
    "url": "https://emdashcms.org/api/v1"
  }
}`}</pre>
        </div>

        <p class="text-sm text-zinc-400 mb-2">
          Then install plugins via the CLI:
        </p>
        <div class="bg-zinc-950 rounded-lg p-4 font-mono text-sm text-zinc-300 overflow-x-auto border border-white/5 mb-6">
          emdash plugin install @scope/plugin-name
        </div>

        <div class="border-l-4 border-amber-800/60 bg-amber-950/20 p-4 rounded-r-lg">
          <p class="text-sm text-amber-200/80 leading-relaxed">
            The <code class="font-mono text-amber-300/90 bg-amber-950/40 px-1 py-0.5 rounded text-xs">emdash</code> CLI ships with EmDash CMS &mdash; it is not provided by this marketplace. Check the <a href="https://emdashcms.com" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-amber-100 transition-colors">EmDash CMS documentation</a> for setup instructions.
          </p>
        </div>
      </section>

      <div class="border-t border-zinc-800"></div>

      <!-- Section 3: For Plugin Authors -->
      <section class="my-16">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-zinc-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
            </svg>
          </div>
          <h2 class="text-2xl font-semibold tracking-tight text-white">For Plugin Authors</h2>
        </div>

        <ol class="space-y-6 text-zinc-100/80 leading-relaxed">
          <li class="flex gap-4">
            <span class="shrink-0 w-7 h-7 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-xs font-mono text-zinc-400">1</span>
            <span><a href="/dashboard" class="text-white underline underline-offset-2 hover:text-zinc-100 transition-colors font-medium">Sign in with GitHub</a> to access your publisher dashboard.</span>
          </li>
          <li class="flex gap-4">
            <span class="shrink-0 w-7 h-7 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-xs font-mono text-zinc-400">2</span>
            <span>Register your plugin with a unique ID.</span>
          </li>
          <li class="flex gap-4">
            <span class="shrink-0 w-7 h-7 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-xs font-mono text-zinc-400">3</span>
            <span>Upload a version &mdash; either a manual <code class="text-zinc-300 bg-zinc-800/60 px-1.5 py-0.5 rounded text-sm font-mono">.tgz</code> upload or connect a GitHub repository for automatic releases.</span>
          </li>
          <li class="flex gap-4">
            <span class="shrink-0 w-7 h-7 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-xs font-mono text-zinc-400">4</span>
            <div>
              <span>Every version is run through an AI security audit:</span>
              <ul class="mt-3 space-y-2 text-sm text-zinc-400">
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  <span><strong class="text-zinc-100/80 font-medium">Passed</strong> versions are published automatically.</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" /></svg>
                  <span><strong class="text-zinc-100/80 font-medium">Flagged</strong> versions are published with warnings.</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-red-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
                  <span><strong class="text-zinc-100/80 font-medium">Failed</strong> versions are rejected.</span>
                </li>
              </ul>
            </div>
          </li>
        </ol>

        <div class="mt-10">
          <a href="/dashboard"
             class="inline-flex items-center gap-2 bg-white text-black px-6 py-3 rounded-lg font-medium hover:bg-zinc-200 transition-all text-sm shadow-[0_0_20px_rgba(255,255,255,0.1)]">
            Get Started
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
      </section>

      <div class="border-t border-zinc-800"></div>

      <!-- Section 4: API Reference -->
      <section class="mt-16 mb-8">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-zinc-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
            </svg>
          </div>
          <h2 class="text-2xl font-semibold tracking-tight text-white">API Reference</h2>
        </div>

        <p class="text-zinc-100/80 leading-relaxed mb-6">
          The marketplace API is available at <code class="text-zinc-300 bg-zinc-800/60 px-1.5 py-0.5 rounded text-sm font-mono">https://emdashcms.org/api/v1</code>
        </p>

        <div class="bg-zinc-950 rounded-lg border border-white/5 overflow-hidden">
          <div class="divide-y divide-white/5">
            <div class="px-4 py-3 flex items-start gap-3">
              <span class="shrink-0 mt-0.5 font-mono text-xs font-medium text-emerald-400 bg-emerald-950/40 border border-emerald-800/30 px-2 py-0.5 rounded">GET</span>
              <div>
                <code class="font-mono text-sm text-zinc-300">/plugins</code>
                <p class="text-xs text-zinc-400 mt-1">Search and browse plugins</p>
              </div>
            </div>
            <div class="px-4 py-3 flex items-start gap-3">
              <span class="shrink-0 mt-0.5 font-mono text-xs font-medium text-emerald-400 bg-emerald-950/40 border border-emerald-800/30 px-2 py-0.5 rounded">GET</span>
              <div>
                <code class="font-mono text-sm text-zinc-300">/plugins/{`{id}`}</code>
                <p class="text-xs text-zinc-400 mt-1">Plugin details</p>
              </div>
            </div>
            <div class="px-4 py-3 flex items-start gap-3">
              <span class="shrink-0 mt-0.5 font-mono text-xs font-medium text-emerald-400 bg-emerald-950/40 border border-emerald-800/30 px-2 py-0.5 rounded">GET</span>
              <div>
                <code class="font-mono text-sm text-zinc-300">/plugins/{`{id}`}/versions/{`{version}`}/bundle</code>
                <p class="text-xs text-zinc-400 mt-1">Download bundle</p>
              </div>
            </div>
            <div class="px-4 py-3 flex items-start gap-3">
              <span class="shrink-0 mt-0.5 font-mono text-xs font-medium text-blue-400 bg-blue-950/40 border border-blue-800/30 px-2 py-0.5 rounded">POST</span>
              <div>
                <code class="font-mono text-sm text-zinc-300">/plugins/{`{id}`}/installs</code>
                <p class="text-xs text-zinc-400 mt-1">Track installations</p>
              </div>
            </div>
          </div>
        </div>

        <p class="mt-6 text-sm text-zinc-400 leading-relaxed">
          The API is compatible with the EmDash CMS <code class="text-zinc-300 bg-zinc-800/60 px-1.5 py-0.5 rounded text-xs font-mono">MarketplaceClient</code> interface.
        </p>
      </section>

    </div>
  </section>

</BaseLayout>
