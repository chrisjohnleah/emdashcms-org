---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PluginCard from '../../../components/PluginCard.astro';
import EmptyState from '../../../components/EmptyState.astro';
import SearchBar from '../../../components/SearchBar.astro';
import Pagination from '../../../components/Pagination.astro';
import { searchPlugins } from '../../../lib/db/queries';

const { slug } = Astro.params;
const category = (slug ?? '').toLowerCase();

const url = new URL(Astro.request.url);
const query = url.searchParams.get('q') ?? '';
const cursor = url.searchParams.get('cursor');
const sort = url.searchParams.get('sort') ?? 'installs';
const LIMIT = 12;

const result = category
  ? await searchPlugins(env.DB, {
      query,
      category,
      capability: null,
      sort,
      cursor,
      limit: LIMIT,
    })
  : { items: [], nextCursor: null };

const titleCategory = category
  .split('-')
  .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
  .join(' ');

const title = `${titleCategory} plugins - emdashcms.org`;
const description = `Browse ${titleCategory} plugins on the emdashcms.org community marketplace for EmDash CMS.`;
---
<BaseLayout title={title} description={description}>
  <section class="page pt-12 pb-16 md:pt-16">

      <nav class="flex items-center gap-2 text-sm text-ink-soft mb-6" aria-label="Breadcrumb">
        <a href="/plugins" class="hover:text-ink-muted transition-colors">Plugins</a>
        <span class="text-rule-strong">/</span>
        <span class="text-ink-muted">{titleCategory}</span>
      </nav>

      <h1 class="text-3xl tracking-tight leading-[1.15] text-ink" style="font-weight: 500; letter-spacing: -0.02em;">
        {titleCategory}
      </h1>
      <p class="mt-1 text-sm text-ink-muted">
        Plugins in the {titleCategory.toLowerCase()} category.
      </p>

      <div class="mt-6">
        <SearchBar
          action={`/plugins/category/${category}`}
          placeholder={`Search ${titleCategory.toLowerCase()} plugins...`}
          value={query}
        />
      </div>

      {result.items.length === 0 ? (
        <EmptyState
          heading="No plugins in this category yet"
          body="Be the first to publish one — or browse other categories."
          linkHref="/plugins"
          linkText="Browse all plugins"
        />
      ) : (
        <div class="mt-8">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {result.items.map((plugin) => (
              <PluginCard plugin={plugin} />
            ))}
          </div>
          <Pagination
            nextCursor={result.nextCursor}
            count={result.items.length}
            label="plugins"
            baseUrl={`/plugins/category/${category}`}
          />
        </div>
      )}

  </section>
</BaseLayout>
