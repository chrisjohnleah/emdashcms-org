---
export const prerender = false;

import { env } from 'cloudflare:workers';
import { getPluginDetail, getPluginVersions } from '../../lib/db/queries';
import type { MarketplaceVersionSummary } from '../../types/marketplace';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuditBadge from '../../components/AuditBadge.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import StarRating from '../../components/StarRating.astro';
import TrustSignals from '../../components/TrustSignals.astro';
import { getReviews, getReviewStats, getUserReview, createReview, updateReview, deleteReview } from '../../lib/db/review-queries';
import { resolveAuthorId } from '../../lib/publishing/plugin-queries';

const { id } = Astro.params;
const plugin = await getPluginDetail(env.DB, id!);

if (!plugin) {
  Astro.response.status = 404;
}

let versions: MarketplaceVersionSummary[] = [];
if (plugin) {
  versions = await getPluginVersions(env.DB, id!);
}

// Reviews
const [reviews, reviewStats] = await Promise.all([
  getReviews(env.DB, 'plugin', id!),
  getReviewStats(env.DB, 'plugin', id!),
]);

// Check if current user can review
const currentAuthor = Astro.locals.author;
let authorId: string | null = null;
let userReview = null;
let isPluginAuthor = false;
if (currentAuthor) {
  authorId = await resolveAuthorId(env.DB, currentAuthor.githubId);
  if (authorId) {
    userReview = await getUserReview(env.DB, 'plugin', id!, authorId);
    isPluginAuthor = plugin?.author?.name === currentAuthor.username;
  }
}

let reviewError = '';
let reviewSuccess = '';

if (plugin && Astro.request.method === 'POST' && authorId) {
  const formData = await Astro.request.formData();
  const action = formData.get('_action') as string;

  if (action === 'create-review' && !isPluginAuthor) {
    const rating = parseInt(formData.get('rating') as string);
    const comment = (formData.get('comment') as string)?.trim();
    if (!rating || rating < 1 || rating > 5) reviewError = 'Please select a rating.';
    else if (!comment || comment.length < 10) reviewError = 'Review must be at least 10 characters.';
    else if (comment.length > 2000) reviewError = 'Review must be 2000 characters or less.';
    else {
      try {
        await createReview(env.DB, 'plugin', id!, authorId, rating, comment);
        reviewSuccess = 'Review submitted!';
        // Redirect to self to avoid re-submission
        return Astro.redirect(Astro.url.pathname + '?reviewed=true');
      } catch { reviewError = 'You have already reviewed this plugin.'; }
    }
  } else if (action === 'update-review' && userReview) {
    const rating = parseInt(formData.get('rating') as string);
    const comment = (formData.get('comment') as string)?.trim();
    if (!rating || rating < 1 || rating > 5) reviewError = 'Please select a rating.';
    else if (!comment || comment.length < 10) reviewError = 'Review must be at least 10 characters.';
    else if (comment.length > 2000) reviewError = 'Review must be 2000 characters or less.';
    else {
      await updateReview(env.DB, userReview.id, authorId, rating, comment);
      return Astro.redirect(Astro.url.pathname + '?updated=true');
    }
  } else if (action === 'delete-review' && userReview) {
    await deleteReview(env.DB, userReview.id);
    return Astro.redirect(Astro.url.pathname + '?deleted=true');
  }
}

// Check for success query params
const reviewed = Astro.url.searchParams.get('reviewed');
const updated = Astro.url.searchParams.get('updated');
const deleted = Astro.url.searchParams.get('deleted');
if (reviewed) reviewSuccess = 'Review submitted!';
if (updated) reviewSuccess = 'Review updated!';
if (deleted) reviewSuccess = 'Review deleted.';

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });

const formatSize = (bytes: number) => {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
};
---
{!plugin ? (
  <BaseLayout title="Plugin not found - emdashcms.org">
    <section class="pt-24 pb-16 px-6">
      <div class="mx-auto max-w-5xl text-center py-16">
        <h1 class="text-xl font-semibold text-zinc-100">Plugin not found</h1>
        <p class="mt-2 text-sm text-zinc-400">The plugin you're looking for doesn't exist or may have been removed.</p>
        <a href="/plugins" class="mt-6 inline-flex items-center rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors">Browse Plugins</a>
      </div>
    </section>
  </BaseLayout>
) : (
  <BaseLayout title={plugin.name + ' - emdashcms.org'} description={plugin.shortDescription ?? plugin.description ?? undefined}>
    <section class="pt-24 pb-16 px-6">
      <div class="mx-auto max-w-5xl">

        <a href="/plugins" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors">&larr; Back to Plugins</a>

        <div class="mt-6 lg:grid lg:grid-cols-3 lg:gap-8">

          <div class="lg:col-span-2">

            <div class="flex items-start gap-4">
              <div class="flex-1">
                <h1 class="text-3xl font-semibold tracking-tight leading-[1.15]">{plugin.name}</h1>
                {plugin.shortDescription && (
                  <p class="mt-1 text-sm text-zinc-400">{plugin.shortDescription}</p>
                )}
                <div class="mt-2 flex items-center gap-3">
                  {plugin.author.avatarUrl ? (
                    <img src={plugin.author.avatarUrl} alt={plugin.author.name} class="w-5 h-5 rounded-full" />
                  ) : (
                    <div class="w-5 h-5 rounded-full bg-zinc-800" />
                  )}
                  <span class="text-sm text-zinc-400">{plugin.author.name}</span>
                </div>
              </div>
            </div>

            <div class="mt-4 flex items-center gap-4 flex-wrap">
              <span class="text-sm text-zinc-500">{plugin.installCount.toLocaleString()} installs</span>
              {reviewStats.totalCount > 0 && (
                <div class="flex items-center gap-1.5">
                  <StarRating rating={reviewStats.averageRating} />
                  <span class="text-sm text-zinc-500">({reviewStats.totalCount})</span>
                </div>
              )}
              {plugin.latestVersion?.audit && (
                <AuditBadge verdict={plugin.latestVersion.audit.verdict} />
              )}
              {plugin.latestVersion?.audit && (
                <span class="text-xs text-zinc-500">Risk score: {plugin.latestVersion.audit.riskScore}/100</span>
              )}
            </div>

            {plugin.capabilities.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-1.5">
                {plugin.capabilities.map(cap => (
                  <span class="rounded-full bg-zinc-800 px-2.5 py-0.5 text-xs text-zinc-400">{cap}</span>
                ))}
              </div>
            )}

            <div class="mt-8 space-y-4">
              {plugin.latestVersion && (plugin.latestVersion.status === 'published' || plugin.latestVersion.status === 'flagged') && (
                <a
                  href={`/api/v1/plugins/${encodeURIComponent(plugin.id)}/versions/${plugin.latestVersion.version}/bundle`}
                  class="flex items-center justify-center gap-2 w-full rounded-lg bg-white text-zinc-950 px-5 py-3 text-sm font-semibold hover:bg-zinc-200 transition-colors"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
                  Download v{plugin.latestVersion.version} ({formatSize(plugin.latestVersion.bundleSize)})
                </a>
              )}

              <div>
                <h2 class="text-sm font-semibold text-zinc-100">Plugin ID</h2>
                <div class="mt-2 flex items-center gap-2 rounded-lg border border-zinc-800 bg-zinc-900 p-3">
                  <code class="flex-1 text-sm font-mono text-zinc-300">{plugin.id}</code>
                  <button
                    data-copy={plugin.id}
                    class="flex-shrink-0 rounded-md border border-zinc-700 bg-zinc-800 px-3 py-1 text-xs font-medium text-zinc-300 hover:bg-zinc-700 hover:text-zinc-100 transition-colors"
                    aria-label="Copy plugin ID"
                  >Copy</button>
                </div>
              </div>

              <a href="/guide" class="flex items-center gap-1.5 text-xs text-zinc-500 hover:text-zinc-300 transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
                How to install plugins &rarr;
              </a>
            </div>

            {plugin.description && (
              <div class="mt-8">
                <h2 class="text-sm font-semibold text-zinc-100">Description</h2>
                <p class="mt-2 text-sm text-zinc-400 leading-relaxed">{plugin.description}</p>
              </div>
            )}

            {plugin.latestVersion?.audit && (
              <div class="mt-8">
                <h2 class="text-sm font-semibold text-zinc-100">Audit Summary</h2>
                <div class="mt-2 rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-4">
                  <div class="flex items-center gap-3">
                    <AuditBadge verdict={plugin.latestVersion.audit.verdict} />
                    <span class="text-sm text-zinc-400">Risk score: {plugin.latestVersion.audit.riskScore}/100</span>
                    <span class="text-sm text-zinc-500">{plugin.latestVersion.audit.findings.length} findings</span>
                  </div>
                  {plugin.latestVersion.audit.findings.length > 0 && (
                    <ul class="mt-3 space-y-1.5">
                      {plugin.latestVersion.audit.findings.map(f => (
                        <li class="flex items-start gap-2 text-sm">
                          <span class:list={[
                            'flex-shrink-0 rounded px-1.5 py-0.5 text-[11px] font-medium uppercase',
                            f.severity === 'critical' && 'bg-red-950/40 text-red-400',
                            f.severity === 'high' && 'bg-red-950/40 text-red-400',
                            f.severity === 'medium' && 'bg-amber-950/40 text-amber-400',
                            f.severity === 'low' && 'bg-zinc-800 text-zinc-400',
                            f.severity === 'info' && 'bg-zinc-800 text-zinc-500',
                          ]}>{f.severity}</span>
                          <span class="text-zinc-300">{f.title}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </div>
            )}
          </div>

          <aside class="mt-8 lg:mt-0 space-y-6">
            <TrustSignals
              plugin={plugin}
              publisherVerified={plugin.author.verified}
              repositoryUrl={plugin.repositoryUrl}
              bundleDownloadUrl={plugin.latestVersion ? `/api/v1/plugins/${encodeURIComponent(plugin.id)}/versions/${plugin.latestVersion.version}/bundle` : null}
            />
            <div class="rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6 space-y-4">
              {!plugin.latestVersion && versions.length > 0 && (
                <div>
                  <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Latest Version</dt>
                  <dd class="mt-1 flex items-center gap-2">
                    <span class="text-sm font-mono text-zinc-400">{versions[0].version}</span>
                    <StatusBadge status={versions[0].status} />
                  </dd>
                </div>
              )}
              {plugin.latestVersion && (
                <div>
                  <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Latest Version</dt>
                  <dd class="mt-1 text-sm font-mono text-zinc-300">{plugin.latestVersion.version}</dd>
                </div>
              )}
              {plugin.license && (
                <div>
                  <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">License</dt>
                  <dd class="mt-1 text-sm text-zinc-300">{plugin.license}</dd>
                </div>
              )}
              {plugin.repositoryUrl && (
                <div>
                  <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Repository</dt>
                  <dd class="mt-1"><a href={plugin.repositoryUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors break-all">{plugin.repositoryUrl.replace('https://', '')}</a></dd>
                </div>
              )}
              {plugin.homepageUrl && (
                <div>
                  <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Homepage</dt>
                  <dd class="mt-1"><a href={plugin.homepageUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors break-all">{plugin.homepageUrl.replace('https://', '')}</a></dd>
                </div>
              )}
              {plugin.keywords.length > 0 && (
                <div>
                  <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Keywords</dt>
                  <dd class="mt-1 flex flex-wrap gap-1.5">
                    {plugin.keywords.map(kw => (
                      <span class="rounded-full bg-zinc-800 px-2 py-0.5 text-[11px] text-zinc-400">{kw}</span>
                    ))}
                  </dd>
                </div>
              )}
              <div>
                <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Created</dt>
                <dd class="mt-1 text-sm text-zinc-500">{formatDate(plugin.createdAt)}</dd>
              </div>
              <div>
                <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Updated</dt>
                <dd class="mt-1 text-sm text-zinc-500">{formatDate(plugin.updatedAt)}</dd>
              </div>
            </div>
          </aside>
        </div>

        {!plugin.latestVersion && versions.length > 0 && (
          <div class="mt-8 rounded-xl border border-amber-800/30 bg-amber-950/20 p-6 text-center">
            <p class="text-sm text-amber-400/80">This plugin has no published versions yet.</p>
            <p class="mt-1 text-xs text-zinc-500">All versions are reviewed by automated security audit before publication.</p>
          </div>
        )}

        {versions.length > 0 && (
          <div class="mt-12">
            <h2 class="text-sm font-semibold text-zinc-100">Version History</h2>
            <div class="mt-4 overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-zinc-800 text-left">
                    <th class="pb-3 pr-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Version</th>
                    <th class="pb-3 pr-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Status</th>
                    <th class="pb-3 pr-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Audit</th>
                    <th class="pb-3 pr-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Size</th>
                    <th class="pb-3 pr-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Date</th>
                    <th class="pb-3 text-xs font-semibold text-zinc-500 uppercase tracking-wide"></th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-zinc-800/60">
                  {versions.map(v => (
                    <tr>
                      <td class="py-3 pr-4 font-mono text-zinc-300">{v.version}</td>
                      <td class="py-3 pr-4"><StatusBadge status={v.status} /></td>
                      <td class="py-3 pr-4"><AuditBadge verdict={v.auditVerdict} /></td>
                      <td class="py-3 pr-4 text-zinc-500">{formatSize(v.bundleSize)}</td>
                      <td class="py-3 pr-4 text-zinc-500">{formatDate(v.publishedAt)}</td>
                      <td class="py-3">
                        {(v.status === 'published' || v.status === 'flagged') && (
                          <a href={`/api/v1/plugins/${encodeURIComponent(plugin.id)}/versions/${v.version}/bundle`} class="text-xs text-zinc-400 hover:text-zinc-100 transition-colors">Download</a>
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        <!-- Reviews Section -->
        <div class="mt-12">
          <h2 class="text-xl font-semibold text-zinc-100 mb-6 flex items-center gap-3">
            Reviews
            {reviewStats.totalCount > 0 && (
              <span class="text-sm font-normal text-zinc-500">
                {reviewStats.averageRating}/5 from {reviewStats.totalCount} {reviewStats.totalCount === 1 ? 'review' : 'reviews'}
              </span>
            )}
          </h2>

          {/* Success/error banners */}
          {reviewSuccess && (
            <div class="mb-4 rounded-lg border border-emerald-800/40 bg-emerald-950/20 px-4 py-3 text-sm text-emerald-400">{reviewSuccess}</div>
          )}
          {reviewError && (
            <div class="mb-4 rounded-lg border border-red-800/40 bg-red-950/20 px-4 py-3 text-sm text-red-400">{reviewError}</div>
          )}

          {/* Write/Edit review form */}
          {currentAuthor && authorId && !isPluginAuthor && (
            <div class="mb-8 rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6">
              <h3 class="text-sm font-semibold text-zinc-100 mb-4">
                {userReview ? 'Edit Your Review' : 'Write a Review'}
              </h3>
              <form method="POST">
                <input type="hidden" name="_action" value={userReview ? 'update-review' : 'create-review'} />

                {/* Star rating input */}
                <div class="mb-4">
                  <label class="text-xs text-zinc-500 uppercase tracking-wide font-semibold block mb-2">Rating</label>
                  <div class="flex gap-1" id="star-input">
                    {[1,2,3,4,5].map(n => (
                      <label class="cursor-pointer">
                        <input type="radio" name="rating" value={String(n)} class="sr-only peer" checked={userReview?.rating === n} />
                        <svg class="w-6 h-6 text-zinc-700 peer-checked:text-amber-400 hover:text-amber-400 transition-colors" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z" />
                        </svg>
                      </label>
                    ))}
                  </div>
                </div>

                {/* Comment */}
                <div class="mb-4">
                  <label for="comment" class="text-xs text-zinc-500 uppercase tracking-wide font-semibold block mb-2">Review</label>
                  <textarea
                    id="comment"
                    name="comment"
                    rows="3"
                    class="w-full rounded-lg border border-zinc-800 bg-zinc-950 px-3 py-2 text-sm text-zinc-100 placeholder-zinc-600 focus:border-zinc-600 focus:outline-none"
                    placeholder="Share your experience with this plugin..."
                    minlength="10"
                    required
                  >{userReview?.comment}</textarea>
                </div>

                <div class="flex items-center gap-3">
                  <button type="submit" class="rounded-lg bg-zinc-100 px-5 py-2 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors">
                    {userReview ? 'Update Review' : 'Submit Review'}
                  </button>
                  {userReview && (
                    <button type="submit" name="_action" value="delete-review" class="text-sm text-red-400 hover:text-red-300 transition-colors">
                      Delete my review
                    </button>
                  )}
                </div>
              </form>
            </div>
          )}

          {/* Login prompt if not authenticated */}
          {!currentAuthor && (
            <div class="mb-8 rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6 text-center">
              <p class="text-sm text-zinc-400">
                <a href="/api/v1/auth/github" class="text-zinc-100 hover:text-white underline transition-colors">Sign in with GitHub</a> to leave a review.
              </p>
            </div>
          )}

          {/* Reviews list */}
          {reviews.length === 0 ? (
            <p class="text-sm text-zinc-500">No reviews yet. Be the first!</p>
          ) : (
            <div class="space-y-4">
              {reviews.map(review => (
                <div class="rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-5">
                  <div class="flex items-center gap-3 mb-2">
                    {review.authorAvatarUrl ? (
                      <img src={review.authorAvatarUrl} alt={review.authorUsername} class="w-6 h-6 rounded-full" />
                    ) : (
                      <div class="w-6 h-6 rounded-full bg-zinc-700" />
                    )}
                    <span class="text-sm font-medium text-zinc-200">{review.authorUsername}</span>
                    <StarRating rating={review.rating} />
                    <span class="text-xs text-zinc-600 ml-auto">{formatDate(review.createdAt)}</span>
                  </div>
                  <p class="text-sm text-zinc-400 leading-relaxed">{review.comment}</p>
                </div>
              ))}
            </div>
          )}
        </div>

      </div>
    </section>

    <script>
      document.querySelectorAll('[data-copy]').forEach(btn => {
        btn.addEventListener('click', () => {
          const text = (btn as HTMLElement).dataset.copy;
          if (!text) return;
          navigator.clipboard.writeText(text).then(() => {
            btn.textContent = 'Copied!';
            setTimeout(() => btn.textContent = 'Copy', 2000);
          });
        });
      });

      // Star rating hover effect
      document.querySelectorAll('#star-input label').forEach((label, index, labels) => {
        label.addEventListener('mouseenter', () => {
          labels.forEach((l, i) => {
            const svg = l.querySelector('svg');
            if (svg) svg.classList.toggle('text-amber-400', i <= index);
            if (svg) svg.classList.toggle('text-zinc-700', i > index);
          });
        });
        label.addEventListener('click', () => {
          const input = label.querySelector('input');
          if (input) (input as HTMLInputElement).checked = true;
          labels.forEach((l, i) => {
            const svg = l.querySelector('svg');
            if (svg) svg.classList.toggle('text-amber-400', i <= index);
            if (svg) svg.classList.toggle('text-zinc-700', i > index);
          });
        });
      });
      document.querySelector('#star-input')?.addEventListener('mouseleave', () => {
        const checked = document.querySelector('#star-input input:checked') as HTMLInputElement | null;
        const checkedIndex = checked ? parseInt(checked.value) - 1 : -1;
        document.querySelectorAll('#star-input label').forEach((l, i) => {
          const svg = l.querySelector('svg');
          if (svg) svg.classList.toggle('text-amber-400', i <= checkedIndex);
          if (svg) svg.classList.toggle('text-zinc-700', i > checkedIndex);
        });
      });
    </script>
  </BaseLayout>
)}
