---
export const prerender = false;

import { env } from 'cloudflare:workers';
import { getPluginDetail, getPluginVersions } from '../../lib/db/queries';
import type { MarketplaceVersionSummary } from '../../types/marketplace';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import AuditBadge from '../../components/AuditBadge.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import StarRating from '../../components/StarRating.astro';
import TrustSignals from '../../components/TrustSignals.astro';
import TrustTierBadge from '../../components/TrustTierBadge.astro';
import { getReviews, getReviewStats, getUserReview, createReview, updateReview, deleteReview } from '../../lib/db/review-queries';
import { resolveAuthorId } from '../../lib/publishing/plugin-queries';
import { renderPluginMarkdown } from '../../lib/markdown';

const { id } = Astro.params;
const plugin = await getPluginDetail(env.DB, id!);

if (!plugin) {
  Astro.response.status = 404;
}

let versions: MarketplaceVersionSummary[] = [];
if (plugin) {
  versions = await getPluginVersions(env.DB, id!);
}

// Reviews
const [reviews, reviewStats] = await Promise.all([
  getReviews(env.DB, 'plugin', id!),
  getReviewStats(env.DB, 'plugin', id!),
]);

// Check if current user can review
const currentAuthor = Astro.locals.author;
let authorId: string | null = null;
let userReview = null;
let isPluginAuthor = false;
if (currentAuthor) {
  authorId = await resolveAuthorId(env.DB, currentAuthor.githubId);
  if (authorId) {
    userReview = await getUserReview(env.DB, 'plugin', id!, authorId);
    isPluginAuthor = plugin?.author?.name === currentAuthor.username;
  }
}

let reviewError = '';
let reviewSuccess = '';

if (plugin && Astro.request.method === 'POST' && authorId) {
  const formData = await Astro.request.formData();
  const action = formData.get('_action') as string;

  if (action === 'create-review' && !isPluginAuthor) {
    const rating = parseInt(formData.get('rating') as string);
    const comment = (formData.get('comment') as string)?.trim();
    if (!rating || rating < 1 || rating > 5) reviewError = 'Please select a rating.';
    else if (!comment || comment.length < 10) reviewError = 'Review must be at least 10 characters.';
    else if (comment.length > 2000) reviewError = 'Review must be 2000 characters or less.';
    else {
      try {
        await createReview(env.DB, 'plugin', id!, authorId, rating, comment);
        reviewSuccess = 'Review submitted!';
        return Astro.redirect(Astro.url.pathname + '?reviewed=true');
      } catch { reviewError = 'You have already reviewed this plugin.'; }
    }
  } else if (action === 'update-review' && userReview) {
    const rating = parseInt(formData.get('rating') as string);
    const comment = (formData.get('comment') as string)?.trim();
    if (!rating || rating < 1 || rating > 5) reviewError = 'Please select a rating.';
    else if (!comment || comment.length < 10) reviewError = 'Review must be at least 10 characters.';
    else if (comment.length > 2000) reviewError = 'Review must be 2000 characters or less.';
    else {
      await updateReview(env.DB, userReview.id, authorId, rating, comment);
      return Astro.redirect(Astro.url.pathname + '?updated=true');
    }
  } else if (action === 'delete-review' && userReview) {
    await deleteReview(env.DB, userReview.id);
    return Astro.redirect(Astro.url.pathname + '?deleted=true');
  }
}

// Check for success query params
const reviewed = Astro.url.searchParams.get('reviewed');
const updated = Astro.url.searchParams.get('updated');
const deleted = Astro.url.searchParams.get('deleted');
if (reviewed) reviewSuccess = 'Review submitted!';
if (updated) reviewSuccess = 'Review updated!';
if (deleted) reviewSuccess = 'Review deleted.';

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });

const formatSize = (bytes: number) => {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
};
---
{!plugin ? (
  <BaseLayout title="Plugin not found — emdashcms.org">
    <section class="page py-24">
      <div class="text-center py-16">
        <span class="emdash-mark text-3xl block mb-4" aria-hidden="true">—</span>
        <h1 class="font-display text-3xl text-ink" style="font-weight: 500;">Plugin not found</h1>
        <p class="mt-3 text-sm text-ink-muted max-w-md mx-auto">
          The plugin you're looking for doesn't exist or may have been removed.
        </p>
        <div class="mt-7">
          <Button href="/plugins" variant="primary">Browse plugins</Button>
        </div>
      </div>
    </section>
  </BaseLayout>
) : (
  <BaseLayout
    title={plugin.name + ' — emdashcms.org'}
    description={plugin.shortDescription ?? plugin.description ?? undefined}
    noindex={plugin.pluginStatus === 'revoked'}
  >
    <section class="page pt-12 pb-16 md:pt-16">

      {plugin.pluginStatus === 'revoked' && (
        <div class="mb-10 rounded-md border border-danger/35 bg-danger-soft p-5">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-danger shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
            </svg>
            <div>
              <h2 class="font-display text-lg text-danger" style="font-weight: 500;">This plugin has been revoked.</h2>
              <p class="mt-1 text-sm text-danger/90 leading-relaxed">
                Downloads are disabled for every version. The listing is preserved so the history, findings, and any
                inbound links remain accessible, but the plugin is hidden from search and we do not recommend installing it.
                See <a href="/docs/security" class="underline underline-offset-2">our review policy</a>
                for what we check and why revocations happen.
              </p>
            </div>
          </div>
        </div>
      )}

      <a href="/plugins" class="text-sm text-ink-muted hover:text-ink transition-colors inline-flex items-center gap-1.5">
        <span aria-hidden="true">←</span> Back to plugins
      </a>

      <div class="mt-10 lg:grid lg:grid-cols-12 lg:gap-12">

        <div class="lg:col-span-8">

          <header>
            <h1 class="font-display text-4xl md:text-5xl text-ink leading-[1.05] tracking-tight" style="font-weight: 500;">
              {plugin.name}
            </h1>
            {plugin.shortDescription && (
              <p class="mt-4 text-lg text-ink-muted leading-relaxed max-w-2xl">{plugin.shortDescription}</p>
            )}

            <div class="mt-5 flex items-center gap-2 text-sm text-ink-soft">
              {plugin.author.avatarUrl ? (
                <img src={plugin.author.avatarUrl} alt="" class="w-5 h-5 rounded-full" />
              ) : (
                <span class="w-5 h-5 rounded-full bg-paper-deep" aria-hidden="true"></span>
              )}
              <a href={`/authors/${plugin.author.name}`} class="text-ink-muted hover:text-ink transition-colors">
                {plugin.author.name}
              </a>
              <span class="emdash-sep" aria-hidden="true"></span>
              <span title="Bundle downloads — every browser ZIP click and every fetch from an EmDash CMS install">
                {plugin.downloadCount.toLocaleString()} downloads
              </span>
              <span class="emdash-sep" aria-hidden="true"></span>
              <span title="Unique sites whose EmDash CMS reported a successful install of this plugin">
                {plugin.installCount.toLocaleString()} installs
              </span>
              {reviewStats.totalCount > 0 && (
                <>
                  <span class="emdash-sep" aria-hidden="true"></span>
                  <span class="inline-flex items-center gap-1.5">
                    <StarRating rating={reviewStats.averageRating} />
                    <span>({reviewStats.totalCount})</span>
                  </span>
                </>
              )}
            </div>

            <div class="mt-5 flex items-center gap-2 flex-wrap">
              {plugin.latestVersion && (plugin.latestVersion.status === 'published' || plugin.latestVersion.status === 'flagged') && (
                <TrustTierBadge
                  status={plugin.latestVersion.status}
                  verdict={plugin.latestVersion.audit?.verdict ?? null}
                  showTooltip
                />
              )}
              {plugin.latestVersion?.audit && (
                <AuditBadge verdict={plugin.latestVersion.audit.verdict} />
              )}
              {plugin.latestVersion?.audit && (
                <span class="text-xs text-ink-soft" title="Worst security-category finding severity">
                  Security {plugin.latestVersion.audit.securityRiskScore}/100
                </span>
              )}
              {plugin.latestVersion?.audit && plugin.latestVersion.audit.privacyRiskScore > 0 && (
                <span class="text-xs text-ink-soft" title="Worst privacy-category finding severity — plugin handles visitor or admin data">
                  Privacy {plugin.latestVersion.audit.privacyRiskScore}/100
                </span>
              )}
            </div>

            {plugin.capabilities.length > 0 && (
              <div class="mt-5 flex flex-wrap gap-1.5">
                {plugin.capabilities.map(cap => (
                  <span class="rounded-full bg-paper-sunk border border-rule px-2.5 py-0.5 text-xs text-ink-muted">{cap}</span>
                ))}
              </div>
            )}
          </header>

          <div class="mt-10 space-y-5">
            {plugin.latestVersion && (plugin.latestVersion.status === 'published' || plugin.latestVersion.status === 'flagged') && (
              <Button
                href={`/api/v1/plugins/${encodeURIComponent(plugin.id)}/versions/${plugin.latestVersion.version}/bundle`}
                variant="hero"
                fullWidth
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
                </svg>
                Download v{plugin.latestVersion.version} ({formatSize(plugin.latestVersion.bundleSize)})
              </Button>
            )}

            <div>
              <h2 class="text-xs font-semibold text-ink-soft uppercase tracking-wider">Plugin ID</h2>
              <div class="mt-2 flex items-center gap-2 rounded-md border border-rule bg-paper-soft p-3">
                <code class="flex-1 font-mono text-sm text-ink-muted">{plugin.id}</code>
                <button
                  data-copy={plugin.id}
                  class="flex-shrink-0 rounded border border-rule-strong bg-paper-soft px-3 py-1 text-xs font-medium text-ink hover:bg-paper-sunk transition-colors"
                  aria-label="Copy plugin ID"
                >Copy</button>
              </div>
            </div>

            <a href="/guide" class="inline-flex items-center gap-1.5 text-xs text-ink-soft hover:text-ink transition-colors">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
              </svg>
              How to install plugins →
            </a>
          </div>

          {plugin.description && (
            <div class="mt-12">
              <h2 class="font-display text-2xl text-ink" style="font-weight: 500;">Description</h2>
              <div class="plugin-prose mt-3 max-w-prose text-base text-ink-muted leading-relaxed" set:html={renderPluginMarkdown(plugin.description) ?? ''}></div>
            </div>
          )}

          {plugin.latestVersion?.audit && (
            <div class="mt-12">
              <h2 class="font-display text-2xl text-ink" style="font-weight: 500;">Audit summary</h2>
              <div class="mt-3 rounded-md border border-rule bg-paper-soft p-5">
                <div class="flex items-center gap-3 flex-wrap text-sm text-ink-muted">
                  <AuditBadge verdict={plugin.latestVersion.audit.verdict} />
                  <span class="emdash-sep" aria-hidden="true"></span>
                  <span>Security risk: {plugin.latestVersion.audit.securityRiskScore}/100</span>
                  <span class="emdash-sep" aria-hidden="true"></span>
                  <span>Privacy disclosure: {plugin.latestVersion.audit.privacyRiskScore}/100</span>
                  <span class="emdash-sep" aria-hidden="true"></span>
                  <span>{plugin.latestVersion.audit.findings.length} findings</span>
                </div>
                <p class="mt-3 text-xs text-ink-soft leading-relaxed">
                  <span class="text-ink-muted font-medium">Security risk</span> answers
                  &ldquo;can this plugin harm my site?&rdquo; — it drives the publish
                  decision.{' '}
                  <span class="text-ink-muted font-medium">Privacy disclosure</span>{' '}
                  answers &ldquo;what visitor or admin data does this plugin handle?&rdquo; —
                  it&rsquo;s informational so you can make your own GDPR call before
                  installing.
                </p>
                {plugin.latestVersion.audit.findings.length > 0 && (
                  <ul class="mt-4 space-y-2">
                    {plugin.latestVersion.audit.findings.map(f => (
                      <li class="flex items-start gap-2 text-sm">
                        <span class:list={[
                          'flex-shrink-0 rounded px-1.5 py-0.5 text-[11px] font-medium uppercase',
                          (f.severity === 'critical' || f.severity === 'high') && 'bg-danger-soft text-danger',
                          f.severity === 'medium' && 'bg-warn-soft text-warn',
                          f.severity === 'low' && 'bg-paper-sunk text-ink-muted',
                          f.severity === 'info' && 'bg-paper-sunk text-ink-soft',
                        ]}>{f.severity}</span>
                        <span class="flex-shrink-0 rounded bg-paper-sunk px-1.5 py-0.5 text-[11px] font-mono text-ink-soft">
                          {f.category}
                        </span>
                        <span class="text-ink">{f.title}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
          )}
        </div>

        <aside class="mt-12 lg:mt-0 lg:col-span-4 space-y-6">
          <TrustSignals
            plugin={plugin}
            publisherVerified={plugin.author.verified}
            repositoryUrl={plugin.repositoryUrl}
            bundleDownloadUrl={plugin.latestVersion ? `/api/v1/plugins/${encodeURIComponent(plugin.id)}/versions/${plugin.latestVersion.version}/bundle` : null}
          />

          <div class="rounded-md border border-rule bg-paper-soft p-6 space-y-5">
            {!plugin.latestVersion && versions.length > 0 && (
              <div>
                <dt class="text-[11px] font-semibold text-ink-soft uppercase tracking-wider">Latest version</dt>
                <dd class="mt-1.5 flex items-center gap-2">
                  <span class="font-mono text-sm text-ink-muted">{versions[0].version}</span>
                  <StatusBadge status={versions[0].status} />
                </dd>
              </div>
            )}
            {plugin.latestVersion && (
              <div>
                <dt class="text-[11px] font-semibold text-ink-soft uppercase tracking-wider">Latest version</dt>
                <dd class="mt-1.5 font-mono text-sm text-ink">{plugin.latestVersion.version}</dd>
              </div>
            )}
            {plugin.latestVersion?.releaseUrl && (
              <div>
                <dt class="text-[11px] font-semibold text-ink-soft uppercase tracking-wider">Build provenance</dt>
                <dd class="mt-1.5">
                  <a
                    href={plugin.latestVersion.releaseUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 text-sm text-ink hover:text-accent-deep transition-colors break-all underline underline-offset-2 decoration-rule-strong hover:decoration-accent-deep"
                  >
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
                    </svg>
                    GitHub release
                  </a>
                  {plugin.latestVersion.commitSha && (
                    <p class="mt-1 text-[11px] font-mono text-ink-soft break-all">
                      {plugin.latestVersion.commitSha.slice(0, 12)}
                    </p>
                  )}
                </dd>
              </div>
            )}
            {plugin.license && (
              <div>
                <dt class="text-[11px] font-semibold text-ink-soft uppercase tracking-wider">Licence</dt>
                <dd class="mt-1.5 text-sm text-ink">{plugin.license}</dd>
              </div>
            )}
            {plugin.repositoryUrl && (
              <div>
                <dt class="text-[11px] font-semibold text-ink-soft uppercase tracking-wider">Repository</dt>
                <dd class="mt-1.5">
                  <a href={plugin.repositoryUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-ink hover:text-accent-deep transition-colors break-all underline underline-offset-2 decoration-rule-strong hover:decoration-accent-deep">
                    {plugin.repositoryUrl.replace('https://', '')}
                  </a>
                </dd>
              </div>
            )}
            {plugin.homepageUrl && (
              <div>
                <dt class="text-[11px] font-semibold text-ink-soft uppercase tracking-wider">Homepage</dt>
                <dd class="mt-1.5">
                  <a href={plugin.homepageUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-ink hover:text-accent-deep transition-colors break-all underline underline-offset-2 decoration-rule-strong hover:decoration-accent-deep">
                    {plugin.homepageUrl.replace('https://', '')}
                  </a>
                </dd>
              </div>
            )}
            {plugin.keywords.length > 0 && (
              <div>
                <dt class="text-[11px] font-semibold text-ink-soft uppercase tracking-wider">Keywords</dt>
                <dd class="mt-1.5 flex flex-wrap gap-1.5">
                  {plugin.keywords.map(kw => (
                    <span class="rounded-full bg-paper-sunk border border-rule px-2 py-0.5 text-[11px] text-ink-muted">{kw}</span>
                  ))}
                </dd>
              </div>
            )}
            <div>
              <dt class="text-[11px] font-semibold text-ink-soft uppercase tracking-wider">Created</dt>
              <dd class="mt-1.5 text-sm text-ink-muted">{formatDate(plugin.createdAt)}</dd>
            </div>
            <div>
              <dt class="text-[11px] font-semibold text-ink-soft uppercase tracking-wider">Updated</dt>
              <dd class="mt-1.5 text-sm text-ink-muted">{formatDate(plugin.updatedAt)}</dd>
            </div>
          </div>
        </aside>
      </div>

      {!plugin.latestVersion && versions.length > 0 && (
        <div class="mt-10 rounded-md border border-warn/35 bg-warn-soft p-6 text-center">
          <p class="text-sm text-warn">This plugin has no published versions yet.</p>
          <p class="mt-1 text-xs text-ink-soft">All versions are reviewed by automated security audit before publication.</p>
        </div>
      )}

      {versions.length > 0 && (
        <>
          <span class="emdash-divider" aria-hidden="true"></span>

          <div>
            <h2 class="font-display text-3xl text-ink" style="font-weight: 500; letter-spacing: -0.02em;">Version history</h2>
            <p class="mt-2 text-sm text-ink-muted leading-relaxed max-w-2xl">
              Rejected and revoked versions remain visible so the history is honest. Expand any row with findings to see why.
              See <a href="/docs/security" class="underline underline-offset-2 decoration-rule-strong hover:decoration-accent-deep transition-colors">our review policy</a>.
            </p>
            <div class="mt-6 space-y-2">
              {versions.map(v => {
                const hasDetail = v.findings.length > 0 || v.publicAdminNote || v.changelog;
                const isDownloadable = v.status === 'published' || v.status === 'flagged';
                return (
                  <div class="rounded-md border border-rule bg-paper-soft overflow-hidden">
                    <details class="group">
                      <summary class:list={[
                        'grid grid-cols-[auto_1fr_auto] items-center gap-4 px-5 py-3.5 hover:bg-paper-sunk transition-colors',
                        hasDetail ? 'cursor-pointer' : 'cursor-default list-none',
                      ]}>
                        <span class="font-mono text-sm text-ink">{v.version}</span>
                        <div class="flex items-center gap-2 flex-wrap min-w-0">
                          <StatusBadge status={v.status} />
                          <AuditBadge verdict={v.auditVerdict} />
                          <span class="text-xs text-ink-soft">{formatSize(v.bundleSize)}</span>
                          <span class="emdash-sep" aria-hidden="true"></span>
                          <span class="text-xs text-ink-soft">{formatDate(v.publishedAt)}</span>
                          <span class="emdash-sep" aria-hidden="true"></span>
                          <span class="text-xs text-ink-soft tabular-nums" title="Downloads of this version">
                            {v.downloadCount.toLocaleString()} downloads
                          </span>
                        </div>
                        <div class="flex items-center gap-3 justify-end">
                          {isDownloadable && plugin.pluginStatus !== 'revoked' && (
                            <a
                              href={`/api/v1/plugins/${encodeURIComponent(plugin.id)}/versions/${v.version}/bundle`}
                              class="download-link text-xs text-ink-muted hover:text-ink transition-colors"
                            >
                              Download
                            </a>
                          )}
                          {hasDetail && (
                            <svg class="w-4 h-4 text-ink-soft transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                            </svg>
                          )}
                        </div>
                      </summary>

                      {hasDetail && (
                        <div class="border-t border-rule bg-paper-sunk px-5 py-5 space-y-5">
                          {v.publicAdminNote && (
                            <div class="rounded-md border border-warn/35 bg-warn-soft p-4">
                              <p class="text-[11px] font-semibold text-warn uppercase tracking-wider">Moderator note</p>
                              <p class="mt-2 text-sm text-ink whitespace-pre-wrap leading-relaxed">
                                {v.publicAdminNote}
                              </p>
                            </div>
                          )}

                          {v.changelog && (
                            <div>
                              <p class="text-[11px] font-semibold text-ink-soft uppercase tracking-wider mb-2">
                                Changelog
                              </p>
                              <div class="rounded-md border border-rule bg-paper-soft p-4">
                                <p class="text-sm text-ink whitespace-pre-wrap leading-relaxed">
                                  {v.changelog}
                                </p>
                              </div>
                            </div>
                          )}

                          {v.findings.length > 0 && (
                            <div>
                              <p class="text-[11px] font-semibold text-ink-soft uppercase tracking-wider mb-2">
                                Scanner findings ({v.findings.length})
                              </p>
                              <div class="space-y-2">
                                {v.findings.map(f => (
                                  <div class="rounded-md border border-rule bg-paper-soft p-3">
                                    <div class="flex items-start gap-2">
                                      <span class:list={[
                                        'flex-shrink-0 rounded px-1.5 py-0.5 text-[11px] font-medium uppercase',
                                        f.severity === 'high' || f.severity === 'critical'
                                          ? 'bg-danger-soft text-danger'
                                          : f.severity === 'medium'
                                            ? 'bg-warn-soft text-warn'
                                            : 'bg-paper-sunk text-ink-muted',
                                      ]}>
                                        {f.severity}
                                      </span>
                                      <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-ink">{f.title}</p>
                                        <p class="mt-1 text-xs text-ink-muted leading-relaxed">{f.description}</p>
                                        <div class="mt-2 flex items-center gap-2 text-[11px] text-ink-soft">
                                          <span class="rounded bg-paper-sunk px-1.5 py-0.5 font-mono">{f.category}</span>
                                          {f.location && (
                                            <span class="font-mono">{f.location}</span>
                                          )}
                                        </div>
                                      </div>
                                    </div>
                                  </div>
                                ))}
                              </div>
                            </div>
                          )}
                        </div>
                      )}
                    </details>
                  </div>
                );
              })}
            </div>
          </div>
        </>
      )}

      <span class="emdash-divider" aria-hidden="true"></span>

      <!-- Reviews Section -->
      <div>
        <h2 class="font-display text-3xl text-ink flex items-baseline gap-3" style="font-weight: 500; letter-spacing: -0.02em;">
          Reviews
          {reviewStats.totalCount > 0 && (
            <span class="text-sm font-sans font-normal text-ink-soft">
              {reviewStats.averageRating}/5 from {reviewStats.totalCount} {reviewStats.totalCount === 1 ? 'review' : 'reviews'}
            </span>
          )}
        </h2>

        {reviewSuccess && (
          <div class="mt-6 rounded-md border border-success/30 bg-success-soft px-4 py-3 text-sm text-success">{reviewSuccess}</div>
        )}
        {reviewError && (
          <div class="mt-6 rounded-md border border-danger/35 bg-danger-soft px-4 py-3 text-sm text-danger">{reviewError}</div>
        )}

        {currentAuthor && authorId && !isPluginAuthor && (
          <div class="mt-8 rounded-md border border-rule bg-paper-soft p-6">
            <h3 class="font-display text-lg text-ink mb-5" style="font-weight: 500;">
              {userReview ? 'Edit your review' : 'Write a review'}
            </h3>
            <form method="POST">
              <input type="hidden" name="_action" value={userReview ? 'update-review' : 'create-review'} />

              <div class="mb-5">
                <label class="text-[11px] text-ink-soft uppercase tracking-wider font-semibold block mb-2">Rating</label>
                <div class="flex gap-1" id="star-input">
                  {[1,2,3,4,5].map(n => (
                    <label class="cursor-pointer">
                      <input type="radio" name="rating" value={String(n)} class="sr-only peer" checked={userReview?.rating === n} />
                      <svg class="w-7 h-7 text-rule-strong peer-checked:text-accent-deep hover:text-accent-deep transition-colors" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z" />
                      </svg>
                    </label>
                  ))}
                </div>
              </div>

              <div class="mb-5">
                <label for="comment" class="text-[11px] text-ink-soft uppercase tracking-wider font-semibold block mb-2">Review</label>
                <textarea
                  id="comment"
                  name="comment"
                  rows="4"
                  class="w-full rounded-md border border-rule-strong bg-paper px-3 py-2 text-sm text-ink placeholder:text-ink-soft focus:border-accent-deep focus:outline-none"
                  placeholder="Share your experience with this plugin..."
                  minlength="10"
                  required
                >{userReview?.comment}</textarea>
              </div>

              <div class="flex items-center gap-4">
                <Button type="submit" variant="primary">
                  {userReview ? 'Update review' : 'Submit review'}
                </Button>
                {userReview && (
                  <button type="submit" name="_action" value="delete-review" class="text-sm text-danger hover:underline transition-colors">
                    Delete my review
                  </button>
                )}
              </div>
            </form>
          </div>
        )}

        {!currentAuthor && (
          <div class="mt-8 rounded-md border border-rule bg-paper-soft p-6 text-center">
            <p class="text-sm text-ink-muted">
              <a href="/api/v1/auth/github" class="text-ink hover:text-accent-deep underline underline-offset-2 transition-colors">Sign in with GitHub</a> to leave a review.
            </p>
          </div>
        )}

        {reviews.length === 0 ? (
          <p class="mt-8 text-sm text-ink-soft">No reviews yet. Be the first.</p>
        ) : (
          <div class="mt-8 space-y-4">
            {reviews.map(review => (
              <div class="rounded-md border border-rule bg-paper-soft p-5">
                <div class="flex items-center gap-3 mb-3">
                  {review.authorAvatarUrl ? (
                    <img src={review.authorAvatarUrl} alt="" class="w-6 h-6 rounded-full" />
                  ) : (
                    <span class="w-6 h-6 rounded-full bg-paper-deep" aria-hidden="true"></span>
                  )}
                  <span class="text-sm font-medium text-ink">{review.authorUsername}</span>
                  <StarRating rating={review.rating} />
                  <span class="text-xs text-ink-soft ml-auto">{formatDate(review.createdAt)}</span>
                </div>
                <p class="text-sm text-ink-muted leading-relaxed">{review.comment}</p>
              </div>
            ))}
          </div>
        )}
      </div>

    </section>

    <script>
      // Download links inside <details> summaries should NOT toggle the accordion
      document.querySelectorAll<HTMLAnchorElement>('a.download-link').forEach((a) => {
        a.addEventListener('click', (e) => e.stopPropagation());
      });

      document.querySelectorAll('[data-copy]').forEach(btn => {
        btn.addEventListener('click', () => {
          const text = (btn as HTMLElement).dataset.copy;
          if (!text) return;
          navigator.clipboard.writeText(text).then(() => {
            btn.textContent = 'Copied!';
            setTimeout(() => btn.textContent = 'Copy', 2000);
          });
        });
      });

      // Star rating hover effect
      document.querySelectorAll('#star-input label').forEach((label, index, labels) => {
        label.addEventListener('mouseenter', () => {
          labels.forEach((l, i) => {
            const svg = l.querySelector('svg');
            if (svg) svg.classList.toggle('text-accent-deep', i <= index);
            if (svg) svg.classList.toggle('text-rule-strong', i > index);
          });
        });
        label.addEventListener('click', () => {
          const input = label.querySelector('input');
          if (input) (input as HTMLInputElement).checked = true;
          labels.forEach((l, i) => {
            const svg = l.querySelector('svg');
            if (svg) svg.classList.toggle('text-accent-deep', i <= index);
            if (svg) svg.classList.toggle('text-rule-strong', i > index);
          });
        });
      });
      document.querySelector('#star-input')?.addEventListener('mouseleave', () => {
        const checked = document.querySelector('#star-input input:checked') as HTMLInputElement | null;
        const checkedIndex = checked ? parseInt(checked.value) - 1 : -1;
        document.querySelectorAll('#star-input label').forEach((l, i) => {
          const svg = l.querySelector('svg');
          if (svg) svg.classList.toggle('text-accent-deep', i <= checkedIndex);
          if (svg) svg.classList.toggle('text-rule-strong', i > checkedIndex);
        });
      });
    </script>

    <style is:global>
      /* Scoped prose styles for publisher-supplied markdown. Matches the
         editorial theme — restrained sizes, existing ink tokens, no
         decorative surprises. The wrapper gets `.plugin-prose` on the
         Description block only, so no bleed into other paragraphs. */
      .plugin-prose :is(h1, h2, h3, h4, h5, h6) {
        font-family: var(--font-display, serif);
        color: var(--color-ink, #1a1a1a);
        font-weight: 500;
        letter-spacing: -0.01em;
        line-height: 1.25;
      }
      .plugin-prose h1 { font-size: 1.75rem; margin-top: 2rem; margin-bottom: 0.75rem; }
      .plugin-prose h2 { font-size: 1.375rem; margin-top: 1.75rem; margin-bottom: 0.625rem; }
      .plugin-prose h3 { font-size: 1.125rem; margin-top: 1.5rem; margin-bottom: 0.5rem; }
      .plugin-prose h4 { font-size: 1rem; margin-top: 1.25rem; margin-bottom: 0.5rem; }
      .plugin-prose > :first-child { margin-top: 0; }

      .plugin-prose p { margin: 0.875rem 0; }
      .plugin-prose ul, .plugin-prose ol { margin: 0.875rem 0; padding-left: 1.375rem; }
      .plugin-prose ul { list-style: disc; }
      .plugin-prose ol { list-style: decimal; }
      .plugin-prose li { margin: 0.25rem 0; }
      .plugin-prose li > p { margin: 0.25rem 0; }

      .plugin-prose a {
        color: var(--color-ink, #1a1a1a);
        text-decoration: underline;
        text-underline-offset: 2px;
        text-decoration-color: var(--color-rule-strong, #cbc9c3);
        transition: text-decoration-color 0.15s;
      }
      .plugin-prose a:hover { text-decoration-color: var(--color-accent-deep, #8b5a2b); }

      .plugin-prose strong { color: var(--color-ink, #1a1a1a); font-weight: 600; }
      .plugin-prose em { font-style: italic; }

      .plugin-prose code {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.875em;
        padding: 0.125rem 0.375rem;
        background: var(--color-paper-sunk, #f2efe9);
        border: 1px solid var(--color-rule, #e5e2db);
        border-radius: 4px;
      }
      .plugin-prose pre {
        margin: 1.25rem 0;
        padding: 1rem 1.125rem;
        background: var(--color-paper-sunk, #f2efe9);
        border: 1px solid var(--color-rule, #e5e2db);
        border-radius: 6px;
        overflow-x: auto;
        font-size: 0.8125rem;
        line-height: 1.55;
      }
      .plugin-prose pre code {
        padding: 0;
        background: transparent;
        border: none;
        border-radius: 0;
        font-size: inherit;
      }

      .plugin-prose blockquote {
        margin: 1.25rem 0;
        padding: 0.25rem 0 0.25rem 1rem;
        border-left: 2px solid var(--color-rule-strong, #cbc9c3);
        color: var(--color-ink-soft, #6b6a65);
        font-style: italic;
      }

      .plugin-prose hr {
        margin: 1.75rem 0;
        border: 0;
        border-top: 1px solid var(--color-rule, #e5e2db);
      }

      .plugin-prose img {
        max-width: 100%;
        height: auto;
        border-radius: 6px;
        margin: 1.25rem 0;
      }

      .plugin-prose table {
        width: 100%;
        margin: 1.25rem 0;
        border-collapse: collapse;
        font-size: 0.875rem;
      }
      .plugin-prose th, .plugin-prose td {
        padding: 0.5rem 0.75rem;
        border-bottom: 1px solid var(--color-rule, #e5e2db);
        text-align: left;
      }
      .plugin-prose th {
        font-weight: 600;
        color: var(--color-ink, #1a1a1a);
        background: var(--color-paper-soft, #f8f6f1);
      }
    </style>
  </BaseLayout>
)}
