---
export const prerender = false;

import { env } from 'cloudflare:workers';
import { getPluginDetail, getPluginVersions } from '../../lib/db/queries';
import type { MarketplaceVersionSummary } from '../../types/marketplace';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuditBadge from '../../components/AuditBadge.astro';
import StatusBadge from '../../components/StatusBadge.astro';

const { id } = Astro.params;
const plugin = await getPluginDetail(env.DB, id!);

if (!plugin) {
  Astro.response.status = 404;
}

let versions: MarketplaceVersionSummary[] = [];
if (plugin) {
  versions = await getPluginVersions(env.DB, id!);
}

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });

const formatSize = (bytes: number) => {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
};
---
{!plugin ? (
  <BaseLayout title="Plugin not found - emdashcms.org">
    <section class="pt-24 pb-16 px-6">
      <div class="mx-auto max-w-5xl text-center py-16">
        <h1 class="text-xl font-semibold text-zinc-100">Plugin not found</h1>
        <p class="mt-2 text-sm text-zinc-400">The plugin you're looking for doesn't exist or may have been removed.</p>
        <a href="/plugins" class="mt-6 inline-flex items-center rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors">Browse Plugins</a>
      </div>
    </section>
  </BaseLayout>
) : (
  <BaseLayout title={plugin.name + ' - emdashcms.org'} description={plugin.description ?? undefined}>
    <section class="pt-24 pb-16 px-6">
      <div class="mx-auto max-w-5xl">

        <a href="/plugins" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors">&larr; Back to Plugins</a>

        <div class="mt-6 lg:grid lg:grid-cols-3 lg:gap-8">

          <div class="lg:col-span-2">

            <div class="flex items-start gap-4">
              <div class="flex-1">
                <h1 class="text-3xl font-semibold tracking-tight leading-[1.15]">{plugin.name}</h1>
                <div class="mt-2 flex items-center gap-3">
                  {plugin.author.avatarUrl ? (
                    <img src={plugin.author.avatarUrl} alt={plugin.author.name} class="w-5 h-5 rounded-full" />
                  ) : (
                    <div class="w-5 h-5 rounded-full bg-zinc-800" />
                  )}
                  <span class="text-sm text-zinc-400">{plugin.author.name}</span>
                </div>
              </div>
            </div>

            <div class="mt-4 flex items-center gap-4 flex-wrap">
              <span class="text-sm text-zinc-500">{plugin.installCount.toLocaleString()} installs</span>
              {plugin.latestVersion?.audit && (
                <AuditBadge verdict={plugin.latestVersion.audit.verdict} />
              )}
              {plugin.latestVersion?.audit && (
                <span class="text-xs text-zinc-500">Risk score: {plugin.latestVersion.audit.riskScore}/100</span>
              )}
            </div>

            {plugin.capabilities.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-1.5">
                {plugin.capabilities.map(cap => (
                  <span class="rounded-full bg-zinc-800 px-2.5 py-0.5 text-xs text-zinc-400">{cap}</span>
                ))}
              </div>
            )}

            <div class="mt-8 space-y-4">
              {plugin.latestVersion && (plugin.latestVersion.status === 'published' || plugin.latestVersion.status === 'flagged') && (
                <a
                  href={`/api/v1/plugins/${encodeURIComponent(plugin.id)}/versions/${plugin.latestVersion.version}/bundle`}
                  class="flex items-center justify-center gap-2 w-full rounded-lg bg-white text-zinc-950 px-5 py-3 text-sm font-semibold hover:bg-zinc-200 transition-colors"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
                  Download v{plugin.latestVersion.version} ({formatSize(plugin.latestVersion.bundleSize)})
                </a>
              )}

              <div>
                <h2 class="text-sm font-semibold text-zinc-100">Plugin ID</h2>
                <div class="mt-2 flex items-center gap-2 rounded-lg border border-zinc-800 bg-zinc-900 p-3">
                  <code class="flex-1 text-sm font-mono text-zinc-300">{plugin.id}</code>
                  <button
                    data-copy={plugin.id}
                    class="flex-shrink-0 rounded-md border border-zinc-700 bg-zinc-800 px-3 py-1 text-xs font-medium text-zinc-300 hover:bg-zinc-700 hover:text-zinc-100 transition-colors"
                    aria-label="Copy plugin ID"
                  >Copy</button>
                </div>
              </div>

              <a href="/guide" class="flex items-center gap-1.5 text-xs text-zinc-500 hover:text-zinc-300 transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
                How to install plugins &rarr;
              </a>
            </div>

            {plugin.description && (
              <div class="mt-8">
                <h2 class="text-sm font-semibold text-zinc-100">Description</h2>
                <p class="mt-2 text-sm text-zinc-400 leading-relaxed">{plugin.description}</p>
              </div>
            )}

            {plugin.latestVersion?.audit && (
              <div class="mt-8">
                <h2 class="text-sm font-semibold text-zinc-100">Audit Summary</h2>
                <div class="mt-2 rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-4">
                  <div class="flex items-center gap-3">
                    <AuditBadge verdict={plugin.latestVersion.audit.verdict} />
                    <span class="text-sm text-zinc-400">Risk score: {plugin.latestVersion.audit.riskScore}/100</span>
                    <span class="text-sm text-zinc-500">{plugin.latestVersion.audit.findings.length} findings</span>
                  </div>
                  {plugin.latestVersion.audit.findings.length > 0 && (
                    <ul class="mt-3 space-y-1.5">
                      {plugin.latestVersion.audit.findings.map(f => (
                        <li class="flex items-start gap-2 text-sm">
                          <span class:list={[
                            'flex-shrink-0 rounded px-1.5 py-0.5 text-[11px] font-medium uppercase',
                            f.severity === 'critical' && 'bg-red-950/40 text-red-400',
                            f.severity === 'high' && 'bg-red-950/40 text-red-400',
                            f.severity === 'medium' && 'bg-amber-950/40 text-amber-400',
                            f.severity === 'low' && 'bg-zinc-800 text-zinc-400',
                            f.severity === 'info' && 'bg-zinc-800 text-zinc-500',
                          ]}>{f.severity}</span>
                          <span class="text-zinc-300">{f.title}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </div>
            )}
          </div>

          <aside class="mt-8 lg:mt-0">
            <div class="rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6 space-y-4">
              {!plugin.latestVersion && versions.length > 0 && (
                <div>
                  <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Latest Version</dt>
                  <dd class="mt-1 flex items-center gap-2">
                    <span class="text-sm font-mono text-zinc-400">{versions[0].version}</span>
                    <StatusBadge status={versions[0].status} />
                  </dd>
                </div>
              )}
              {plugin.latestVersion && (
                <div>
                  <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Latest Version</dt>
                  <dd class="mt-1 text-sm font-mono text-zinc-300">{plugin.latestVersion.version}</dd>
                </div>
              )}
              {plugin.license && (
                <div>
                  <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">License</dt>
                  <dd class="mt-1 text-sm text-zinc-300">{plugin.license}</dd>
                </div>
              )}
              {plugin.repositoryUrl && (
                <div>
                  <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Repository</dt>
                  <dd class="mt-1"><a href={plugin.repositoryUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors break-all">{plugin.repositoryUrl.replace('https://', '')}</a></dd>
                </div>
              )}
              {plugin.homepageUrl && (
                <div>
                  <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Homepage</dt>
                  <dd class="mt-1"><a href={plugin.homepageUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors break-all">{plugin.homepageUrl.replace('https://', '')}</a></dd>
                </div>
              )}
              {plugin.keywords.length > 0 && (
                <div>
                  <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Keywords</dt>
                  <dd class="mt-1 flex flex-wrap gap-1.5">
                    {plugin.keywords.map(kw => (
                      <span class="rounded-full bg-zinc-800 px-2 py-0.5 text-[11px] text-zinc-400">{kw}</span>
                    ))}
                  </dd>
                </div>
              )}
              <div>
                <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Created</dt>
                <dd class="mt-1 text-sm text-zinc-500">{formatDate(plugin.createdAt)}</dd>
              </div>
              <div>
                <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Updated</dt>
                <dd class="mt-1 text-sm text-zinc-500">{formatDate(plugin.updatedAt)}</dd>
              </div>
            </div>
          </aside>
        </div>

        {!plugin.latestVersion && versions.length > 0 && (
          <div class="mt-8 rounded-xl border border-amber-800/30 bg-amber-950/20 p-6 text-center">
            <p class="text-sm text-amber-400/80">This plugin has no published versions yet.</p>
            <p class="mt-1 text-xs text-zinc-500">All versions are reviewed by automated security audit before publication.</p>
          </div>
        )}

        {versions.length > 0 && (
          <div class="mt-12">
            <h2 class="text-sm font-semibold text-zinc-100">Version History</h2>
            <div class="mt-4 overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-zinc-800 text-left">
                    <th class="pb-3 pr-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Version</th>
                    <th class="pb-3 pr-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Status</th>
                    <th class="pb-3 pr-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Audit</th>
                    <th class="pb-3 pr-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Size</th>
                    <th class="pb-3 pr-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Date</th>
                    <th class="pb-3 text-xs font-semibold text-zinc-500 uppercase tracking-wide"></th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-zinc-800/60">
                  {versions.map(v => (
                    <tr>
                      <td class="py-3 pr-4 font-mono text-zinc-300">{v.version}</td>
                      <td class="py-3 pr-4"><StatusBadge status={v.status} /></td>
                      <td class="py-3 pr-4"><AuditBadge verdict={v.auditVerdict} /></td>
                      <td class="py-3 pr-4 text-zinc-500">{formatSize(v.bundleSize)}</td>
                      <td class="py-3 pr-4 text-zinc-500">{formatDate(v.publishedAt)}</td>
                      <td class="py-3">
                        {(v.status === 'published' || v.status === 'flagged') && (
                          <a href={`/api/v1/plugins/${encodeURIComponent(plugin.id)}/versions/${v.version}/bundle`} class="text-xs text-zinc-400 hover:text-zinc-100 transition-colors">Download</a>
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

      </div>
    </section>

    <script>
      document.querySelectorAll('[data-copy]').forEach(btn => {
        btn.addEventListener('click', () => {
          const text = (btn as HTMLElement).dataset.copy;
          if (!text) return;
          navigator.clipboard.writeText(text).then(() => {
            btn.textContent = 'Copied!';
            setTimeout(() => btn.textContent = 'Copy', 2000);
          });
        });
      });
    </script>
  </BaseLayout>
)}
