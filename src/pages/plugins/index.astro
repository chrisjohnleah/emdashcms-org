---
export const prerender = false;

import { env } from 'cloudflare:workers';
import { searchPlugins } from '../../lib/db/queries';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PluginCard from '../../components/PluginCard.astro';
import SearchBar from '../../components/SearchBar.astro';
import Pagination from '../../components/Pagination.astro';
import EmptyState from '../../components/EmptyState.astro';

const url = Astro.url;
const q = url.searchParams.get('q') ?? '';
const category = url.searchParams.get('category') ?? null;
const sort = url.searchParams.get('sort') ?? 'downloads';
const cursor = url.searchParams.get('cursor') ?? null;

const { items: plugins, nextCursor } = await searchPlugins(env.DB, {
  query: q,
  category,
  capability: null,
  sort,
  cursor,
  limit: 12,
});

const sortOptions = [
  { value: 'downloads', label: 'Most downloaded' },
  { value: 'installs', label: 'Most installed' },
  { value: 'updated', label: 'Recently updated' },
  { value: 'created', label: 'Recently added' },
  { value: 'name', label: 'Name A-Z' },
];

const isFiltered = q || category;
---
<BaseLayout title="Plugins - emdashcms.org" description="Browse community plugins for EmDash CMS. Search, filter by capability, and discover extensions for your site.">
  <section class="page pt-12 pb-16 md:pt-16">

      <h1 class="text-3xl tracking-tight leading-[1.15]" style="font-weight: 500; letter-spacing: -0.02em;">Plugins</h1>

      <div class="mt-8">
        <SearchBar action="/plugins" placeholder="Search plugins..." value={q} />
      </div>

      <div class="mt-4 flex justify-end">
        <form method="GET" action="/plugins" class="flex-shrink-0">
          {q && <input type="hidden" name="q" value={q} />}
          {category && <input type="hidden" name="category" value={category} />}
          <select
            name="sort"
            data-auto-submit
            class="rounded-md border border-rule-strong bg-paper-soft px-3 py-2 text-sm text-ink focus:border-accent-deep focus:outline-none"
          >
            {sortOptions.map(opt => (
              <option value={opt.value} selected={sort === opt.value}>{opt.label}</option>
            ))}
          </select>
        </form>
      </div>

      {plugins.length > 0 ? (
        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {plugins.map(plugin => <PluginCard plugin={plugin} />)}
        </div>
      ) : isFiltered ? (
        <div class="mt-8">
          <EmptyState
            heading="No plugins found"
            body="Try adjusting your search or filters to find what you're looking for."
          />
        </div>
      ) : (
        <div class="mt-8">
          <EmptyState
            heading="No plugins published yet"
            body="Be the first to publish a plugin. Sign in with GitHub to get started."
            linkHref="/dashboard"
            linkText="Go to Dashboard"
          />
        </div>
      )}

      {plugins.length > 0 && (
        <div class="mt-8">
          <Pagination nextCursor={nextCursor} count={plugins.length} label="plugins" baseUrl="/plugins" />
        </div>
      )}

  </section>

  <script>
    document.querySelectorAll('[data-auto-submit]').forEach(el => {
      el.addEventListener('change', () => {
        const select = el as unknown as HTMLSelectElement;
        select.form?.submit();
      });
    });
  </script>
</BaseLayout>
