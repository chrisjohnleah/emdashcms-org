---
export const prerender = false;

import { env } from 'cloudflare:workers';
import { getThemeDetail } from '../../lib/db/queries';
import BaseLayout from '../../layouts/BaseLayout.astro';

const { id } = Astro.params;
const theme = await getThemeDetail(env.DB, id!);

if (!theme) {
  Astro.response.status = 404;
}
---
{!theme ? (
  <BaseLayout title="Theme not found - emdashcms.org">
    <section class="pt-24 pb-16 px-6">
      <div class="mx-auto max-w-5xl text-center py-16">
        <h1 class="text-xl font-semibold text-zinc-100">Theme not found</h1>
        <p class="mt-2 text-sm text-zinc-400">The theme you're looking for doesn't exist or may have been removed.</p>
        <a href="/themes" class="mt-6 inline-flex items-center rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors">Browse Themes</a>
      </div>
    </section>
  </BaseLayout>
) : (
  <BaseLayout title={theme.name + " - emdashcms.org"}>
    <section class="pt-24 pb-16 px-6">
      <div class="mx-auto max-w-5xl">

        <a href="/themes" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors">&larr; Back to Themes</a>

        <div class="mt-6 max-w-3xl">

          <h1 class="text-3xl font-semibold tracking-tight leading-[1.15]">{theme.name}</h1>
          <div class="mt-2 flex items-center gap-3">
            {theme.author.avatarUrl ? (
              <img src={theme.author.avatarUrl} alt={theme.author.name} class="w-5 h-5 rounded-full" />
            ) : (
              <div class="w-5 h-5 rounded-full bg-zinc-800" />
            )}
            <span class="text-sm text-zinc-400">{theme.author.name}</span>
          </div>

          {theme.previewUrl && (
            <div class="mt-6">
              <a
                href={theme.previewUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
                Preview Theme
              </a>
            </div>
          )}

          {theme.description && (
            <div class="mt-8">
              <h2 class="text-sm font-semibold text-zinc-100">Description</h2>
              <p class="mt-2 text-sm text-zinc-400 leading-relaxed">{theme.description}</p>
            </div>
          )}

          {theme.screenshotUrls.length > 0 && (
            <div class="mt-8">
              <h2 class="text-sm font-semibold text-zinc-100">Screenshots</h2>
              <div class="mt-2 flex gap-3 overflow-x-auto pb-2" role="list" style="scroll-snap-type: x mandatory;">
                {theme.screenshotUrls.map((url, index) => (
                  <a
                    href={url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex-none w-60"
                    role="listitem"
                  >
                    <img
                      src={url}
                      alt={`Screenshot ${index + 1} of ${theme.name}`}
                      class="aspect-video rounded-lg object-cover w-full hover:opacity-90 transition-opacity"
                      style="scroll-snap-align: start;"
                    />
                  </a>
                ))}
              </div>
            </div>
          )}

          <div class="mt-8 rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6 space-y-4">
            {theme.keywords.length > 0 && (
              <div>
                <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Keywords</dt>
                <dd class="mt-1 flex flex-wrap gap-1.5">
                  {theme.keywords.map(kw => (
                    <span class="rounded-full bg-zinc-800 px-2 py-0.5 text-[11px] text-zinc-400">{kw}</span>
                  ))}
                </dd>
              </div>
            )}
            {theme.license && (
              <div>
                <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">License</dt>
                <dd class="mt-1 text-sm text-zinc-300">{theme.license}</dd>
              </div>
            )}
            {theme.repositoryUrl && (
              <div>
                <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Repository</dt>
                <dd class="mt-1"><a href={theme.repositoryUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors break-all">{theme.repositoryUrl.replace('https://', '')}</a></dd>
              </div>
            )}
            {theme.homepageUrl && (
              <div>
                <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Homepage</dt>
                <dd class="mt-1"><a href={theme.homepageUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors break-all">{theme.homepageUrl.replace('https://', '')}</a></dd>
              </div>
            )}
            {theme.demoUrl && (
              <div>
                <dt class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Demo</dt>
                <dd class="mt-1"><a href={theme.demoUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors break-all">{theme.demoUrl.replace('https://', '')}</a></dd>
              </div>
            )}
          </div>

        </div>
      </div>
    </section>
  </BaseLayout>
)}
