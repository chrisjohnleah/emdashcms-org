---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DashboardBanner from '../../../components/DashboardBanner.astro';
import RoleBadge from '../../../components/RoleBadge.astro';
import { resolveAuthorId } from '../../../lib/publishing/plugin-queries';
import {
  getCollaborators,
  createInvite,
  removeCollaborator,
  updateCollaboratorRole,
  transferOwnership,
  deleteTheme,
  getPendingInvitesForPlugin,
} from '../../../lib/auth/collaborator-queries';
import { updateThemeMetadata, updateThemeThumbnailKey, updateThemeScreenshotKeys } from '../../../lib/publishing/theme-queries';
import { checkPluginAccess, hasRole, type Role } from '../../../lib/auth/permissions';
import { validateImageUpload, storeImageInR2, MIME_TO_EXT } from '../../../lib/publishing/image-storage';
import { getThemeDetail } from '../../../lib/db/queries';
import {
  getPluginGitHubLink,
  getInstallationByAuthor,
  linkPluginToRepo,
  toggleAutoSubmit,
  unlinkPlugin,
  setTagPattern,
} from '../../../lib/github/queries';
import {
  getInstallationToken,
  listInstallationRepos,
  type GitHubRepo,
} from '../../../lib/github/installation';

const { id: themeId } = Astro.params;
const author = Astro.locals.author!;

// RBAC check — any collaborator role can view (D-06, D-10)
const authorId = await resolveAuthorId(env.DB, author.githubId);
if (!authorId) return Astro.redirect('/dashboard/themes');

const access = await checkPluginAccess(env.DB, authorId, themeId!);
if (!access.found || !access.role) return Astro.redirect('/dashboard/themes');
const userRole = access.role as Role;
const isOwner = userRole === 'owner';
const isMaintainer = hasRole(userRole, 'maintainer');

let saveSuccess = false;
let saveError = '';
let imageSuccess = false;
let imageError = '';
let githubSuccess = '';
let githubError = '';

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const action = data.get('_action') as string;

  if (action === 'metadata') {
    try {
      if (!isMaintainer) throw new Error('Maintainer role required to edit metadata');
      const description = (data.get('description') as string ?? '').trim();
      const keywordsRaw = (data.get('keywords') as string ?? '').trim();
      const previewUrl = (data.get('previewUrl') as string ?? '').trim();
      const demoUrl = (data.get('demoUrl') as string ?? '').trim();
      const repositoryUrl = (data.get('repositoryUrl') as string ?? '').trim();
      const homepageUrl = (data.get('homepageUrl') as string ?? '').trim();
      const license = (data.get('license') as string ?? '').trim();

      const keywordsArray = keywordsRaw
        ? keywordsRaw.split(',').map((k: string) => k.trim()).filter(Boolean)
        : [];

      await updateThemeMetadata(env.DB, themeId!, {
        description,
        keywords: keywordsArray,
        previewUrl: previewUrl || undefined,
        demoUrl: demoUrl || undefined,
        repositoryUrl: repositoryUrl || undefined,
        homepageUrl: homepageUrl || undefined,
        license: license || undefined,
      });
      saveSuccess = true;
    } catch (e) {
      saveError = e instanceof Error ? e.message : 'An error occurred';
    }
  }

  if (action === 'images') {
    try {
      if (!isMaintainer) throw new Error('Maintainer role required to upload images');
      const thumbnail = data.get('thumbnail') as File | null;
      if (thumbnail && thumbnail.size > 0) {
        const validation = validateImageUpload(thumbnail);
        if (!validation.valid) throw new Error(validation.error);
        const ext = MIME_TO_EXT[thumbnail.type];
        const key = 'themes/' + themeId + '/thumbnail.' + ext;
        await storeImageInR2(env.ARTIFACTS, key, thumbnail);
        await updateThemeThumbnailKey(env.DB, themeId!, key);
      }

      const screenshots = data.getAll('screenshots') as File[];
      const validScreenshots = screenshots.filter(f => f.size > 0);
      if (validScreenshots.length > 5) throw new Error('Maximum 5 screenshots allowed.');

      if (validScreenshots.length > 0) {
        const newKeys: string[] = [];
        for (let i = 0; i < validScreenshots.length; i++) {
          const file = validScreenshots[i];
          const validation = validateImageUpload(file);
          if (!validation.valid) throw new Error(validation.error);
          const ext = MIME_TO_EXT[file.type];
          const key = 'themes/' + themeId + '/screenshots/' + i + '.' + ext;
          await storeImageInR2(env.ARTIFACTS, key, file);
          newKeys.push(key);
        }

        // Clean up stale screenshots beyond new count
        const existingRow = await env.DB.prepare(
          'SELECT screenshot_keys FROM themes WHERE id = ?'
        ).bind(themeId).first<{ screenshot_keys: string | null }>();
        const oldKeys: string[] = existingRow?.screenshot_keys
          ? JSON.parse(existingRow.screenshot_keys)
          : [];
        for (let i = newKeys.length; i < oldKeys.length; i++) {
          await env.ARTIFACTS.delete(oldKeys[i]);
        }

        await updateThemeScreenshotKeys(env.DB, themeId!, newKeys);
      }

      imageSuccess = true;
    } catch (e) {
      imageError = e instanceof Error ? e.message : 'An error occurred';
    }
  }

  // plugin_github_links.plugin_id used for both plugins and themes (D1 FK not enforced)
  if (action === 'connect-repo') {
    try {
      if (!isMaintainer) throw new Error('Maintainer role required');
      const repoFullName = data.get('repo_full_name') as string;
      const repoId = Number(data.get('repo_id'));
      if (!repoFullName || !repoId) throw new Error('Select a repository');
      const ghInstallation = await getInstallationByAuthor(env.DB, authorId);
      if (!ghInstallation) throw new Error('No GitHub App installation found');
      await linkPluginToRepo(env.DB, {
        pluginId: themeId!,
        installationId: ghInstallation.id,
        repoFullName,
        repoId,
      });
      githubSuccess = 'GitHub repository connected.';
    } catch (e) {
      githubError = e instanceof Error ? e.message : 'An error occurred';
    }
  }

  if (action === 'toggle-auto-submit') {
    try {
      if (!isMaintainer) throw new Error('Maintainer role required');
      const link = await getPluginGitHubLink(env.DB, themeId!);
      if (link) {
        await toggleAutoSubmit(env.DB, themeId!, !link.autoSubmit);
        githubSuccess = 'Auto-submit setting updated.';
      }
    } catch (e) {
      githubError = e instanceof Error ? e.message : 'An error occurred';
    }
  }

  if (action === 'disconnect') {
    try {
      if (!isOwner) throw new Error('Only the owner can disconnect GitHub');
      await unlinkPlugin(env.DB, themeId!);
      githubSuccess = 'GitHub repository disconnected.';
    } catch (e) {
      githubError = e instanceof Error ? e.message : 'An error occurred';
    }
  }

  if (action === 'update-tag-pattern') {
    try {
      if (!isMaintainer) throw new Error('Maintainer role required');
      const pattern = (data.get('tag_pattern') as string ?? '').trim();
      if (!pattern) throw new Error('Tag pattern cannot be empty');
      await setTagPattern(env.DB, themeId!, pattern);
      githubSuccess = 'Tag pattern updated.';
    } catch (e) {
      githubError = e instanceof Error ? e.message : 'An error occurred';
    }
  }

  if (action === 'invite') {
    try {
      if (!isOwner) throw new Error('Only the owner can invite collaborators');
      const username = (data.get('github_username') as string ?? '').trim();
      const role = data.get('role') as string;
      if (!username) throw new Error('GitHub username is required');
      if (role !== 'maintainer' && role !== 'contributor') throw new Error('Invalid role');
      await createInvite(env.DB, {
        pluginId: themeId!,
        invitedGithubUsername: username,
        role: role as 'maintainer' | 'contributor',
        invitedBy: authorId,
        inviterGithubUsername: author.username,
      });
      saveSuccess = true;
    } catch (e) {
      saveError = e instanceof Error ? e.message : 'An error occurred';
    }
  }

  if (action === 'change-role') {
    try {
      if (!isOwner) throw new Error('Only the owner can change roles');
      const collabAuthorId = data.get('collaborator_author_id') as string;
      const newRole = data.get('new_role') as string;
      if (newRole !== 'maintainer' && newRole !== 'contributor') throw new Error('Invalid role');
      await updateCollaboratorRole(env.DB, themeId!, collabAuthorId, newRole as 'maintainer' | 'contributor');
      saveSuccess = true;
    } catch (e) {
      saveError = e instanceof Error ? e.message : 'An error occurred';
    }
  }

  if (action === 'remove-collaborator') {
    try {
      if (!isOwner) throw new Error('Only the owner can remove collaborators');
      const collabAuthorId = data.get('collaborator_author_id') as string;
      await removeCollaborator(env.DB, themeId!, collabAuthorId);
      saveSuccess = true;
    } catch (e) {
      saveError = e instanceof Error ? e.message : 'An error occurred';
    }
  }

  if (action === 'transfer-ownership') {
    try {
      if (!isOwner) throw new Error('Only the owner can transfer ownership');
      const confirmId = (data.get('confirm_theme_id') as string ?? '').trim();
      const newOwnerAuthorId = data.get('new_owner_author_id') as string;
      if (confirmId !== themeId) throw new Error('Theme ID does not match. Transfer cancelled.');
      await transferOwnership(env.DB, themeId!, authorId, newOwnerAuthorId, 'theme');
      return Astro.redirect('/dashboard');
    } catch (e) {
      saveError = e instanceof Error ? e.message : 'An error occurred';
    }
  }

  if (action === 'delete-theme') {
    try {
      if (!isOwner) throw new Error('Only the owner can delete this theme');
      const confirmId = (data.get('confirm_theme_id') as string ?? '').trim();
      if (confirmId !== themeId) throw new Error('Theme ID does not match. Deletion cancelled.');
      await deleteTheme(env.DB, env.ARTIFACTS, themeId!);
      return Astro.redirect('/dashboard');
    } catch (e) {
      saveError = e instanceof Error ? e.message : 'An error occurred';
    }
  }
}

// Load theme data (re-fetch after potential update)
const theme = await getThemeDetail(env.DB, themeId!);
if (!theme) return Astro.redirect('/dashboard/themes');

// Team data
const collaborators = await getCollaborators(env.DB, themeId!);
const pendingThemeInvites = await getPendingInvitesForPlugin(env.DB, themeId!);

// Fetch raw values for editable form fields
const rawTheme = await env.DB.prepare(
  'SELECT description, keywords, preview_url, demo_url, repository_url, homepage_url, license, thumbnail_key, screenshot_keys FROM themes WHERE id = ?'
).bind(themeId).first<{
  description: string | null;
  keywords: string | null;
  preview_url: string | null;
  demo_url: string | null;
  repository_url: string | null;
  homepage_url: string | null;
  license: string | null;
  thumbnail_key: string | null;
  screenshot_keys: string | null;
}>();

const parsedKeywords = (() => {
  try {
    return JSON.parse(rawTheme?.keywords || '[]').join(', ');
  } catch {
    return '';
  }
})();

const currentScreenshotKeys: string[] = (() => {
  try {
    return JSON.parse(rawTheme?.screenshot_keys || '[]');
  } catch {
    return [];
  }
})();

// GitHub integration state
const githubLink = await getPluginGitHubLink(env.DB, themeId!);
const ghInstall = await getInstallationByAuthor(env.DB, authorId);

let availableRepos: GitHubRepo[] = [];
if (ghInstall && !githubLink) {
  try {
    const token = await getInstallationToken(
      ghInstall.id,
      env.GITHUB_CLIENT_ID,
      env.GITHUB_APP_PRIVATE_KEY,
    );
    availableRepos = await listInstallationRepos(token);
  } catch (err) {
    console.error('[dashboard] Failed to list repos:', err);
  }
}
---
<BaseLayout title={theme.name + ' - Dashboard - emdashcms.org'}>
  <section class="pt-24 pb-16 px-6">
    <div class="mx-auto max-w-5xl">

      <a href="/dashboard/themes" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors">&larr; Back to Themes</a>

      <h1 class="mt-4 text-3xl font-semibold tracking-tight leading-[1.15] text-zinc-100">{theme.name}</h1>

      {saveSuccess && (
        <div class="mt-6">
          <DashboardBanner type="success" message="Theme details updated." />
        </div>
      )}
      {saveError && (
        <div class="mt-6">
          <DashboardBanner type="error" message={'Failed to update theme details. ' + saveError} />
        </div>
      )}
      {imageSuccess && (
        <div class="mt-6">
          <DashboardBanner type="success" message="Images uploaded successfully." />
        </div>
      )}
      {imageError && (
        <div class="mt-6">
          <DashboardBanner type="error" message={'Failed to upload images. ' + imageError} />
        </div>
      )}

      <!-- Section 1: Theme Details -->
      <div class="mt-8">
        <h2 class="text-xl font-semibold text-zinc-100">Theme Details</h2>
        {isMaintainer ? (
          <form method="POST" class="mt-4 rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6 space-y-4">
            <input type="hidden" name="_action" value="metadata" />

            <div>
              <dt class="text-sm font-semibold text-zinc-100">Theme ID</dt>
              <dd class="mt-1 text-sm text-zinc-400 font-mono">{theme.id}</dd>
            </div>

            <div>
              <dt class="text-sm font-semibold text-zinc-100">Name</dt>
              <dd class="mt-1 text-sm text-zinc-400">{theme.name}</dd>
            </div>

            <div>
              <label for="description" class="block text-sm font-semibold text-zinc-100">Description</label>
              <textarea id="description" name="description"
                class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm min-h-[80px] resize-y focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500"
              >{rawTheme?.description ?? ''}</textarea>
            </div>

            <div>
              <label for="keywords" class="block text-sm font-semibold text-zinc-100">Keywords</label>
              <p class="mt-1 text-xs text-zinc-500">Comma-separated (e.g. blog, minimal, dark)</p>
              <input type="text" id="keywords" name="keywords" value={parsedKeywords}
                class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500" />
            </div>

            <div>
              <label for="previewUrl" class="block text-sm font-semibold text-zinc-100">Preview URL</label>
              <input type="url" id="previewUrl" name="previewUrl" value={rawTheme?.preview_url ?? ''}
                class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500" />
            </div>

            <div>
              <label for="demoUrl" class="block text-sm font-semibold text-zinc-100">Demo URL</label>
              <input type="url" id="demoUrl" name="demoUrl" value={rawTheme?.demo_url ?? ''}
                class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500" />
            </div>

            <div>
              <label for="repositoryUrl" class="block text-sm font-semibold text-zinc-100">Repository URL</label>
              <input type="url" id="repositoryUrl" name="repositoryUrl" value={rawTheme?.repository_url ?? ''}
                class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500" />
            </div>

            <div>
              <label for="homepageUrl" class="block text-sm font-semibold text-zinc-100">Homepage URL</label>
              <input type="url" id="homepageUrl" name="homepageUrl" value={rawTheme?.homepage_url ?? ''}
                class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500" />
            </div>

            <div>
              <label for="license" class="block text-sm font-semibold text-zinc-100">License</label>
              <input type="text" id="license" name="license" value={rawTheme?.license ?? ''}
                class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500" />
            </div>

            <button type="submit" class="rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors">Save Theme Details</button>

          </form>
        ) : (
          <div class="mt-4 rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6 space-y-4">
            <div>
              <dt class="text-sm font-semibold text-zinc-100">Theme ID</dt>
              <dd class="mt-1 text-sm text-zinc-400 font-mono">{theme.id}</dd>
            </div>
            <div>
              <dt class="text-sm font-semibold text-zinc-100">Name</dt>
              <dd class="mt-1 text-sm text-zinc-400">{theme.name}</dd>
            </div>
            <div>
              <dt class="text-sm font-semibold text-zinc-100">Description</dt>
              <dd class="mt-1 text-sm text-zinc-400">{rawTheme?.description ?? 'No description'}</dd>
            </div>
            <div>
              <dt class="text-sm font-semibold text-zinc-100">Keywords</dt>
              <dd class="mt-1 text-sm text-zinc-400">{parsedKeywords || 'None'}</dd>
            </div>
            <div>
              <dt class="text-sm font-semibold text-zinc-100">License</dt>
              <dd class="mt-1 text-sm text-zinc-400">{rawTheme?.license ?? 'Not specified'}</dd>
            </div>
          </div>
        )}
      </div>

      {githubSuccess && (
        <div class="mt-6">
          <DashboardBanner type="success" message={githubSuccess} />
        </div>
      )}
      {githubError && (
        <div class="mt-6">
          <DashboardBanner type="error" message={githubError} />
        </div>
      )}

      <div class="mt-12">
        <h2 class="text-xl font-semibold text-zinc-100">GitHub</h2>
        <div class="mt-4 rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6">
          {githubLink ? (
            <div class="space-y-4">
              <div>
                <span class="text-sm text-zinc-100 font-mono">{githubLink.repoFullName}</span>
                <span class="ml-3 text-sm text-emerald-400">Connected</span>
              </div>
              {isMaintainer && (
                <div class="flex items-center gap-3">
                  <form method="POST">
                    <input type="hidden" name="_action" value="toggle-auto-submit" />
                    <button type="submit" class="rounded-lg bg-zinc-900 border border-zinc-800 px-4 py-2 text-sm text-zinc-300 hover:bg-zinc-800 hover:text-zinc-100 transition-colors">
                      {githubLink.autoSubmit ? 'Pause auto-submit' : 'Enable auto-submit'}
                    </button>
                  </form>
                  <span class:list={['text-sm', githubLink.autoSubmit ? 'text-emerald-400' : 'text-amber-400']}>
                    {githubLink.autoSubmit ? 'Auto-submit on release' : 'Auto-submit paused'}
                  </span>
                </div>
              )}
              {!isMaintainer && (
                <div class="flex items-center gap-3">
                  <span class:list={['text-sm', githubLink.autoSubmit ? 'text-emerald-400' : 'text-amber-400']}>
                    {githubLink.autoSubmit ? 'Auto-submit on release' : 'Auto-submit paused'}
                  </span>
                </div>
              )}
              {isMaintainer && (
                <form method="POST" class="flex items-end gap-3">
                  <input type="hidden" name="_action" value="update-tag-pattern" />
                  <div class="flex-1">
                    <label for="theme_tag_pattern" class="block text-sm font-semibold text-zinc-100">Tag pattern</label>
                    <p class="mt-1 text-xs text-zinc-500">Glob pattern for release tags (e.g. v*, release-*, *). Only matching tags trigger auto-submit.</p>
                    <input type="text" id="theme_tag_pattern" name="tag_pattern" value={githubLink.tagPattern}
                      class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500"
                      placeholder="*" />
                  </div>
                  <button type="submit" class="rounded-lg bg-zinc-900 border border-zinc-800 px-4 py-2.5 text-sm text-zinc-300 hover:bg-zinc-800 hover:text-zinc-100 transition-colors">
                    Save pattern
                  </button>
                </form>
              )}
              {!isMaintainer && (
                <div>
                  <dt class="text-sm font-semibold text-zinc-100">Tag pattern</dt>
                  <dd class="mt-1 text-sm text-zinc-400 font-mono">{githubLink.tagPattern}</dd>
                </div>
              )}
              {isOwner && (
                <div class="flex justify-end">
                  <form method="POST">
                    <input type="hidden" name="_action" value="disconnect" />
                    <button type="submit" class="rounded-lg bg-red-950/40 border border-red-800/60 px-4 py-2 text-sm text-red-400 hover:bg-red-950/60 hover:text-red-300 transition-colors">
                      Disconnect {githubLink.repoFullName}
                    </button>
                  </form>
                </div>
              )}
            </div>
          ) : isMaintainer && ghInstall ? (
            <form method="POST" class="space-y-4">
              <input type="hidden" name="_action" value="connect-repo" />
              <input type="hidden" name="repo_id" id="theme_repo_id" value="" />
              <div>
                <label for="theme_repo_select" class="block text-sm font-semibold text-zinc-100">Select repository</label>
                {availableRepos.length === 0 ? (
                  <p class="mt-2 text-sm text-zinc-500">No accessible repositories found. Install the GitHub App on your repos first.</p>
                ) : (
                  <div class="mt-2 flex items-end gap-3">
                    <select id="theme_repo_select" name="repo_full_name"
                      class="flex-1 bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500">
                      <option value="">Choose a repository...</option>
                      {availableRepos.map(repo => (
                        <option value={repo.full_name} data-repo-id={repo.id}>{repo.full_name}</option>
                      ))}
                    </select>
                    <button type="submit" class="rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors">Connect</button>
                  </div>
                )}
              </div>
              <script>
document.getElementById('theme_repo_select')?.addEventListener('change', function (this: HTMLSelectElement) {
  const selected = this.options[this.selectedIndex];
  const repoIdInput = document.getElementById('theme_repo_id') as HTMLInputElement | null;
  if (repoIdInput) {
    repoIdInput.value = selected.getAttribute('data-repo-id') || '';
  }
});
</script>
            </form>
          ) : isMaintainer ? (
            <div>
              <p class="text-sm text-zinc-400">No GitHub repository connected.</p>
              <p class="mt-1 text-sm text-zinc-500">Connect a repo to automatically submit new versions when you publish a release.</p>
              <div class="mt-4">
                <a href={`https://github.com/apps/emdashcms/installations/new?state=${themeId}`}
                  class="inline-flex items-center rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors">
                  Connect GitHub Repo
                </a>
              </div>
            </div>
          ) : (
            <div>
              <p class="text-sm text-zinc-400">No GitHub repository connected.</p>
            </div>
          )}
        </div>
      </div>

      <!-- Section 2: Images -->
      <div class="mt-12">
        <h2 class="text-xl font-semibold text-zinc-100">Images</h2>
        {isMaintainer ? (
          <form method="POST" enctype="multipart/form-data" class="mt-4 rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6 space-y-4">
            <input type="hidden" name="_action" value="images" />

            <div>
              <label for="thumbnail" class="block text-sm font-semibold text-zinc-100">Thumbnail</label>
              {rawTheme?.thumbnail_key ? (
                <div class="mt-2">
                  <img src={'/api/v1/images/' + rawTheme.thumbnail_key} alt="Current thumbnail" class="w-[120px] aspect-video rounded-lg object-cover" />
                </div>
              ) : (
                <p class="mt-2 text-sm text-zinc-500">No thumbnail uploaded</p>
              )}
              <input type="file" id="thumbnail" name="thumbnail" accept="image/jpeg,image/png,image/webp"
                class="mt-2 block w-full text-sm text-zinc-400 file:mr-4 file:rounded-lg file:border-0 file:bg-zinc-800 file:px-4 file:py-2 file:text-sm file:font-medium file:text-zinc-300 hover:file:bg-zinc-700" />
              <p class="mt-1 text-xs text-zinc-500">Max 5MB. JPEG, PNG, or WebP.</p>
            </div>

            <div>
              <label for="screenshots" class="block text-sm font-semibold text-zinc-100">Screenshots</label>
              {currentScreenshotKeys.length > 0 && (
                <div class="mt-2 flex gap-3 overflow-x-auto pb-2">
                  {currentScreenshotKeys.map((key, index) => (
                    <img src={'/api/v1/images/' + key} alt={`Screenshot ${index + 1}`} class="w-[160px] aspect-video rounded-lg object-cover flex-none" />
                  ))}
                </div>
              )}
              <input type="file" id="screenshots" name="screenshots" accept="image/jpeg,image/png,image/webp" multiple
                class="mt-2 block w-full text-sm text-zinc-400 file:mr-4 file:rounded-lg file:border-0 file:bg-zinc-800 file:px-4 file:py-2 file:text-sm file:font-medium file:text-zinc-300 hover:file:bg-zinc-700" />
              <p class="mt-1 text-xs text-zinc-500">Up to 5 images. Max 5MB each. JPEG, PNG, or WebP.</p>
              <p class="mt-1 text-xs text-zinc-500">Uploading new screenshots replaces all existing screenshots.</p>
            </div>

            <button type="submit" class="rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors">Upload Images</button>

          </form>
        ) : (
          <div class="mt-4 rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6 space-y-4">
            <div>
              <dt class="text-sm font-semibold text-zinc-100">Thumbnail</dt>
              {rawTheme?.thumbnail_key ? (
                <div class="mt-2">
                  <img src={'/api/v1/images/' + rawTheme.thumbnail_key} alt="Current thumbnail" class="w-[120px] aspect-video rounded-lg object-cover" />
                </div>
              ) : (
                <p class="mt-2 text-sm text-zinc-500">No thumbnail uploaded</p>
              )}
            </div>
            {currentScreenshotKeys.length > 0 && (
              <div>
                <dt class="text-sm font-semibold text-zinc-100">Screenshots</dt>
                <div class="mt-2 flex gap-3 overflow-x-auto pb-2">
                  {currentScreenshotKeys.map((key, index) => (
                    <img src={'/api/v1/images/' + key} alt={`Screenshot ${index + 1}`} class="w-[160px] aspect-video rounded-lg object-cover flex-none" />
                  ))}
                </div>
              </div>
            )}
          </div>
        )}
      </div>

      <!-- Section: Team -->
      <div class="mt-12">
        <h2 class="text-xl font-semibold text-zinc-100">Team</h2>
        <div class="mt-4 rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6">

          <div class="space-y-3">
            {collaborators.map(collab => (
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span class="text-sm text-zinc-100">{collab.githubUsername}</span>
                  <RoleBadge role={collab.role} />
                </div>
                {isOwner && collab.role !== 'owner' && (
                  <div class="flex items-center gap-2">
                    <form method="POST" class="flex items-center gap-2">
                      <input type="hidden" name="_action" value="change-role" />
                      <input type="hidden" name="collaborator_author_id" value={collab.authorId} />
                      <select name="new_role"
                        class="bg-zinc-900 border border-zinc-800 text-zinc-300 rounded-lg px-2 py-1 text-sm focus:border-zinc-500 focus:outline-none">
                        <option value="maintainer" selected={collab.role === 'maintainer'}>Maintainer</option>
                        <option value="contributor" selected={collab.role === 'contributor'}>Contributor</option>
                      </select>
                      <button type="submit" class="rounded-lg bg-zinc-900 border border-zinc-800 px-3 py-1 text-sm text-zinc-300 hover:bg-zinc-800 transition-colors">Update</button>
                    </form>
                    <form method="POST">
                      <input type="hidden" name="_action" value="remove-collaborator" />
                      <input type="hidden" name="collaborator_author_id" value={collab.authorId} />
                      <button type="submit" class="rounded-lg bg-red-950/40 border border-red-800/60 px-3 py-1 text-sm text-red-400 hover:bg-red-950/60 transition-colors">Remove</button>
                    </form>
                  </div>
                )}
              </div>
            ))}
          </div>

          {pendingThemeInvites.length > 0 && (
            <div class="mt-4 pt-4 border-t border-zinc-800/60">
              <h3 class="text-sm font-semibold text-zinc-400 uppercase tracking-wide mb-3">Pending Invitations</h3>
              {pendingThemeInvites.map(invite => (
                <div class="flex items-center justify-between py-2">
                  <div class="flex items-center gap-3">
                    <span class="text-sm text-zinc-300">{invite.invitedGithubUsername}</span>
                    <RoleBadge role={invite.role as 'owner' | 'maintainer' | 'contributor'} />
                    <span class="text-xs text-zinc-500">Pending</span>
                  </div>
                </div>
              ))}
            </div>
          )}

          {isOwner && (
            <div class="mt-4 pt-4 border-t border-zinc-800/60">
              <h3 class="text-sm font-semibold text-zinc-400 uppercase tracking-wide mb-3">Invite Collaborator</h3>
              <form method="POST" class="flex items-end gap-3">
                <input type="hidden" name="_action" value="invite" />
                <div class="flex-1">
                  <label for="theme_github_username" class="block text-sm text-zinc-300">GitHub Username</label>
                  <input type="text" id="theme_github_username" name="github_username" required
                    class="mt-1 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500"
                    placeholder="username" />
                </div>
                <div>
                  <label for="theme_invite_role" class="block text-sm text-zinc-300">Role</label>
                  <select id="theme_invite_role" name="role"
                    class="mt-1 bg-zinc-900 border border-zinc-800 text-zinc-300 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none">
                    <option value="maintainer">Maintainer</option>
                    <option value="contributor">Contributor</option>
                  </select>
                </div>
                <button type="submit" class="rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors">Invite</button>
              </form>
            </div>
          )}
        </div>
      </div>

      {isOwner && collaborators.filter(c => c.role !== 'owner').length > 0 && (
        <div class="mt-12">
          <h2 class="text-xl font-semibold text-zinc-100">Transfer Ownership</h2>
          <div class="mt-4 rounded-xl border border-red-900/30 bg-zinc-900/40 p-6">
            <p class="text-sm text-zinc-400 mb-4">Transfer ownership to a collaborator. You will be downgraded to Maintainer.</p>
            <form method="POST" class="space-y-4">
              <input type="hidden" name="_action" value="transfer-ownership" />
              <div>
                <label for="theme_new_owner" class="block text-sm text-zinc-300">New Owner</label>
                <select id="theme_new_owner" name="new_owner_author_id"
                  class="mt-1 bg-zinc-900 border border-zinc-800 text-zinc-300 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none">
                  {collaborators.filter(c => c.role !== 'owner').map(c => (
                    <option value={c.authorId}>{c.githubUsername} ({c.role})</option>
                  ))}
                </select>
              </div>
              <div>
                <label for="theme_confirm_transfer_id" class="block text-sm text-zinc-300">Type <code class="font-mono text-zinc-100">{themeId}</code> to confirm</label>
                <input type="text" id="theme_confirm_transfer_id" name="confirm_theme_id" required
                  class="mt-1 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500"
                  placeholder="theme-id" />
              </div>
              <button type="submit" class="rounded-lg bg-red-950/40 border border-red-800/60 px-5 py-2.5 text-sm text-red-400 hover:bg-red-950/60 hover:text-red-300 transition-colors">Transfer Ownership</button>
            </form>
          </div>
        </div>
      )}

      {isOwner && (
        <div class="mt-12">
          <h2 class="text-xl font-semibold text-zinc-100">Danger Zone</h2>
          <div class="mt-4 rounded-xl border border-red-900/30 bg-zinc-900/40 p-6">
            <p class="text-sm text-zinc-400 mb-4">Permanently delete this theme and all its collaborator access. This action cannot be undone.</p>
            <form method="POST" class="space-y-4">
              <input type="hidden" name="_action" value="delete-theme" />
              <div>
                <label for="theme_confirm_delete_id" class="block text-sm text-zinc-300">Type <code class="font-mono text-zinc-100">{themeId}</code> to confirm deletion</label>
                <input type="text" id="theme_confirm_delete_id" name="confirm_theme_id" required
                  class="mt-1 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500"
                  placeholder="theme-id" />
              </div>
              <button type="submit" class="rounded-lg bg-red-950/40 border border-red-800/60 px-5 py-2.5 text-sm text-red-400 hover:bg-red-950/60 hover:text-red-300 transition-colors">Delete Theme</button>
            </form>
          </div>
        </div>
      )}

    </div>
  </section>
</BaseLayout>
