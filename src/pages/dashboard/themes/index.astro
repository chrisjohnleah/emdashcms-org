---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EmptyState from '../../../components/EmptyState.astro';
import { resolveAuthorId } from '../../../lib/publishing/plugin-queries';
import { getThemesByAuthor } from '../../../lib/publishing/theme-queries';

const author = Astro.locals.author!;
const authorId = await resolveAuthorId(env.DB, author.githubId);

let themes: Awaited<ReturnType<typeof getThemesByAuthor>> = [];
if (authorId) {
  themes = await getThemesByAuthor(env.DB, authorId);
}

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'short', year: 'numeric',
  });
---
<BaseLayout title="Your Themes - Dashboard - emdashcms.org">
  <section class="pt-24 pb-16 px-6">
    <div class="mx-auto max-w-5xl">

      <a href="/dashboard" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors">&larr; Back to Dashboard</a>

      <div class="flex items-center justify-between mb-8 mt-4">
        <h1 class="text-3xl font-semibold tracking-tight leading-[1.15] text-zinc-100">Your Themes</h1>
        <a href="/dashboard/themes/new" class="inline-flex items-center rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors">Register Theme</a>
      </div>

      {themes.length === 0 ? (
        <EmptyState
          heading="You haven't listed any themes yet"
          body="List your first theme to share it with the EmDash community."
          linkHref="/dashboard/themes/new"
          linkText="List Your First Theme"
        />
      ) : (
        <div class="rounded-xl border border-zinc-800/60 bg-zinc-900/40 overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-zinc-800 text-left">
                <th class="pb-3 pl-6 pr-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide" scope="col">Theme</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide" scope="col">Keywords</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide" scope="col">License</th>
                <th class="pb-3 pl-4 pr-6 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide" scope="col">Updated</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-800/60">
              {themes.map(theme => (
                <tr class="hover:bg-zinc-900/30 transition-colors">
                  <th scope="row" class="py-3 pl-6 pr-4">
                    <a href={'/dashboard/themes/' + theme.id} class="text-zinc-100 font-medium hover:text-white hover:underline transition-colors">{theme.name}</a>
                  </th>
                  <td class="py-3 px-4 text-zinc-400">{theme.keywords.join(', ')}</td>
                  <td class="py-3 px-4 text-zinc-500">{theme.license ?? '\u2014'}</td>
                  <td class="py-3 pl-4 pr-6 text-zinc-500">{formatDate(theme.updatedAt)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

    </div>
  </section>
</BaseLayout>
