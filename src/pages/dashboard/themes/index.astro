---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import EmptyState from '../../../components/EmptyState.astro';
import { resolveAuthorId } from '../../../lib/publishing/plugin-queries';
import { getThemesByAuthor } from '../../../lib/publishing/theme-queries';

const author = Astro.locals.author!;
const authorId = await resolveAuthorId(env.DB, author.githubId);

let themes: Awaited<ReturnType<typeof getThemesByAuthor>> = [];
if (authorId) {
  themes = await getThemesByAuthor(env.DB, authorId);
}

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'short', year: 'numeric',
  });
---
<BaseLayout title="Your Themes - Dashboard - emdashcms.org">
  <section class="page pt-12 pb-16 md:pt-16">

      <a href="/dashboard" class="text-sm text-ink-muted hover:text-ink transition-colors">&larr; Back to Dashboard</a>

      <div class="flex items-center justify-between mb-8 mt-4">
        <h1 class="text-3xl text-ink">Your Themes</h1>
        <Button href="/dashboard/themes/new" variant="primary">Register Theme</Button>
      </div>

      {themes.length === 0 ? (
        <EmptyState
          heading="You haven't listed any themes yet"
          body="List your first theme to share it with the EmDash community."
          linkHref="/dashboard/themes/new"
          linkText="List Your First Theme"
        />
      ) : (
        <div class="rounded-xl border border-rule bg-paper-soft overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-rule text-left">
                <th class="pb-3 pl-6 pr-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide" scope="col">Theme</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide" scope="col">Keywords</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide" scope="col">License</th>
                <th class="pb-3 pl-4 pr-6 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide" scope="col">Updated</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-rule">
              {themes.map(theme => (
                <tr class="hover:bg-paper-sunk transition-colors">
                  <th scope="row" class="py-3 pl-6 pr-4">
                    <a href={'/dashboard/themes/' + theme.id} class="text-ink font-medium hover:underline transition-colors">{theme.name}</a>
                  </th>
                  <td class="py-3 px-4 text-ink-muted">{theme.keywords.join(', ')}</td>
                  <td class="py-3 px-4 text-ink-soft">{theme.license ?? '\u2014'}</td>
                  <td class="py-3 pl-4 pr-6 text-ink-soft">{formatDate(theme.updatedAt)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

  </section>
</BaseLayout>
