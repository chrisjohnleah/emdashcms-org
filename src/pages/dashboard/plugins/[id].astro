---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import StatusBadge from '../../../components/StatusBadge.astro';
import AuditBadge from '../../../components/AuditBadge.astro';
import SourceBadge from '../../../components/SourceBadge.astro';
import DashboardBanner from '../../../components/DashboardBanner.astro';
import RoleBadge from '../../../components/RoleBadge.astro';
import { getPluginDetail, getPluginVersions } from '../../../lib/db/queries';
import {
  getCollaborators,
  createInvite,
  removeCollaborator,
  updateCollaboratorRole,
  transferOwnership,
  deletePlugin,
  getPendingInvitesForPlugin,
} from '../../../lib/auth/collaborator-queries';
import { resolveAuthorId, updatePluginMetadata } from '../../../lib/publishing/plugin-queries';
import { checkPluginAccess, hasRole, type Role } from '../../../lib/auth/permissions';
import {
  validateUrlFields,
  validateStringLengths,
  validateKeywords,
  validateCategory,
} from '../../../lib/api/validation';
import {
  getPluginGitHubLink,
  getInstallationByAuthor,
  linkPluginToRepo,
  toggleAutoSubmit,
  unlinkPlugin,
  setTagPattern,
} from '../../../lib/github/queries';
import {
  getInstallationToken,
  listInstallationRepos,
  type GitHubRepo,
} from '../../../lib/github/installation';
import type { MarketplaceVersionSummary } from '../../../types/marketplace';

const { id: pluginId } = Astro.params;
const author = Astro.locals.author!;

// RBAC check — any collaborator role can view (D-06, D-10)
const authorId = await resolveAuthorId(env.DB, author.githubId);
if (!authorId) return Astro.redirect('/dashboard');

const access = await checkPluginAccess(env.DB, authorId, pluginId!);
if (!access.found || !access.role) return Astro.redirect('/dashboard');
const userRole = access.role as Role;
const isOwner = userRole === 'owner';
const isMaintainer = hasRole(userRole, 'maintainer');

// Handle metadata edit POST (D-16)
let saveSuccess = false;
let saveError = '';
let githubSuccess = '';
let githubError = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = data.get('_action') as string;

    if (action === 'metadata') {
      if (!isMaintainer) throw new Error('Maintainer role required to edit metadata');

      const metadata: Record<string, unknown> = {
        shortDescription: (data.get('shortDescription') as string) || undefined,
        description: (data.get('description') as string) ?? undefined,
        category: (data.get('category') as string) || undefined,
        repositoryUrl: (data.get('repositoryUrl') as string) || undefined,
        homepageUrl: (data.get('homepageUrl') as string) || undefined,
        supportUrl: (data.get('supportUrl') as string) || undefined,
        fundingUrl: (data.get('fundingUrl') as string) || undefined,
        license: (data.get('license') as string) || undefined,
      };
      const keywordsArray = (data.get('keywords') as string ?? '')
        .split(',').map((k: string) => k.trim()).filter(Boolean);

      // Same validation the API route applies (D-16, security audit fix)
      const badUrl = validateUrlFields(metadata, [
        'repositoryUrl', 'homepageUrl', 'supportUrl', 'fundingUrl',
      ]);
      if (badUrl) throw new Error(`${badUrl} must be a valid http/https URL`);

      const lenErr = validateStringLengths(metadata);
      if (lenErr) throw new Error(lenErr);

      const kwErr = validateKeywords(keywordsArray);
      if (kwErr) throw new Error(kwErr);

      if (metadata.category) {
        const catErr = validateCategory(metadata.category as string);
        if (catErr) throw new Error(catErr);
      }

      await updatePluginMetadata(env.DB, pluginId!, {
        ...metadata,
        keywords: keywordsArray,
      } as Parameters<typeof updatePluginMetadata>[2]);
      saveSuccess = true;
    } else if (action === 'connect-repo') {
      if (!isMaintainer) throw new Error('Maintainer role required');
      const repoFullName = data.get('repo_full_name') as string;
      const repoId = Number(data.get('repo_id'));
      if (!repoFullName || !repoId) throw new Error('Select a repository');
      const installation = await getInstallationByAuthor(env.DB, authorId);
      if (!installation) throw new Error('No GitHub App installation found');
      await linkPluginToRepo(env.DB, {
        pluginId: pluginId!,
        installationId: installation.id,
        repoFullName,
        repoId,
      });
      githubSuccess = 'GitHub repository connected.';
    } else if (action === 'toggle-auto-submit') {
      if (!isMaintainer) throw new Error('Maintainer role required');
      const link = await getPluginGitHubLink(env.DB, pluginId!);
      if (link) {
        await toggleAutoSubmit(env.DB, pluginId!, !link.autoSubmit);
        githubSuccess = 'Auto-submit setting updated.';
      }
    } else if (action === 'update-tag-pattern') {
      if (!isMaintainer) throw new Error('Maintainer role required');
      const pattern = (data.get('tag_pattern') as string ?? '').trim();
      if (!pattern) throw new Error('Tag pattern cannot be empty');
      // Bound length and restrict to safe glob characters to prevent ReDoS
      // when matchesTagPattern compiles the pattern into a regex.
      if (pattern.length > 100) throw new Error('Tag pattern must be 100 characters or less');
      if (!/^[a-zA-Z0-9.*_\-]+$/.test(pattern)) {
        throw new Error('Tag pattern can only contain letters, numbers, dots, asterisks, underscores, and hyphens');
      }
      await setTagPattern(env.DB, pluginId!, pattern);
      githubSuccess = 'Tag pattern updated.';
    } else if (action === 'disconnect') {
      if (!isOwner) throw new Error('Only the owner can disconnect GitHub');
      await unlinkPlugin(env.DB, pluginId!);
      githubSuccess = 'GitHub repository disconnected.';
    } else if (action === 'invite' && isOwner) {
      const username = (data.get('github_username') as string ?? '').trim();
      const role = data.get('role') as string;
      if (!username) throw new Error('GitHub username is required');
      if (role !== 'maintainer' && role !== 'contributor') throw new Error('Invalid role');
      await createInvite(env.DB, {
        pluginId: pluginId!,
        invitedGithubUsername: username,
        role: role as 'maintainer' | 'contributor',
        invitedBy: authorId,
        inviterGithubUsername: author.username,
      });
      saveSuccess = true;
    } else if (action === 'change-role' && isOwner) {
      const collabAuthorId = data.get('collaborator_author_id') as string;
      const newRole = data.get('new_role') as string;
      if (newRole !== 'maintainer' && newRole !== 'contributor') throw new Error('Invalid role');
      await updateCollaboratorRole(env.DB, pluginId!, collabAuthorId, newRole as 'maintainer' | 'contributor');
      saveSuccess = true;
    } else if (action === 'remove-collaborator' && isOwner) {
      const collabAuthorId = data.get('collaborator_author_id') as string;
      await removeCollaborator(env.DB, pluginId!, collabAuthorId);
      saveSuccess = true;
    } else if (action === 'transfer-ownership' && isOwner) {
      const confirmId = (data.get('confirm_plugin_id') as string ?? '').trim();
      const newOwnerAuthorId = data.get('new_owner_author_id') as string;
      if (confirmId !== pluginId) throw new Error('Plugin ID does not match. Transfer cancelled.');
      await transferOwnership(env.DB, pluginId!, authorId, newOwnerAuthorId, 'plugin');
      return Astro.redirect('/dashboard');
    } else if (action === 'delete-plugin' && isOwner) {
      const confirmId = (data.get('confirm_plugin_id') as string ?? '').trim();
      if (confirmId !== pluginId) throw new Error('Plugin ID does not match. Deletion cancelled.');
      await deletePlugin(env.DB, env.ARTIFACTS, pluginId!);
      return Astro.redirect('/dashboard');
    }
  } catch (e) {
    const msg = e instanceof Error ? e.message : 'An error occurred';
    if (!githubSuccess) {
      githubError = msg;
    }
    if (!githubError && !saveSuccess) {
      saveError = msg;
    }
  }
}

// Check URL params for upload success banner (D-11)
const uploaded = Astro.url.searchParams.get('uploaded') === 'true';

// Load plugin data (re-fetch after potential update)
const plugin = await getPluginDetail(env.DB, pluginId!);
if (!plugin) return Astro.redirect('/dashboard');

const versions: MarketplaceVersionSummary[] = await getPluginVersions(env.DB, pluginId!);

// Team data
const collaborators = await getCollaborators(env.DB, pluginId!);
const pendingPluginInvites = await getPendingInvitesForPlugin(env.DB, pluginId!);

// GitHub integration state
const githubLink = await getPluginGitHubLink(env.DB, pluginId!);
const installation = await getInstallationByAuthor(env.DB, authorId);

let availableRepos: GitHubRepo[] = [];
if (installation && !githubLink) {
  try {
    const token = await getInstallationToken(
      installation.id,
      env.GITHUB_CLIENT_ID,
      env.GITHUB_APP_PRIVATE_KEY,
    );
    availableRepos = await listInstallationRepos(token);
  } catch (err) {
    console.error('[dashboard] Failed to list repos:', err);
  }
}

// Fetch version sources for SourceBadge
const versionSources = await env.DB.prepare(
  'SELECT version, source FROM plugin_versions WHERE plugin_id = ?'
).bind(pluginId).all<{ version: string; source: string }>();
const sourceMap = new Map(versionSources.results.map(r => [r.version, r.source ?? 'upload']));

// Fetch raw plugin row for editable fields not on MarketplacePluginDetail
const rawPlugin = await env.DB.prepare(
  'SELECT short_description, description, keywords, category, repository_url, homepage_url, support_url, funding_url, license FROM plugins WHERE id = ?'
).bind(pluginId).first<{
  short_description: string | null;
  description: string | null;
  keywords: string | null;
  category: string | null;
  repository_url: string | null;
  homepage_url: string | null;
  support_url: string | null;
  funding_url: string | null;
  license: string | null;
}>();

const parsedKeywords = (() => {
  try {
    return JSON.parse(rawPlugin?.keywords || '[]').join(', ');
  } catch {
    return '';
  }
})();

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'short', year: 'numeric',
  });
---
<BaseLayout title={plugin.name + ' - Dashboard - emdashcms.org'}>
  <section class="pt-24 pb-16 px-6">
    <div class="mx-auto max-w-5xl">

      <a href="/dashboard" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors">&larr; Back to Dashboard</a>

      <h1 class="mt-4 text-3xl font-semibold tracking-tight leading-[1.15] text-zinc-100">{plugin.name}</h1>

      {uploaded && (
        <div class="mt-6">
          <DashboardBanner type="success" message="Version uploaded successfully. Audit is in progress." />
        </div>
      )}
      {saveSuccess && (
        <div class="mt-6">
          <DashboardBanner type="success" message="Plugin details updated." />
        </div>
      )}
      {saveError && (
        <div class="mt-6">
          <DashboardBanner type="error" message={'Failed to update plugin details. ' + saveError} />
        </div>
      )}

      <!-- Section 1: Plugin Details -->
      <div class="mt-8">
        <h2 class="text-xl font-semibold text-zinc-100">Plugin Details</h2>
        {isMaintainer ? (
          <form method="POST" class="mt-4 rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6 space-y-4">
            <input type="hidden" name="_action" value="metadata" />

            <div>
              <dt class="text-sm font-semibold text-zinc-100">Plugin ID</dt>
              <dd class="mt-1 text-sm text-zinc-400 font-mono">{plugin.id}</dd>
            </div>

            <div>
              <dt class="text-sm font-semibold text-zinc-100">Name</dt>
              <dd class="mt-1 text-sm text-zinc-400">{plugin.name}</dd>
            </div>

            {!rawPlugin?.short_description && (
              <div class="rounded-lg border border-amber-800/40 bg-amber-950/20 px-4 py-3">
                <p class="text-sm text-amber-400">Add a short description to improve your listing in search results and cards.</p>
              </div>
            )}

            <div>
              <label for="shortDescription" class="block text-sm font-semibold text-zinc-100">Short Description</label>
              <p class="mt-1 text-xs text-zinc-500">A one-line tagline shown in search results and cards (150 chars max)</p>
              <input type="text" id="shortDescription" name="shortDescription" value={rawPlugin?.short_description ?? ''}
                maxlength="150"
                class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500" />
            </div>

            <div>
              <label for="description" class="block text-sm font-semibold text-zinc-100">Description</label>
              <textarea id="description" name="description"
                class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm min-h-[80px] resize-y focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500"
              >{rawPlugin?.description ?? ''}</textarea>
            </div>

            <div>
              <label for="category" class="block text-sm font-semibold text-zinc-100">Category</label>
              <select id="category" name="category"
                class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500">
                <option value="">None</option>
                <option value="content" selected={rawPlugin?.category === 'content'}>Content</option>
                <option value="media" selected={rawPlugin?.category === 'media'}>Media</option>
                <option value="seo" selected={rawPlugin?.category === 'seo'}>SEO</option>
                <option value="analytics" selected={rawPlugin?.category === 'analytics'}>Analytics</option>
                <option value="security" selected={rawPlugin?.category === 'security'}>Security</option>
                <option value="performance" selected={rawPlugin?.category === 'performance'}>Performance</option>
                <option value="integration" selected={rawPlugin?.category === 'integration'}>Integration</option>
                <option value="workflow" selected={rawPlugin?.category === 'workflow'}>Workflow</option>
                <option value="developer-tools" selected={rawPlugin?.category === 'developer-tools'}>Developer tools</option>
                <option value="ui" selected={rawPlugin?.category === 'ui'}>UI</option>
              </select>
            </div>

            <div>
              <label for="repositoryUrl" class="block text-sm font-semibold text-zinc-100">Repository URL</label>
              <input type="url" id="repositoryUrl" name="repositoryUrl" value={rawPlugin?.repository_url ?? ''}
                class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500" />
            </div>

            <div>
              <label for="homepageUrl" class="block text-sm font-semibold text-zinc-100">Homepage URL</label>
              <input type="url" id="homepageUrl" name="homepageUrl" value={rawPlugin?.homepage_url ?? ''}
                class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500" />
            </div>

            <div>
              <label for="supportUrl" class="block text-sm font-semibold text-zinc-100">Support URL</label>
              <input type="url" id="supportUrl" name="supportUrl" value={rawPlugin?.support_url ?? ''}
                class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500" />
            </div>

            <div>
              <label for="fundingUrl" class="block text-sm font-semibold text-zinc-100">Funding URL</label>
              <input type="url" id="fundingUrl" name="fundingUrl" value={rawPlugin?.funding_url ?? ''}
                class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500" />
            </div>

            <div>
              <label for="keywords" class="block text-sm font-semibold text-zinc-100">Keywords</label>
              <p class="mt-1 text-xs text-zinc-500">Comma-separated (e.g. markdown, editor, syntax)</p>
              <input type="text" id="keywords" name="keywords" value={parsedKeywords}
                class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500" />
            </div>

            <div>
              <label for="license" class="block text-sm font-semibold text-zinc-100">License</label>
              <input type="text" id="license" name="license" value={rawPlugin?.license ?? ''}
                class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500" />
            </div>

            <button type="submit" class="rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors">Save Plugin Details</button>

          </form>
        ) : (
          <div class="mt-4 rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6 space-y-4">
            <div>
              <dt class="text-sm font-semibold text-zinc-100">Plugin ID</dt>
              <dd class="mt-1 text-sm text-zinc-400 font-mono">{plugin.id}</dd>
            </div>
            <div>
              <dt class="text-sm font-semibold text-zinc-100">Name</dt>
              <dd class="mt-1 text-sm text-zinc-400">{plugin.name}</dd>
            </div>
            <div>
              <dt class="text-sm font-semibold text-zinc-100">Description</dt>
              <dd class="mt-1 text-sm text-zinc-400">{rawPlugin?.description ?? 'No description'}</dd>
            </div>
            <div>
              <dt class="text-sm font-semibold text-zinc-100">Keywords</dt>
              <dd class="mt-1 text-sm text-zinc-400">{parsedKeywords || 'None'}</dd>
            </div>
            <div>
              <dt class="text-sm font-semibold text-zinc-100">License</dt>
              <dd class="mt-1 text-sm text-zinc-400">{rawPlugin?.license ?? 'Not specified'}</dd>
            </div>
          </div>
        )}
      </div>

      {githubSuccess && (
        <div class="mt-6">
          <DashboardBanner type="success" message={githubSuccess} />
        </div>
      )}
      {githubError && (
        <div class="mt-6">
          <DashboardBanner type="error" message={githubError} />
        </div>
      )}

      <div class="mt-12">
        <h2 class="text-xl font-semibold text-zinc-100">GitHub</h2>
        <div class="mt-4 rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6">
          {githubLink ? (
            <div class="space-y-4">
              <div>
                <span class="text-sm text-zinc-100 font-mono">{githubLink.repoFullName}</span>
                <span class="ml-3 text-sm text-emerald-400">Connected</span>
              </div>
              {isMaintainer && (
                <div class="flex items-center gap-3">
                  <form method="POST">
                    <input type="hidden" name="_action" value="toggle-auto-submit" />
                    <button type="submit" class="rounded-lg bg-zinc-900 border border-zinc-800 px-4 py-2 text-sm text-zinc-300 hover:bg-zinc-800 hover:text-zinc-100 transition-colors">
                      {githubLink.autoSubmit ? 'Pause auto-submit' : 'Enable auto-submit'}
                    </button>
                  </form>
                  <span class:list={['text-sm', githubLink.autoSubmit ? 'text-emerald-400' : 'text-amber-400']}>
                    {githubLink.autoSubmit ? 'Auto-submit on release' : 'Auto-submit paused'}
                  </span>
                </div>
              )}
              {!isMaintainer && (
                <div class="flex items-center gap-3">
                  <span class:list={['text-sm', githubLink.autoSubmit ? 'text-emerald-400' : 'text-amber-400']}>
                    {githubLink.autoSubmit ? 'Auto-submit on release' : 'Auto-submit paused'}
                  </span>
                </div>
              )}
              {isMaintainer && (
                <form method="POST" class="flex items-end gap-3">
                  <input type="hidden" name="_action" value="update-tag-pattern" />
                  <div class="flex-1">
                    <label for="tag_pattern" class="block text-sm font-semibold text-zinc-100">Tag pattern</label>
                    <p class="mt-1 text-xs text-zinc-500">Glob pattern for release tags (e.g. v*, release-*, *). Only matching tags trigger auto-submit.</p>
                    <input type="text" id="tag_pattern" name="tag_pattern" value={githubLink.tagPattern}
                      class="mt-2 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500"
                      placeholder="*" />
                  </div>
                  <button type="submit" class="rounded-lg bg-zinc-900 border border-zinc-800 px-4 py-2.5 text-sm text-zinc-300 hover:bg-zinc-800 hover:text-zinc-100 transition-colors">
                    Save pattern
                  </button>
                </form>
              )}
              {!isMaintainer && (
                <div>
                  <dt class="text-sm font-semibold text-zinc-100">Tag pattern</dt>
                  <dd class="mt-1 text-sm text-zinc-400 font-mono">{githubLink.tagPattern}</dd>
                </div>
              )}
              {isOwner && (
                <div class="flex justify-end">
                  <form method="POST">
                    <input type="hidden" name="_action" value="disconnect" />
                    <button type="submit" class="rounded-lg bg-red-950/40 border border-red-800/60 px-4 py-2 text-sm text-red-400 hover:bg-red-950/60 hover:text-red-300 transition-colors">
                      Disconnect {githubLink.repoFullName}
                    </button>
                  </form>
                </div>
              )}
            </div>
          ) : isMaintainer && installation ? (
            <form method="POST" class="space-y-4">
              <input type="hidden" name="_action" value="connect-repo" />
              <input type="hidden" name="repo_id" id="repo_id" value="" />
              <div>
                <label for="repo_select" class="block text-sm font-semibold text-zinc-100">Select repository</label>
                {availableRepos.length === 0 ? (
                  <p class="mt-2 text-sm text-zinc-500">No accessible repositories found. Install the GitHub App on your repos first.</p>
                ) : (
                  <div class="mt-2 flex items-end gap-3">
                    <select id="repo_select" name="repo_full_name"
                      class="flex-1 bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500">
                      <option value="">Choose a repository...</option>
                      {availableRepos.map(repo => (
                        <option value={repo.full_name} data-repo-id={repo.id}>{repo.full_name}</option>
                      ))}
                    </select>
                    <button type="submit" class="rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors">Connect</button>
                  </div>
                )}
              </div>
              <script>
document.getElementById('repo_select')?.addEventListener('change', function (this: HTMLSelectElement) {
  const selected = this.options[this.selectedIndex];
  const repoIdInput = document.getElementById('repo_id') as HTMLInputElement | null;
  if (repoIdInput) {
    repoIdInput.value = selected.getAttribute('data-repo-id') || '';
  }
});
</script>
            </form>
          ) : isMaintainer ? (
            <div>
              <p class="text-sm text-zinc-400">No GitHub repository connected.</p>
              <p class="mt-1 text-sm text-zinc-500">Connect a repo to automatically submit new versions when you publish a release.</p>
              <div class="mt-4">
                <a href={`https://github.com/apps/emdashcms/installations/new?state=${pluginId}`}
                  class="inline-flex items-center rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors">
                  Connect GitHub Repo
                </a>
              </div>
            </div>
          ) : (
            <div>
              <p class="text-sm text-zinc-400">No GitHub repository connected.</p>
            </div>
          )}
        </div>
      </div>

      <!-- Section 2: Versions -->
      <div class="mt-12">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold text-zinc-100">Versions</h2>
          {isMaintainer && (
            <a href={'/dashboard/plugins/' + encodeURIComponent(pluginId!) + '/upload'} class="inline-flex items-center rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors">Upload Version</a>
          )}
        </div>

        {versions.length === 0 ? (
          <p class="mt-4 text-sm text-zinc-400">No versions uploaded yet.</p>
        ) : (
          <div class="mt-4 rounded-xl border border-zinc-800/60 bg-zinc-900/40 overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-zinc-800 text-left">
                  <th class="pb-3 pl-6 pr-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide" scope="col">Version</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide" scope="col">Status</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide" scope="col">Audit</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide" scope="col">Source</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide" scope="col">Uploaded</th>
                  <th class="pb-3 pl-4 pr-6 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide" scope="col">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-zinc-800/60">
                {versions.map(v => (
                  <tr class="hover:bg-zinc-900/30 transition-colors">
                    <td class="py-3 pl-6 pr-4 font-mono text-zinc-100">{v.version}</td>
                    <td class="py-3 px-4"><StatusBadge status={v.status} /></td>
                    <td class="py-3 px-4"><AuditBadge verdict={v.auditVerdict} /></td>
                    <td class="py-3 px-4"><SourceBadge source={(sourceMap.get(v.version) ?? 'upload') as 'github' | 'upload'} /></td>
                    <td class="py-3 px-4 text-zinc-500">{formatDate(v.publishedAt)}</td>
                    <td class="py-3 pl-4 pr-6">
                      <a href={'/dashboard/plugins/' + encodeURIComponent(pluginId!) + '/versions/' + v.version} class="text-zinc-400 hover:text-zinc-100 transition-colors text-sm">View Audit</a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

      <!-- Section: Team -->
      <div class="mt-12">
        <h2 class="text-xl font-semibold text-zinc-100">Team</h2>
        <div class="mt-4 rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6">

          <div class="space-y-3">
            {collaborators.map(collab => (
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span class="text-sm text-zinc-100">{collab.githubUsername}</span>
                  <RoleBadge role={collab.role} />
                </div>
                {isOwner && collab.role !== 'owner' && (
                  <div class="flex items-center gap-2">
                    <form method="POST" class="flex items-center gap-2">
                      <input type="hidden" name="_action" value="change-role" />
                      <input type="hidden" name="collaborator_author_id" value={collab.authorId} />
                      <select name="new_role"
                        class="bg-zinc-900 border border-zinc-800 text-zinc-300 rounded-lg px-2 py-1 text-sm focus:border-zinc-500 focus:outline-none">
                        <option value="maintainer" selected={collab.role === 'maintainer'}>Maintainer</option>
                        <option value="contributor" selected={collab.role === 'contributor'}>Contributor</option>
                      </select>
                      <button type="submit" class="rounded-lg bg-zinc-900 border border-zinc-800 px-3 py-1 text-sm text-zinc-300 hover:bg-zinc-800 transition-colors">Update</button>
                    </form>
                    <form method="POST">
                      <input type="hidden" name="_action" value="remove-collaborator" />
                      <input type="hidden" name="collaborator_author_id" value={collab.authorId} />
                      <button type="submit" class="rounded-lg bg-red-950/40 border border-red-800/60 px-3 py-1 text-sm text-red-400 hover:bg-red-950/60 transition-colors">Remove</button>
                    </form>
                  </div>
                )}
              </div>
            ))}
          </div>

          {pendingPluginInvites.length > 0 && (
            <div class="mt-4 pt-4 border-t border-zinc-800/60">
              <h3 class="text-sm font-semibold text-zinc-400 uppercase tracking-wide mb-3">Pending Invitations</h3>
              {pendingPluginInvites.map(invite => (
                <div class="flex items-center justify-between py-2">
                  <div class="flex items-center gap-3">
                    <span class="text-sm text-zinc-300">{invite.invitedGithubUsername}</span>
                    <RoleBadge role={invite.role as 'owner' | 'maintainer' | 'contributor'} />
                    <span class="text-xs text-zinc-500">Pending</span>
                  </div>
                </div>
              ))}
            </div>
          )}

          {isOwner && (
            <div class="mt-4 pt-4 border-t border-zinc-800/60">
              <h3 class="text-sm font-semibold text-zinc-400 uppercase tracking-wide mb-3">Invite Collaborator</h3>
              <form method="POST" class="flex items-end gap-3">
                <input type="hidden" name="_action" value="invite" />
                <div class="flex-1">
                  <label for="github_username" class="block text-sm text-zinc-300">GitHub Username</label>
                  <input type="text" id="github_username" name="github_username" required
                    class="mt-1 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500"
                    placeholder="username" />
                </div>
                <div>
                  <label for="invite_role" class="block text-sm text-zinc-300">Role</label>
                  <select id="invite_role" name="role"
                    class="mt-1 bg-zinc-900 border border-zinc-800 text-zinc-300 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none">
                    <option value="maintainer">Maintainer</option>
                    <option value="contributor">Contributor</option>
                  </select>
                </div>
                <button type="submit" class="rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors">Invite</button>
              </form>
            </div>
          )}
        </div>
      </div>

      {isOwner && collaborators.filter(c => c.role !== 'owner').length > 0 && (
        <div class="mt-12">
          <h2 class="text-xl font-semibold text-zinc-100">Transfer Ownership</h2>
          <div class="mt-4 rounded-xl border border-red-900/30 bg-zinc-900/40 p-6">
            <p class="text-sm text-zinc-400 mb-4">Transfer ownership to a collaborator. You will be downgraded to Maintainer.</p>
            <form method="POST" class="space-y-4">
              <input type="hidden" name="_action" value="transfer-ownership" />
              <div>
                <label for="new_owner" class="block text-sm text-zinc-300">New Owner</label>
                <select id="new_owner" name="new_owner_author_id"
                  class="mt-1 bg-zinc-900 border border-zinc-800 text-zinc-300 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none">
                  {collaborators.filter(c => c.role !== 'owner').map(c => (
                    <option value={c.authorId}>{c.githubUsername} ({c.role})</option>
                  ))}
                </select>
              </div>
              <div>
                <label for="confirm_transfer_id" class="block text-sm text-zinc-300">Type <code class="font-mono text-zinc-100">{pluginId}</code> to confirm</label>
                <input type="text" id="confirm_transfer_id" name="confirm_plugin_id" required
                  class="mt-1 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500"
                  placeholder="plugin-id" />
              </div>
              <button type="submit" class="rounded-lg bg-red-950/40 border border-red-800/60 px-5 py-2.5 text-sm text-red-400 hover:bg-red-950/60 hover:text-red-300 transition-colors">Transfer Ownership</button>
            </form>
          </div>
        </div>
      )}

      {isOwner && (
        <div class="mt-12">
          <h2 class="text-xl font-semibold text-zinc-100">Danger Zone</h2>
          <div class="mt-4 rounded-xl border border-red-900/30 bg-zinc-900/40 p-6">
            <p class="text-sm text-zinc-400 mb-4">Permanently delete this plugin and all its versions, audit records, and collaborator access. This action cannot be undone.</p>
            <form method="POST" class="space-y-4">
              <input type="hidden" name="_action" value="delete-plugin" />
              <div>
                <label for="confirm_delete_id" class="block text-sm text-zinc-300">Type <code class="font-mono text-zinc-100">{pluginId}</code> to confirm deletion</label>
                <input type="text" id="confirm_delete_id" name="confirm_plugin_id" required
                  class="mt-1 w-full bg-zinc-900 border border-zinc-800 text-zinc-100 rounded-lg px-3 py-2 text-sm focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500"
                  placeholder="plugin-id" />
              </div>
              <button type="submit" class="rounded-lg bg-red-950/40 border border-red-800/60 px-5 py-2.5 text-sm text-red-400 hover:bg-red-950/60 hover:text-red-300 transition-colors">Delete Plugin</button>
            </form>
          </div>
        </div>
      )}

    </div>
  </section>
</BaseLayout>
