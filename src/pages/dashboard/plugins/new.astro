---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import DashboardBanner from '../../../components/DashboardBanner.astro';
import TurnstileWidget from '../../../components/TurnstileWidget.astro';
import { resolveAuthorId, registerPlugin, createVersion, checkUploadRateLimit, updatePluginIconKey, findChecksumCollision, getAuthorPluginSlugs } from '../../../lib/publishing/plugin-queries';
import { findSimilarPlugin } from '../../../lib/publishing/name-similarity';
import { validateImageUpload, storeImageInR2, MIME_TO_EXT } from '../../../lib/publishing/image-storage';
import { KNOWN_CATEGORIES } from '../../../lib/api/validation';
import { validateBundle } from '../../../lib/publishing/bundle-validator';
import { storeBundleInR2 } from '../../../lib/publishing/r2-storage';
import { enqueueAuditJob } from '../../../lib/publishing/queue';
import { checkAuthorAuditBudget, recordAuthorAuditUsage } from '../../../lib/audit/author-budget';
import { getInstallationByAuthor, linkPluginToRepo } from '../../../lib/github/queries';
import { getInstallationToken, listInstallationRepos, type GitHubRepo } from '../../../lib/github/installation';
import { verifyTurnstile } from '../../../lib/turnstile/verify';

// --- Auth gate ---
const author = Astro.locals.author;
if (!author) {
  return Astro.redirect('/api/v1/auth/github');
}

// --- GitHub App availability ---
// Capabilities are no longer collected on the form — they're declared in
// manifest.json inside the bundle and extracted on upload (see
// validateBundle → result.manifest.capabilities). The form mirrors theme
// register: marketplace listing data only.
const githubAppConfigured = Boolean(env.GITHUB_APP_ID);

// --- State ---
type WizardStep = 1 | 2;
let currentStep: WizardStep = 1;
let errors: Record<string, string> = {};
let globalError = '';
let globalErrorAction: { href: string; label: string } | null = null;
let globalSuccess = '';

// Metadata fields carried across steps
const SPDX_LICENSES = ['MIT', 'Apache-2.0', 'GPL-3.0-only', 'GPL-2.0-only', 'ISC', 'BSD-2-Clause', 'BSD-3-Clause', 'MPL-2.0', 'Unlicense'];

let formValues = {
  id: '',
  name: '',
  shortDescription: '',
  description: '',
  category: '',
  keywords: '',
  license: '',
  licenseOther: '',
  repositoryUrl: '',
  homepageUrl: '',
  supportUrl: '',
};

// Step 2 state
let githubInstalled = false;
let githubRepos: GitHubRepo[] = [];
let githubError = '';

// Step 1 soft-gate: when a near-duplicate of one of the author's
// existing plugins is detected, we stay on step 1 and ask them to
// acknowledge with a hidden field on resubmit. This is intentionally
// non-blocking — legitimate authors with similar plugin lines (e.g.
// `auth-google`, `auth-github`) can proceed by acknowledging.
let similarPluginWarning: { matchedId: string; matchedName: string; ratio: number } | null = null;
let acknowledgedSimilarId = '';

// Slugs only — same as theme register, WordPress-style. Legacy scoped
// plugins (e.g. @rankshield/emdash-security) keep working at upload time
// because the manifest schema stays permissive; new registrations don't.
const PLUGIN_ID_REGEX = /^[a-z0-9-]+$/;

// --- Helpers ---
function readMetadata(data: FormData) {
  formValues.id = (data.get('id') as string ?? '').trim();
  formValues.name = (data.get('name') as string ?? '').trim();
  formValues.shortDescription = (data.get('shortDescription') as string ?? '').trim();
  formValues.description = (data.get('description') as string ?? '').trim();
  formValues.category = (data.get('category') as string ?? '').trim();
  formValues.keywords = (data.get('keywords') as string ?? '').trim();
  const licenseSelect = (data.get('license') as string ?? '').trim();
  const licenseOtherVal = (data.get('licenseOther') as string ?? '').trim();
  formValues.license = licenseSelect === '__other__' ? licenseOtherVal : licenseSelect;
  formValues.licenseOther = licenseOtherVal;
  formValues.repositoryUrl = (data.get('repositoryUrl') as string ?? '').trim();
  formValues.homepageUrl = (data.get('homepageUrl') as string ?? '').trim();
  formValues.supportUrl = (data.get('supportUrl') as string ?? '').trim();
}

function validateMetadata(): boolean {
  errors = {};
  if (!formValues.id) errors.id = 'Plugin ID is required.';
  else if (!PLUGIN_ID_REGEX.test(formValues.id)) errors.id = 'ID must be lowercase alphanumeric with hyphens (e.g. my-plugin).';
  if (!formValues.name) errors.name = 'Name is required.';
  if (!formValues.shortDescription) errors.shortDescription = 'Short description is required.';
  else if (formValues.shortDescription.length > 150) errors.shortDescription = 'Short description must be 150 characters or less.';
  if (!formValues.description) errors.description = 'Description is required.';
  else if (formValues.description.length > 5000) errors.description = 'Description must be 5000 characters or less.';
  if (!formValues.category) errors.category = 'Category is required.';
  return Object.keys(errors).length === 0;
}

async function loadGitHubState(authorId: string) {
  if (!githubAppConfigured) return;
  try {
    const installation = await getInstallationByAuthor(env.DB, authorId);
    if (installation) {
      githubInstalled = true;
      const token = await getInstallationToken(
        installation.id,
        env.GITHUB_APP_ID,
        env.GITHUB_APP_PRIVATE_KEY,
      );
      githubRepos = await listInstallationRepos(token);
    }
  } catch (err) {
    githubError = err instanceof Error ? err.message : 'Failed to load GitHub repositories.';
  }
}

// --- POST handling ---
if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const step = (data.get('_step') as string ?? '').trim();

  // Always read metadata from form (may be hidden fields on step 2)
  readMetadata(data);
  acknowledgedSimilarId = (data.get('acknowledged_similar') as string ?? '').trim();

  if (step === '1') {
    // --- Step 1: Validate metadata ---
    if (validateMetadata()) {
      // Check ID uniqueness in D1
      const existingPlugin = await env.DB.prepare('SELECT id FROM plugins WHERE id = ?').bind(formValues.id).first();
      if (existingPlugin) {
        errors.id = 'A plugin with this ID already exists.';
        currentStep = 1;
      } else {
        // Soft-gate: warn if the proposed id/name is suspiciously
        // close to one of the author's own existing plugins. Catches
        // the lazy-rename pattern where someone whose audit failed
        // tries to slip the same project under a tweaked slug
        // instead of uploading a new version against the existing
        // plugin record. Bypassable with explicit acknowledgment.
        const authorId = await resolveAuthorId(env.DB, author.githubId);
        if (authorId) {
          const ownSlugs = await getAuthorPluginSlugs(env.DB, authorId);
          const match = findSimilarPlugin(
            { id: formValues.id, name: formValues.name },
            ownSlugs,
          );
          if (match && acknowledgedSimilarId !== match.candidate.id) {
            similarPluginWarning = {
              matchedId: match.candidate.id,
              matchedName: match.candidate.name,
              ratio: match.ratio,
            };
            currentStep = 1;
          } else {
            // Validation passed: advance to step 2
            currentStep = 2;
            await loadGitHubState(authorId);
          }
        } else {
          // No author row — let the next step surface the auth error.
          currentStep = 2;
        }
      }
    } else {
      currentStep = 1;
    }
  } else if (step === '2-upload') {
    // --- Step 2A: Upload .tgz ---
    currentStep = 2;

    // Turnstile bot check
    const tsToken = data.get('cf-turnstile-response') as string ?? '';
    const tsIp = Astro.request.headers.get('CF-Connecting-IP') ?? undefined;
    const tsResult = await verifyTurnstile(tsToken, env.TURNSTILE_SECRET_KEY, tsIp);
    if (!tsResult.success) {
      globalError = 'Challenge verification failed. Please try again.';
    }

    const authorId = !globalError ? await resolveAuthorId(env.DB, author.githubId) : null;
    if (globalError) {
      // Turnstile failed — skip everything
    } else if (!authorId) {
      globalError = 'Author not found. Please log out and log in again.';
    } else {
      const file = data.get('bundle') as File | null;
      if (!file || file.size === 0) {
        globalError = 'Please select a .tgz bundle file.';
        await loadGitHubState(authorId);
      } else {
        // Rate limit check
        const rateCheck = await checkUploadRateLimit(env.DB, authorId);
        if (!rateCheck.allowed) {
          globalError = `Daily upload limit reached. Try again after ${rateCheck.retryAfter ?? 'midnight UTC'}.`;
          await loadGitHubState(authorId);
        } else {
          const tarballBytes = await file.arrayBuffer();

          try {
            // Validate the bundle FIRST so we can derive capabilities from
            // the manifest before touching D1. No rollback path needed.
            const result = await validateBundle(tarballBytes, formValues.id);
            const collision = result.checksum
              ? await findChecksumCollision(env.DB, result.checksum, authorId)
              : null;
            if (!result.valid) {
              globalError = 'Bundle validation failed: ' + (result.errors?.join('; ') ?? 'Unknown error');
              await loadGitHubState(authorId);
            } else if (collision) {
              // Cross-plugin content dedup. The bundle bytes already exist
              // under another plugin slug. Same-author collisions get a
              // friendly redirect to the upload page so they end up adding
              // a new version on the canonical plugin instead of forking
              // the slug. Different-author collisions get a generic
              // message — we don't reveal which plugin they collided with.
              if (collision.ownedBySameAuthor) {
                globalError = `This bundle is byte-identical to your existing plugin "${collision.pluginName}". Upload it as a new version on that plugin instead — the audit will re-run automatically.`;
                globalErrorAction = {
                  href: `/dashboard/plugins/${encodeURIComponent(collision.pluginId)}/upload`,
                  label: `Upload new version of ${collision.pluginName}`,
                };
              } else {
                globalError = 'This exact bundle has already been registered under another plugin. If you believe this is a mistake, contact support.';
              }
              await loadGitHubState(authorId);
            } else {
              const keywordsArray = formValues.keywords
                ? formValues.keywords.split(',').map((k: string) => k.trim()).filter(Boolean)
                : [];

              await registerPlugin(env.DB, authorId, {
                id: formValues.id,
                name: formValues.name,
                short_description: formValues.shortDescription || undefined,
                description: formValues.description,
                // Capabilities come from the validated manifest, not the form.
                capabilities: result.manifest!.capabilities,
                keywords: keywordsArray,
                license: formValues.license || undefined,
                category: formValues.category || undefined,
                repository_url: formValues.repositoryUrl || undefined,
                homepage_url: formValues.homepageUrl || undefined,
                support_url: formValues.supportUrl || undefined,
              });

              // Store in R2
              const { key: bundleKey } = await storeBundleInR2(
                env.ARTIFACTS,
                formValues.id,
                result.manifest!.version,
                tarballBytes,
                result.checksum!,
              );

              // Create version record
              await createVersion(env.DB, {
                pluginId: formValues.id,
                version: result.manifest!.version,
                manifest: JSON.stringify(result.manifest),
                bundleKey,
                checksum: result.checksum!,
                fileCount: result.stats!.fileCount,
                compressedSize: result.stats!.compressedSize,
                decompressedSize: result.stats!.decompressedSize,
                source: 'upload',
              });

              // Author audit budget is only meaningful in auto mode, but we
              // keep the spam-protection check on every upload regardless.
              const budget = await checkAuthorAuditBudget(env.DB, authorId);
              if (!budget.allowed) throw new Error('Daily upload limit reached (10/day). Try again tomorrow.');

              await enqueueAuditJob(env.AUDIT_QUEUE, {
                pluginId: formValues.id,
                version: result.manifest!.version,
                authorId,
                bundleKey,
              });
              await recordAuthorAuditUsage(env.DB, authorId);

              return Astro.redirect('/dashboard/plugins/' + encodeURIComponent(formValues.id) + '?uploaded=true');
            }
          } catch (err) {
            const msg = err instanceof Error ? err.message : String(err);
            if (msg.includes('UNIQUE')) {
              errors.id = 'A plugin with this ID already exists.';
              currentStep = 1;
            } else {
              // Best-effort cleanup in case registerPlugin landed before the throw
              try {
                await env.DB.prepare('DELETE FROM plugins WHERE id = ?').bind(formValues.id).run();
              } catch {
                // Best-effort cleanup
              }
              globalError = 'Failed to register plugin: ' + msg;
              await loadGitHubState(authorId);
            }
          }
        }
      }
    }
  } else if (step === '2-github') {
    // --- Step 2B: Connect GitHub ---
    currentStep = 2;

    const authorId = await resolveAuthorId(env.DB, author.githubId);
    if (!authorId) {
      globalError = 'Author not found. Please log out and log in again.';
    } else {
      const repoFullName = (data.get('repoFullName') as string ?? '').trim();
      const repoId = parseInt(data.get('repoId') as string ?? '0', 10);

      if (!repoFullName || !repoId) {
        globalError = 'Please select a repository.';
        await loadGitHubState(authorId);
      } else {
        try {
          // Verify installation exists
          const installation = await getInstallationByAuthor(env.DB, authorId);
          if (!installation) {
            globalError = 'GitHub App installation not found. Please install the app first.';
            await loadGitHubState(authorId);
          } else {
            const keywordsArray = formValues.keywords
              ? formValues.keywords.split(',').map((k: string) => k.trim()).filter(Boolean)
              : [];

            // Register plugin. Capabilities start empty; the audit worker
            // will populate them when the first version bundle arrives.
            await registerPlugin(env.DB, authorId, {
              id: formValues.id,
              name: formValues.name,
              short_description: formValues.shortDescription || undefined,
              description: formValues.description,
              capabilities: [],
              keywords: keywordsArray,
              license: formValues.license || undefined,
              category: formValues.category || undefined,
              repository_url: formValues.repositoryUrl || undefined,
              homepage_url: formValues.homepageUrl || undefined,
              support_url: formValues.supportUrl || undefined,
            });

            // Link to repo
            await linkPluginToRepo(env.DB, {
              pluginId: formValues.id,
              installationId: installation.id,
              repoFullName,
              repoId,
            });

            return Astro.redirect('/dashboard/plugins/' + encodeURIComponent(formValues.id) + '?linked=true');
          }
        } catch (err) {
          const msg = err instanceof Error ? err.message : String(err);
          if (msg.includes('UNIQUE')) {
            errors.id = 'A plugin with this ID already exists.';
            currentStep = 1;
          } else {
            try {
              await env.DB.prepare('DELETE FROM plugins WHERE id = ?').bind(formValues.id).run();
            } catch {
              // Best-effort cleanup
            }
            globalError = 'Failed to register plugin: ' + msg;
            await loadGitHubState(authorId);
          }
        }
      }
    }
  }
}

// CSS helper for input styling
const inputBase = 'w-full bg-paper-soft text-ink rounded-lg px-3 py-2 text-sm focus:border-accent-deep focus:outline-none border';
const inputNormal = `${inputBase} border-rule-strong`;
const inputError = `${inputBase} border-danger`;
---
<BaseLayout title="Register Plugin - Dashboard - emdashcms.org">
  <section class="page-narrow pt-12 pb-16 md:pt-16">

      <a href="/dashboard" class="text-sm text-ink-muted hover:text-ink transition-colors">&larr; Back to Dashboard</a>

      <h1 class="mt-4 text-3xl text-ink">Register Plugin</h1>

      {/* --- Step Indicator --- */}
      <div class="mt-8 flex items-center justify-center gap-0">
        <div class="flex flex-col items-center">
          <div class:list={[
            'flex h-9 w-9 items-center justify-center rounded-full text-sm font-semibold transition-colors',
            currentStep >= 1 ? 'bg-ink text-paper' : 'bg-paper-sunk text-ink-soft',
          ]}>1</div>
          <span class:list={[
            'mt-2 text-xs font-medium',
            currentStep >= 1 ? 'text-ink' : 'text-ink-soft',
          ]}>Plugin Details</span>
        </div>
        <div class:list={[
          'mx-4 h-px w-24 sm:w-32 -mt-5 transition-colors',
          currentStep >= 2 ? 'bg-ink' : 'bg-rule-strong',
        ]} />
        <div class="flex flex-col items-center">
          <div class:list={[
            'flex h-9 w-9 items-center justify-center rounded-full text-sm font-semibold transition-colors',
            currentStep >= 2 ? 'bg-ink text-paper' : 'bg-paper-sunk text-ink-soft',
          ]}>2</div>
          <span class:list={[
            'mt-2 text-xs font-medium',
            currentStep >= 2 ? 'text-ink' : 'text-ink-soft',
          ]}>First Version</span>
        </div>
      </div>

      {/* --- Global messages --- */}
      {globalError && (
        <div class="mt-6">
          <DashboardBanner type="error" message={globalError}>
            <span>{globalError}</span>
            {globalErrorAction && (
              <>
                {' '}
                <a
                  href={globalErrorAction.href}
                  class="font-semibold underline decoration-rule-strong hover:decoration-current"
                >
                  {globalErrorAction.label}
                </a>
              </>
            )}
          </DashboardBanner>
        </div>
      )}
      {globalSuccess && (
        <div class="mt-6">
          <DashboardBanner type="success" message={globalSuccess} />
        </div>
      )}

      {/* =============================== STEP 1 =============================== */}
      {currentStep === 1 && (
        <>
          <p class="mt-6 text-xs text-ink-soft">
            Updating an existing plugin? <a href="/dashboard" class="underline decoration-rule-strong hover:text-ink">See your plugins</a> and upload a new version there — keeps everything under one record and re-audits automatically.
          </p>

          {similarPluginWarning && (
            <div class="mt-4">
              <DashboardBanner type="warn" message="">
                <p class="font-semibold">Looks similar to one of your existing plugins.</p>
                <p class="mt-1">
                  This is close to <a href={`/dashboard/plugins/${encodeURIComponent(similarPluginWarning.matchedId)}`} class="underline decoration-rule-strong hover:decoration-current">{similarPluginWarning.matchedName}</a>. If this is genuinely a different plugin, submit again to confirm. If it's the same project with a tweaked name, <a href={`/dashboard/plugins/${encodeURIComponent(similarPluginWarning.matchedId)}/upload`} class="underline decoration-rule-strong hover:decoration-current font-semibold">upload a new version on the existing plugin</a> instead.
                </p>
              </DashboardBanner>
            </div>
          )}

        <form method="POST" class="mt-8 rounded-xl border border-rule bg-paper-soft p-6 space-y-5">
          <input type="hidden" name="_step" value="1" />
          {similarPluginWarning && (
            <input type="hidden" name="acknowledged_similar" value={similarPluginWarning.matchedId} />
          )}

          {/* Plugin ID */}
          <div>
            <label for="id" class="block text-sm font-semibold text-ink">Plugin ID <span class="text-danger">*</span></label>
            <p class="mt-1 text-xs text-ink-soft">Lowercase alphanumeric with hyphens (e.g. my-plugin)</p>
            <input type="text" id="id" name="id" value={formValues.id}
              placeholder="my-plugin"
              class:list={['mt-2', errors.id ? inputError : inputNormal]}
              aria-required="true"
              aria-invalid={errors.id ? 'true' : undefined}
              aria-describedby={errors.id ? 'id-error' : undefined} />
            {errors.id && <p id="id-error" class="mt-1 text-xs text-danger">{errors.id}</p>}
          </div>

          {/* Name */}
          <div>
            <label for="name" class="block text-sm font-semibold text-ink">Name <span class="text-danger">*</span></label>
            <input type="text" id="name" name="name" value={formValues.name}
              class:list={['mt-2', errors.name ? inputError : inputNormal]}
              aria-required="true"
              aria-invalid={errors.name ? 'true' : undefined}
              aria-describedby={errors.name ? 'name-error' : undefined} />
            {errors.name && <p id="name-error" class="mt-1 text-xs text-danger">{errors.name}</p>}
          </div>

          {/* Short Description */}
          <div>
            <label for="shortDescription" class="block text-sm font-semibold text-ink">Short Description <span class="text-danger">*</span></label>
            <p class="mt-1 text-xs text-ink-soft">A one-line tagline shown in search results and cards</p>
            <input type="text" id="shortDescription" name="shortDescription" value={formValues.shortDescription}
              maxlength="150"
              placeholder="e.g. Adds real-time collaboration editing to your CMS"
              class:list={['mt-2', errors.shortDescription ? inputError : inputNormal]}
              aria-required="true"
              aria-invalid={errors.shortDescription ? 'true' : undefined}
              aria-describedby={errors.shortDescription ? 'shortDescription-error' : 'shortDescription-counter'} />
            <div class="mt-1 flex justify-between">
              {errors.shortDescription ? <p id="shortDescription-error" class="text-xs text-danger">{errors.shortDescription}</p> : <span />}
              <p id="shortDescription-counter" class="text-xs text-ink-soft"><span data-counter="shortDescription">{formValues.shortDescription.length}</span>/150</p>
            </div>
          </div>

          {/* Description */}
          <div>
            <label for="description" class="block text-sm font-semibold text-ink">Description <span class="text-danger">*</span></label>
            <p class="mt-1 text-xs text-ink-soft">Detailed description shown on your listing page. Markdown supported.</p>
            <textarea id="description" name="description"
              maxlength="5000"
              class:list={['mt-2 min-h-[120px] resize-y', errors.description ? inputError : inputNormal]}
              aria-required="true"
              aria-invalid={errors.description ? 'true' : undefined}
              aria-describedby={errors.description ? 'description-error' : 'description-counter'}>{formValues.description}</textarea>
            <div class="mt-1 flex justify-between">
              {errors.description ? <p id="description-error" class="text-xs text-danger">{errors.description}</p> : <span />}
              <p id="description-counter" class="text-xs text-ink-soft"><span data-counter="description">{formValues.description.length}</span>/5000</p>
            </div>
          </div>

          {/* Category */}
          <div>
            <label for="category" class="block text-sm font-semibold text-ink">Category <span class="text-danger">*</span></label>
            <select id="category" name="category"
              class:list={['mt-2', errors.category ? inputError : inputNormal]}
              aria-required="true"
              aria-invalid={errors.category ? 'true' : undefined}
              aria-describedby={errors.category ? 'category-error' : undefined}>
              <option value="" disabled selected={!formValues.category}>Select a category...</option>
              {KNOWN_CATEGORIES.map(cat => (
                <option value={cat} selected={formValues.category === cat}>{cat.charAt(0).toUpperCase() + cat.slice(1).replace('-', ' ')}</option>
              ))}
            </select>
            {errors.category && <p id="category-error" class="mt-1 text-xs text-danger">{errors.category}</p>}
          </div>

          {/* Capabilities live in the bundle's manifest.json — extracted on upload, no need to type them here. */}
          <div class="rounded-lg border border-rule bg-paper-sunk p-3 text-xs text-ink-soft">
            <span class="text-ink-muted">Capabilities &amp; hooks</span> are read from your bundle's <code class="font-mono text-ink">manifest.json</code> when you upload — you don't need to declare them here.
          </div>

          {/* Optional fields in a 2-col grid */}
          <div class="border-t border-rule pt-5">
            <p class="text-sm font-semibold text-ink mb-4">Optional Details</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="keywords" class="block text-sm text-ink-muted">Keywords</label>
                <p class="mt-0.5 text-xs text-ink-soft">Comma-separated</p>
                <input type="text" id="keywords" name="keywords" value={formValues.keywords}
                  placeholder="markdown, editor, syntax"
                  class:list={['mt-1.5', inputNormal]} />
              </div>
              <div>
                <label for="license" class="block text-sm text-ink-muted">License</label>
                <select id="license" name="license" class:list={['mt-1.5', inputNormal]}>
                  <option value="">None</option>
                  {SPDX_LICENSES.map(lic => (
                    <option value={lic} selected={formValues.license === lic}>{lic}</option>
                  ))}
                  <option value="__other__" selected={formValues.license && !SPDX_LICENSES.includes(formValues.license)}>Other...</option>
                </select>
                <input type="text" id="licenseOther" name="licenseOther"
                  value={formValues.licenseOther || (formValues.license && !SPDX_LICENSES.includes(formValues.license) ? formValues.license : '')}
                  placeholder="SPDX identifier"
                  class:list={['mt-1.5', inputNormal, (!formValues.license || SPDX_LICENSES.includes(formValues.license)) && 'hidden']}
                  data-license-other />
              </div>
              <div>
                <label for="repositoryUrl" class="block text-sm text-ink-muted">Repository URL</label>
                <input type="url" id="repositoryUrl" name="repositoryUrl" value={formValues.repositoryUrl}
                  placeholder="https://github.com/..."
                  class:list={['mt-1.5', inputNormal]} />
              </div>
              <div>
                <label for="homepageUrl" class="block text-sm text-ink-muted">Homepage URL</label>
                <input type="url" id="homepageUrl" name="homepageUrl" value={formValues.homepageUrl}
                  placeholder="https://..."
                  class:list={['mt-1.5', inputNormal]} />
              </div>
              <div class="sm:col-span-2">
                <label for="supportUrl" class="block text-sm text-ink-muted">Support URL</label>
                <input type="url" id="supportUrl" name="supportUrl" value={formValues.supportUrl}
                  placeholder="https://..."
                  class:list={['mt-1.5', inputNormal]} />
              </div>
            </div>
          </div>

          <Button type="submit" variant="primary" fullWidth>
            Continue to Version Setup
          </Button>
        </form>
        </>
      )}

      {/* =============================== STEP 2 =============================== */}
      {currentStep === 2 && (
        <div class="mt-8 space-y-6">
          {/* Summary of selected metadata */}
          <div class="rounded-xl border border-rule bg-paper-soft p-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs text-ink-soft uppercase tracking-wider font-medium">Plugin</p>
                <p class="mt-1 text-sm text-ink font-mono">{formValues.id}</p>
                <p class="text-xs text-ink-muted mt-0.5">{formValues.name}</p>
              </div>
              <form method="POST">
                <input type="hidden" name="_step" value="1" />
                <input type="hidden" name="id" value={formValues.id} />
                <input type="hidden" name="name" value={formValues.name} />
                <input type="hidden" name="shortDescription" value={formValues.shortDescription} />
                <input type="hidden" name="description" value={formValues.description} />
                <input type="hidden" name="category" value={formValues.category} />
                <input type="hidden" name="keywords" value={formValues.keywords} />
                <input type="hidden" name="license" value={formValues.license} />
                <input type="hidden" name="repositoryUrl" value={formValues.repositoryUrl} />
                <input type="hidden" name="homepageUrl" value={formValues.homepageUrl} />
                <input type="hidden" name="supportUrl" value={formValues.supportUrl} />
                <Button type="submit" variant="ghost" size="sm">
                  Edit details
                </Button>
              </form>
            </div>
          </div>

          {/* Delivery options: side-by-side cards */}
          <div class:list={[
            'grid gap-6',
            githubAppConfigured ? 'grid-cols-1 md:grid-cols-2' : 'grid-cols-1 max-w-lg mx-auto',
          ]}>

            {/* --- Option A: Upload Bundle --- */}
            <form method="POST" enctype="multipart/form-data" class="rounded-xl border border-rule bg-paper-soft p-6 flex flex-col">
              <input type="hidden" name="_step" value="2-upload" />
              {/* Carry every step-1 field through so readMetadata sees them all */}
              <input type="hidden" name="id" value={formValues.id} />
              <input type="hidden" name="name" value={formValues.name} />
              <input type="hidden" name="shortDescription" value={formValues.shortDescription} />
              <input type="hidden" name="description" value={formValues.description} />
              <input type="hidden" name="category" value={formValues.category} />
              <input type="hidden" name="keywords" value={formValues.keywords} />
              <input type="hidden" name="license" value={formValues.license} />
              <input type="hidden" name="repositoryUrl" value={formValues.repositoryUrl} />
              <input type="hidden" name="homepageUrl" value={formValues.homepageUrl} />
              <input type="hidden" name="supportUrl" value={formValues.supportUrl} />

              <div class="flex items-center gap-3 mb-4">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-paper-sunk text-ink">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-sm font-semibold text-ink">Upload Bundle</h3>
                  <p class="text-xs text-ink-soft">Upload a .tgz plugin bundle directly</p>
                </div>
              </div>

              <div class="flex-1">
                <label for="bundle" class="block text-sm text-ink-muted mb-2">Plugin bundle (.tgz)</label>
                <input type="file" id="bundle" name="bundle" accept=".tgz,.tar.gz,application/gzip"
                  class="w-full text-sm text-ink-muted file:mr-3 file:rounded-lg file:border-0 file:bg-paper-sunk file:px-3 file:py-2 file:text-sm file:font-medium file:text-ink file:cursor-pointer hover:file:bg-paper-deep file:transition-colors cursor-pointer" />
                <p class="mt-2 text-xs text-ink-soft">Max 10 MB. Must contain a valid manifest.json.</p>
              </div>

              <div class="mt-4">
                <TurnstileWidget />
              </div>
              <Button type="submit" variant="primary" fullWidth class="mt-4">
                Upload &amp; Register
              </Button>
            </form>

            {/* --- Option B: Connect GitHub --- */}
            {githubAppConfigured && (
              <div class="rounded-xl border border-rule bg-paper-soft p-6 flex flex-col">
                <div class="flex items-center gap-3 mb-4">
                  <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-paper-sunk text-ink">
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 16 16">
                      <path d="M8 .2a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38l-.01-1.49c-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.42 7.42 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48l-.01 2.2c0 .21.15.46.55.38A8.01 8.01 0 0 0 8 .2Z" />
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-sm font-semibold text-ink">Connect GitHub</h3>
                    <p class="text-xs text-ink-soft">Auto-publish from GitHub releases</p>
                  </div>
                </div>

                {githubError && (
                  <div class="mb-4">
                    <DashboardBanner type="error" message={githubError} />
                  </div>
                )}

                {githubInstalled ? (
                  <form method="POST" class="flex-1 flex flex-col">
                    <input type="hidden" name="_step" value="2-github" />
                    {/* Carry every step-1 field through so readMetadata sees them all */}
                    <input type="hidden" name="id" value={formValues.id} />
                    <input type="hidden" name="name" value={formValues.name} />
                    <input type="hidden" name="shortDescription" value={formValues.shortDescription} />
                    <input type="hidden" name="description" value={formValues.description} />
                    <input type="hidden" name="category" value={formValues.category} />
                    <input type="hidden" name="keywords" value={formValues.keywords} />
                    <input type="hidden" name="license" value={formValues.license} />
                    <input type="hidden" name="repositoryUrl" value={formValues.repositoryUrl} />
                    <input type="hidden" name="homepageUrl" value={formValues.homepageUrl} />
                    <input type="hidden" name="supportUrl" value={formValues.supportUrl} />

                    <div class="flex-1">
                      <label for="repoFullName" class="block text-sm text-ink-muted mb-2">Repository</label>
                      {githubRepos.length > 0 ? (
                        <select id="repoFullName" name="repoFullName"
                          class="w-full bg-paper-soft border border-rule-strong text-ink rounded-lg px-3 py-2 text-sm focus:border-accent-deep focus:outline-none"
                          onchange="this.form.querySelector('[name=repoId]').value = this.options[this.selectedIndex].dataset.repoId || ''">
                          <option value="">Select a repository...</option>
                          {githubRepos.map(repo => (
                            <option value={repo.full_name} data-repo-id={repo.id}>
                              {repo.full_name}{repo.private ? ' (private)' : ''}
                            </option>
                          ))}
                        </select>
                      ) : (
                        <p class="text-sm text-ink-soft">No repositories found. Grant access to repositories in the GitHub App settings.</p>
                      )}
                      <input type="hidden" name="repoId" value="" />
                    </div>

                    <Button type="submit" variant="primary" fullWidth disabled={githubRepos.length === 0} class="mt-6">
                      Link Repository
                    </Button>
                  </form>
                ) : (
                  <div class="flex-1 flex flex-col justify-center">
                    <div class="rounded-lg border border-rule bg-paper-sunk p-4 text-center">
                      <p class="text-sm text-ink-muted mb-3">Install the emdashcms.org GitHub App to connect a repository.</p>
                      <Button href={`https://github.com/apps/emdashcms-org/installations/new`}
                        target="_blank"
                        rel="noopener noreferrer"
                        variant="secondary"
                        size="md">
                        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 16 16">
                          <path d="M8 .2a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38l-.01-1.49c-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.42 7.42 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48l-.01 2.2c0 .21.15.46.55.38A8.01 8.01 0 0 0 8 .2Z" />
                        </svg>
                        Install GitHub App
                      </Button>
                    </div>
                    <p class="mt-3 text-center">
                      <a href={Astro.url.pathname} class="text-xs text-ink-soft hover:text-ink transition-colors underline underline-offset-2">
                        I've installed it, refresh
                      </a>
                    </p>
                  </div>
                )}
              </div>
            )}

          </div>
        </div>
      )}

  </section>

  <script is:inline>
    // Character counters
    document.querySelectorAll('[data-counter]').forEach(function(span) {
      var fieldId = span.getAttribute('data-counter');
      var field = document.getElementById(fieldId);
      if (field) {
        field.addEventListener('input', function() {
          span.textContent = field.value.length;
        });
      }
    });

    // License "Other" toggle
    var licenseSelect = document.getElementById('license');
    var licenseOther = document.querySelector('[data-license-other]');
    if (licenseSelect && licenseOther) {
      licenseSelect.addEventListener('change', function() {
        if (licenseSelect.value === '__other__') {
          licenseOther.classList.remove('hidden');
          licenseOther.focus();
        } else {
          licenseOther.classList.add('hidden');
        }
      });
    }
  </script>
</BaseLayout>
