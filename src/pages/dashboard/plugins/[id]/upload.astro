---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Button from '../../../../components/Button.astro';
import DashboardBanner from '../../../../components/DashboardBanner.astro';
import {
  resolveAuthorId,
  checkUploadRateLimit,
  checkVersionExists,
  createVersion,
} from '../../../../lib/publishing/plugin-queries';
import { checkPluginAccess, hasRole } from '../../../../lib/auth/permissions';
import { validateBundle } from '../../../../lib/publishing/bundle-validator';
import { storeBundleInR2 } from '../../../../lib/publishing/r2-storage';
import { enqueueAuditJob } from '../../../../lib/publishing/queue';
import { checkAuthorAuditBudget, recordAuthorAuditUsage } from '../../../../lib/audit/author-budget';
import TurnstileWidget from '../../../../components/TurnstileWidget.astro';
import { verifyTurnstile } from '../../../../lib/turnstile/verify';

const { id: pluginId } = Astro.params;
const author = Astro.locals.author!;

// RBAC check — maintainer+ required for upload (D-06)
const authorId = await resolveAuthorId(env.DB, author.githubId);
if (!authorId) return Astro.redirect('/dashboard');

const access = await checkPluginAccess(env.DB, authorId, pluginId!);
if (!access.found || !access.role || !hasRole(access.role, 'maintainer')) {
  return Astro.redirect('/dashboard');
}

// Get plugin name for breadcrumb
const pluginRow = await env.DB.prepare('SELECT name FROM plugins WHERE id = ?')
  .bind(pluginId).first<{ name: string }>();
const pluginName = pluginRow?.name ?? pluginId;

let error = '';

if (Astro.request.method === 'POST') {
  try {
    // Parse multipart form (D-12: server-side handling)
    const data = await Astro.request.formData();

    // Turnstile bot check
    const tsToken = data.get('cf-turnstile-response') as string ?? '';
    const tsIp = Astro.request.headers.get('CF-Connecting-IP') ?? undefined;
    const tsResult = await verifyTurnstile(tsToken, env.TURNSTILE_SECRET_KEY, tsIp);
    if (!tsResult.success) throw new Error('Challenge verification failed. Please try again.');

    const file = data.get('tarball');
    if (!(file instanceof File)) {
      throw new Error('Please select a .tgz file to upload.');
    }

    // Rate limit check (COST-01)
    const rateLimit = await checkUploadRateLimit(env.DB, authorId);
    if (!rateLimit.allowed) {
      throw new Error('Rate limit exceeded: 5 versions per day. Try again tomorrow.');
    }

    // Validate bundle (PUBL-03)
    const tarballBytes = await file.arrayBuffer();
    const validation = await validateBundle(tarballBytes, pluginId!);
    if (!validation.valid) {
      throw new Error(`Bundle validation failed: ${validation.errors!.join('; ')}`);
    }

    // Check version not already uploaded
    const versionStr = validation.manifest!.version;
    const exists = await checkVersionExists(env.DB, pluginId!, versionStr);
    if (exists) {
      throw new Error(`Version ${versionStr} already exists for this plugin.`);
    }

    // Store in R2 (PUBL-04)
    const { key: bundleKey } = await storeBundleInR2(
      env.ARTIFACTS,
      pluginId!,
      versionStr,
      tarballBytes,
      validation.checksum!,
    );

    // Create D1 version record
    await createVersion(env.DB, {
      pluginId: pluginId!,
      version: versionStr,
      manifest: JSON.stringify(validation.manifest),
      bundleKey,
      checksum: validation.checksum!,
      fileCount: validation.stats!.fileCount,
      compressedSize: validation.stats!.compressedSize,
      decompressedSize: validation.stats!.decompressedSize,
      changelog: (validation.manifest as any).changelog ?? undefined,
      minEmDashVersion: (validation.manifest as any).minEmDashVersion ?? undefined,
    });

    // Audit budget check (COST-03)
    const budget = await checkAuthorAuditBudget(env.DB, authorId);
    if (!budget.allowed) throw new Error('Daily audit limit reached (10/day). Try again tomorrow.');

    await enqueueAuditJob(env.AUDIT_QUEUE, {
      pluginId: pluginId!,
      version: versionStr,
      authorId,
      bundleKey,
    });
    await recordAuthorAuditUsage(env.DB, authorId);

    // Redirect to plugin detail with success banner (D-11)
    return Astro.redirect(`/dashboard/plugins/${encodeURIComponent(pluginId!)}?uploaded=true`);
  } catch (e) {
    error = 'An error occurred during upload. Please check your file and try again.';
  }
}
---
<BaseLayout title={'Upload Version - ' + pluginName + ' - Dashboard - emdashcms.org'}>
  <section class="page-narrow pt-12 pb-16 md:pt-16">

      <a href={'/dashboard/plugins/' + pluginId} class="text-sm text-ink-muted hover:text-ink transition-colors">
        Back to {pluginName}
      </a>

      <h1 class="mt-4 text-3xl text-ink">
        Upload Version
      </h1>

      {error && (
        <div class="mt-6">
          <DashboardBanner type="error" message={error} />
        </div>
      )}

      <form method="POST" enctype="multipart/form-data" class="mt-8 rounded-xl border border-rule bg-paper-soft p-6 space-y-4">
        <div>
          <label for="tarball" class="block text-sm font-semibold text-ink">
            Plugin bundle (.tgz) *
          </label>
          <p class="mt-1 text-xs text-ink-soft">
            Upload a .tgz tarball built with emdash plugin build
          </p>
          <input
            type="file"
            id="tarball"
            name="tarball"
            accept=".tgz,application/gzip"
            aria-required="true"
            class="mt-2 block w-full text-sm text-ink-muted file:mr-4 file:rounded-lg file:border-0 file:bg-paper-sunk file:px-4 file:py-2 file:text-sm file:font-medium file:text-ink hover:file:bg-paper-deep focus:outline-none"
          />
        </div>

        <div class="mb-4">
          <TurnstileWidget />
        </div>
        <Button type="submit" variant="primary" fullWidth>
          Upload Version
        </Button>
      </form>

  </section>
</BaseLayout>
