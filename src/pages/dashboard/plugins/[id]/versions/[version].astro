---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import Button from '../../../../../components/Button.astro';
import AuditBadge from '../../../../../components/AuditBadge.astro';
import StatusBadge from '../../../../../components/StatusBadge.astro';
import DashboardBanner from '../../../../../components/DashboardBanner.astro';
import { getVersionDetail } from '../../../../../lib/db/queries';
import {
  resolveAuthorId,
  getVersionForRetry,
  incrementRetryCount,
} from '../../../../../lib/publishing/plugin-queries';
import { checkPluginAccess, hasRole } from '../../../../../lib/auth/permissions';
import { enqueueAuditJob } from '../../../../../lib/publishing/queue';
import { checkAuthorAuditBudget, recordAuthorAuditUsage } from '../../../../../lib/audit/author-budget';

const { id: pluginId, version: versionStr } = Astro.params;
const author = Astro.locals.author!;

// RBAC check — any collaborator can view audit details (D-10)
const authorId = await resolveAuthorId(env.DB, author.githubId);
if (!authorId) return Astro.redirect('/dashboard');

const access = await checkPluginAccess(env.DB, authorId, pluginId!);
if (!access.found || !access.role) return Astro.redirect('/dashboard');
const isMaintainer = hasRole(access.role, 'maintainer');

// Get plugin name for breadcrumb
const pluginRow = await env.DB.prepare('SELECT name FROM plugins WHERE id = ?')
  .bind(pluginId).first<{ name: string }>();
const pluginName = pluginRow?.name ?? pluginId;

// Handle retry audit POST (D-21)
let retrySuccess = false;
let retryError = '';

if (Astro.request.method === 'POST') {
  try {
    if (!isMaintainer) throw new Error('Maintainer role required to retry audit');
    const ver = await getVersionForRetry(env.DB, pluginId!, versionStr!);
    if (!ver) throw new Error('Version not found');
    if (ver.status !== 'rejected') {
      throw new Error(`Cannot retry audit for version with status '${ver.status}'. Only rejected versions can be retried.`);
    }
    if (ver.retryCount >= 3) {
      throw new Error('Maximum retry attempts (3) exceeded. Please upload a new version.');
    }

    // Audit budget check
    const budget = await checkAuthorAuditBudget(env.DB, authorId);
    if (!budget.allowed) throw new Error('Daily audit limit reached (10/day). Try again tomorrow.');

    await incrementRetryCount(env.DB, ver.id);
    await enqueueAuditJob(env.AUDIT_QUEUE, {
      pluginId: pluginId!,
      version: versionStr!,
      authorId,
      bundleKey: ver.bundleKey,
    });
    await recordAuthorAuditUsage(env.DB, authorId);

    retrySuccess = true;
  } catch (e) {
    retryError = e instanceof Error ? e.message : 'An error occurred';
  }
}

// Load version detail (re-fetch after potential retry)
const versionDetail = await getVersionDetail(env.DB, pluginId!, versionStr!);
if (!versionDetail) return Astro.redirect('/dashboard/plugins/' + pluginId);

// Risk score color helper
const riskColor = (score: number | null) => {
  if (score === null) return 'text-ink-muted';
  if (score <= 33) return 'text-success';
  if (score <= 66) return 'text-warn';
  return 'text-danger';
};

// Severity badge classes (matching existing pattern from plugins/[id].astro)
const severityClasses = (severity: string) => {
  switch (severity) {
    case 'critical': return 'bg-danger-soft text-danger';
    case 'high': return 'bg-danger-soft text-danger';
    case 'medium': return 'bg-warn-soft text-warn';
    case 'low': return 'bg-paper-sunk text-ink-muted';
    case 'info': return 'bg-paper-sunk text-ink-soft';
    default: return 'bg-paper-sunk text-ink-muted';
  }
};
---
<BaseLayout title={'v' + versionDetail.version + ' Audit - ' + pluginName + ' - Dashboard - emdashcms.org'}>
  <section class="page-narrow pt-12 pb-16 md:pt-16">

      <a href={'/dashboard/plugins/' + pluginId} class="text-sm text-ink-muted hover:text-ink transition-colors">
        Back to {pluginName}
      </a>

      <h1 class="mt-4 text-3xl text-ink">
        Audit Results
      </h1>
      <p class="mt-1 text-sm text-ink-muted">
        Version <code class="font-mono">{versionDetail.version}</code>
      </p>

      {retrySuccess && (
        <div class="mt-6">
          <DashboardBanner type="success" message="Audit retry queued. Refresh in a moment to see results." />
        </div>
      )}

      {retryError && (
        <div class="mt-6">
          <DashboardBanner type="error" message={'Retry failed. ' + retryError} />
        </div>
      )}

      {versionDetail.status === 'pending' ? (
        <div class="mt-8 text-center py-16">
          <h2 class="text-xl text-ink">Audit in progress</h2>
          <p class="mt-2 text-sm text-ink-muted">Check back shortly.</p>
        </div>
      ) : (
        <>
          <div class="mt-8 rounded-xl border border-rule bg-paper-soft p-6">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                <AuditBadge verdict={versionDetail.verdict} />
                <StatusBadge status={versionDetail.status} />
              </div>
              <div class="text-right">
                <p class="text-xs font-semibold text-ink-soft uppercase tracking-wide">Risk Score</p>
                <p class:list={['text-2xl font-semibold', riskColor(versionDetail.riskScore)]}>
                  {versionDetail.riskScore ?? '\u2014'}
                </p>
              </div>
            </div>

            {versionDetail.status === 'rejected' && (
              <div class="mt-4 pt-4 border-t border-rule flex items-center justify-between">
                <p class="text-sm text-ink-muted">
                  {versionDetail.retryCount} of 3 retry attempts used
                </p>
                {versionDetail.latestAuditModel === 'static-only' ? (
                  <p class="text-sm text-ink-soft">
                    Static-scanner rejection — upload a corrected bundle.
                  </p>
                ) : isMaintainer && versionDetail.retryCount < 3 ? (
                  <form method="POST" class="inline">
                    <Button type="submit" variant="destructive" size="md">
                      Retry Audit
                    </Button>
                  </form>
                ) : versionDetail.retryCount >= 3 ? (
                  <p class="text-sm text-danger">Maximum retries reached. Upload a new version.</p>
                ) : null}
              </div>
            )}
          </div>

          {versionDetail.status === 'rejected' && versionDetail.adminRejectionReason && (
            <div class="mt-8 rounded-xl border border-warn/35 bg-warn-soft p-5">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-warn shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
                </svg>
                <div>
                  <h3 class="text-sm font-semibold text-warn uppercase tracking-wide">
                    Moderator note
                  </h3>
                  <p class="mt-2 text-sm text-ink whitespace-pre-wrap leading-relaxed">
                    {versionDetail.adminRejectionReason}
                  </p>
                </div>
              </div>
            </div>
          )}

          {versionDetail.latestAuditModel === 'static-only' && versionDetail.status === 'rejected' && (
            <div class="mt-4 text-xs text-ink-soft">
              Static-scanner rejections are deterministic — retrying the same bundle will produce the same result.
              Review the findings below, fix the issue in your source, and upload a new version.
              See <a href="/docs/security" class="text-ink hover:text-accent-deep underline decoration-rule-strong">the review policy</a> for the full ruleset.
            </div>
          )}

          <h2 class="mt-12 text-xl text-ink">Findings</h2>

          {versionDetail.findings.length === 0 ? (
            <p class="mt-4 text-sm text-ink-muted">No findings reported.</p>
          ) : (
            <div class="mt-4 space-y-3">
              {versionDetail.findings.map((finding) => (
                <div class="rounded-lg border border-rule bg-paper-soft p-4">
                  <div class="flex items-start gap-3">
                    <span class:list={['flex-shrink-0 rounded px-1.5 py-0.5 text-[11px] font-medium uppercase', severityClasses(finding.severity)]}>
                      {finding.severity}
                    </span>
                    <h3 class="text-sm font-semibold text-ink">{finding.title}</h3>
                  </div>
                  <p class="mt-2 text-sm text-ink-muted">{finding.description}</p>
                  <div class="mt-2 flex items-center gap-3 text-xs text-ink-soft">
                    <span class="rounded bg-paper-sunk px-1.5 py-0.5">{finding.category}</span>
                    {finding.location && <code class="font-mono">{finding.location}</code>}
                  </div>
                </div>
              ))}
            </div>
          )}
        </>
      )}

  </section>
</BaseLayout>
