---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import AuditBadge from '../../../../../components/AuditBadge.astro';
import StatusBadge from '../../../../../components/StatusBadge.astro';
import DashboardBanner from '../../../../../components/DashboardBanner.astro';
import { getVersionDetail } from '../../../../../lib/db/queries';
import {
  resolveAuthorId,
  getPluginOwner,
  getVersionForRetry,
  incrementRetryCount,
} from '../../../../../lib/publishing/plugin-queries';
import { enqueueAuditJob } from '../../../../../lib/publishing/queue';

const { id: pluginId, version: versionStr } = Astro.params;
const author = Astro.locals.author!;

// Ownership check (D-09)
const authorId = await resolveAuthorId(env.DB, author.githubId);
if (!authorId) return Astro.redirect('/dashboard');

const owner = await getPluginOwner(env.DB, pluginId!);
if (!owner || owner.authorId !== authorId) {
  return Astro.redirect('/dashboard');
}

// Get plugin name for breadcrumb
const pluginRow = await env.DB.prepare('SELECT name FROM plugins WHERE id = ?')
  .bind(pluginId).first<{ name: string }>();
const pluginName = pluginRow?.name ?? pluginId;

// Handle retry audit POST (D-21)
let retrySuccess = false;
let retryError = '';

if (Astro.request.method === 'POST') {
  try {
    const ver = await getVersionForRetry(env.DB, pluginId!, versionStr!);
    if (!ver) throw new Error('Version not found');
    if (ver.status !== 'rejected') {
      throw new Error(`Cannot retry audit for version with status '${ver.status}'. Only rejected versions can be retried.`);
    }
    if (ver.retryCount >= 3) {
      throw new Error('Maximum retry attempts (3) exceeded. Please upload a new version.');
    }

    await incrementRetryCount(env.DB, ver.id);
    await enqueueAuditJob(env.AUDIT_QUEUE, {
      pluginId: pluginId!,
      version: versionStr!,
      authorId,
      bundleKey: ver.bundleKey,
    });

    retrySuccess = true;
  } catch (e) {
    retryError = e instanceof Error ? e.message : 'An error occurred';
  }
}

// Load version detail (re-fetch after potential retry)
const versionDetail = await getVersionDetail(env.DB, pluginId!, versionStr!);
if (!versionDetail) return Astro.redirect('/dashboard/plugins/' + pluginId);

// Risk score color helper
const riskColor = (score: number | null) => {
  if (score === null) return 'text-zinc-400';
  if (score <= 33) return 'text-emerald-400';
  if (score <= 66) return 'text-amber-400';
  return 'text-red-400';
};

// Severity badge classes (matching existing pattern from plugins/[id].astro)
const severityClasses = (severity: string) => {
  switch (severity) {
    case 'critical': return 'bg-red-950/40 text-red-400';
    case 'high': return 'bg-red-950/40 text-red-400';
    case 'medium': return 'bg-amber-950/40 text-amber-400';
    case 'low': return 'bg-zinc-800 text-zinc-400';
    case 'info': return 'bg-zinc-800 text-zinc-500';
    default: return 'bg-zinc-800 text-zinc-400';
  }
};
---
<BaseLayout title={'v' + versionDetail.version + ' Audit - ' + pluginName + ' - Dashboard - emdashcms.org'}>
  <section class="pt-24 pb-16 px-6">
    <div class="mx-auto max-w-3xl">

      <a href={'/dashboard/plugins/' + pluginId} class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors">
        Back to {pluginName}
      </a>

      <h1 class="mt-4 text-3xl font-semibold tracking-tight leading-[1.15] text-zinc-100">
        Audit Results
      </h1>
      <p class="mt-1 text-sm text-zinc-400">
        Version <code class="font-mono">{versionDetail.version}</code>
      </p>

      {retrySuccess && (
        <div class="mt-6">
          <DashboardBanner type="success" message="Audit retry queued. Refresh in a moment to see results." />
        </div>
      )}

      {retryError && (
        <div class="mt-6">
          <DashboardBanner type="error" message={'Retry failed. ' + retryError} />
        </div>
      )}

      {versionDetail.status === 'pending' ? (
        <div class="mt-8 text-center py-16">
          <h2 class="text-xl font-semibold text-zinc-100">Audit in progress</h2>
          <p class="mt-2 text-sm text-zinc-400">Check back shortly.</p>
        </div>
      ) : (
        <>
          <div class="mt-8 rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                <AuditBadge verdict={versionDetail.verdict} />
                <StatusBadge status={versionDetail.status} />
              </div>
              <div class="text-right">
                <p class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Risk Score</p>
                <p class:list={['text-2xl font-semibold', riskColor(versionDetail.riskScore)]}>
                  {versionDetail.riskScore ?? '\u2014'}
                </p>
              </div>
            </div>

            {versionDetail.status === 'rejected' && (
              <div class="mt-4 pt-4 border-t border-zinc-800/60 flex items-center justify-between">
                <p class="text-sm text-zinc-400">
                  {versionDetail.retryCount} of 3 retry attempts used
                </p>
                {versionDetail.retryCount < 3 ? (
                  <form method="POST" class="inline">
                    <button
                      type="submit"
                      class="rounded-lg bg-red-950/40 border border-red-800/60 px-4 py-2 text-sm font-medium text-red-400 hover:bg-red-950/60 hover:text-red-300 transition-colors"
                    >
                      Retry Audit
                    </button>
                  </form>
                ) : (
                  <p class="text-sm text-red-400">Maximum retries reached. Upload a new version.</p>
                )}
              </div>
            )}
          </div>

          <h2 class="mt-12 text-xl font-semibold text-zinc-100">Findings</h2>

          {versionDetail.findings.length === 0 ? (
            <p class="mt-4 text-sm text-zinc-400">No findings reported.</p>
          ) : (
            <div class="mt-4 space-y-3">
              {versionDetail.findings.map((finding) => (
                <div class="rounded-lg border border-zinc-800/60 bg-zinc-900/40 p-4">
                  <div class="flex items-start gap-3">
                    <span class:list={['flex-shrink-0 rounded px-1.5 py-0.5 text-[11px] font-medium uppercase', severityClasses(finding.severity)]}>
                      {finding.severity}
                    </span>
                    <h3 class="text-sm font-semibold text-zinc-100">{finding.title}</h3>
                  </div>
                  <p class="mt-2 text-sm text-zinc-400">{finding.description}</p>
                  <div class="mt-2 flex items-center gap-3 text-xs text-zinc-500">
                    <span class="rounded bg-zinc-800 px-1.5 py-0.5">{finding.category}</span>
                    {finding.location && <code class="font-mono">{finding.location}</code>}
                  </div>
                </div>
              ))}
            </div>
          )}
        </>
      )}

    </div>
  </section>
</BaseLayout>
