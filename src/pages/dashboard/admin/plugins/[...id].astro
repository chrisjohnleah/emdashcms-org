---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Button from '../../../../components/Button.astro';
import StatusBadge from '../../../../components/StatusBadge.astro';
import AuditBadge from '../../../../components/AuditBadge.astro';
import SourceBadge from '../../../../components/SourceBadge.astro';
import { isSuperAdmin } from '../../../../lib/auth/admin';
import { getAdminPluginDetail, getAdminPluginVersions } from '../../../../lib/db/admin-queries';
import { AUDIT_MODELS, DEFAULT_AUDIT_MODEL } from '../../../../lib/audit/prompt';

const author = Astro.locals.author;
if (!author || !isSuperAdmin(author.githubId)) {
  return Astro.redirect('/dashboard', 302);
}

const pluginId = Astro.params.id;
if (!pluginId) {
  return Astro.redirect('/dashboard/admin', 302);
}

const plugin = await getAdminPluginDetail(env.DB, pluginId);
if (!plugin) {
  return Astro.redirect('/dashboard/admin', 302);
}

const versions = await getAdminPluginVersions(env.DB, pluginId);

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'short', year: 'numeric',
  });

// Audit models wrap their JSON response in markdown code fences
// (```json … ```). Strip them so the moderator dashboard renders the
// payload cleanly. Storage stays untouched — this is a display-only
// transform so old rows clean up automatically.
const stripCodeFence = (raw: string): string => {
  const trimmed = raw.trim();
  const fenced = trimmed.match(/^```(?:json|JSON)?\s*\n([\s\S]*?)\n?```$/);
  return fenced ? fenced[1].trim() : trimmed;
};

const formatBytes = (bytes: number) => {
  if (bytes === 0) return '0 B';
  const k = 1024;
  const sizes = ['B', 'KB', 'MB'];
  const i = Math.floor(Math.log(bytes) / Math.log(k));
  return `${parseFloat((bytes / Math.pow(k, i)).toFixed(1))} ${sizes[i]}`;
};

const riskColor = (score: number | null) => {
  if (score === null) return 'text-ink-soft';
  if (score <= 33) return 'text-success';
  if (score <= 66) return 'text-warn';
  return 'text-danger';
};

const severityStyle = (severity: string) => {
  const s = severity.toLowerCase();
  if (s === 'critical' || s === 'high') return 'bg-danger-soft text-danger';
  if (s === 'medium') return 'bg-warn-soft text-warn';
  return 'bg-paper-sunk text-ink-muted';
};
---
<BaseLayout title={`${plugin.name} - Admin - emdashcms.org`}>
  <section class="page pt-12 pb-16 md:pt-16">

      <!-- Breadcrumb -->
      <nav class="mb-6 flex items-center gap-2 text-sm text-ink-soft">
        <a href="/dashboard/admin" class="hover:text-ink transition-colors">Admin</a>
        <span>/</span>
        <a href="/dashboard/admin" class="hover:text-ink transition-colors">Plugins</a>
        <span>/</span>
        <span class="text-ink-muted">{plugin.name}</span>
      </nav>

      <!-- Header -->
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <div>
          <div class="flex items-center gap-3">
            <h1 class="text-3xl text-ink">{plugin.name}</h1>
            {plugin.status === 'active' ? (
              <span class="inline-flex items-center rounded-full bg-success-soft border border-success/30 px-2 py-0.5 text-[11px] text-success font-medium">Active</span>
            ) : (
              <span class="inline-flex items-center rounded-full bg-danger-soft border border-danger/35 px-2 py-0.5 text-[11px] text-danger font-medium">Revoked</span>
            )}
          </div>
          <p class="text-xs text-ink-soft font-mono mt-1">{plugin.id}</p>
        </div>
        <div class="flex items-center gap-2">
          {plugin.status === 'active' ? (
            <form method="POST" data-admin-action="revoke" data-plugin-id={encodeURIComponent(plugin.id)}>
              <Button type="submit" variant="secondary" size="md">Revoke</Button>
            </form>
          ) : (
            <form method="POST" data-admin-action="restore" data-plugin-id={encodeURIComponent(plugin.id)}>
              <Button type="submit" variant="primary" size="md">Restore</Button>
            </form>
          )}
          <form method="POST" data-admin-action="delete" data-plugin-id={encodeURIComponent(plugin.id)}>
            <Button type="submit" variant="destructive" size="md">Delete</Button>
          </form>
        </div>
      </div>

      <!-- Info Card -->
      <div class="rounded-xl border border-rule bg-paper-soft p-6 mb-10">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-5">

          <!-- Author -->
          <div>
            <p class="text-xs text-ink-soft uppercase tracking-wide font-semibold mb-1">Author</p>
            <a href={`/dashboard/admin/authors/${plugin.authorId}`} class="inline-flex items-center gap-2 text-ink hover:underline transition-colors">
              {plugin.authorAvatarUrl ? (
                <img src={plugin.authorAvatarUrl} alt={plugin.authorUsername} class="w-5 h-5 rounded-full" />
              ) : (
                <div class="w-5 h-5 rounded-full bg-paper-deep" />
              )}
              <span class="font-medium">{plugin.authorUsername}</span>
            </a>
          </div>

          <!-- Category -->
          <div>
            <p class="text-xs text-ink-soft uppercase tracking-wide font-semibold mb-1">Category</p>
            <p class="text-ink-muted">{plugin.category ?? 'Uncategorized'}</p>
          </div>

          <!-- Description -->
          <div class="md:col-span-2">
            <p class="text-xs text-ink-soft uppercase tracking-wide font-semibold mb-1">Description</p>
            <p class="text-ink-muted">{plugin.description ?? 'No description provided.'}</p>
          </div>

          <!-- License -->
          <div>
            <p class="text-xs text-ink-soft uppercase tracking-wide font-semibold mb-1">License</p>
            <p class="text-ink-muted">{plugin.license ?? 'Not specified'}</p>
          </div>

          <!-- Install Count -->
          <div>
            <p class="text-xs text-ink-soft uppercase tracking-wide font-semibold mb-1">Installs</p>
            <p class="text-ink-muted">{plugin.installCount.toLocaleString()}</p>
          </div>

          <!-- Capabilities -->
          {plugin.capabilities.length > 0 && (
            <div class="md:col-span-2">
              <p class="text-xs text-ink-soft uppercase tracking-wide font-semibold mb-2">Capabilities</p>
              <div class="flex flex-wrap gap-1.5">
                {plugin.capabilities.map(cap => (
                  <span class="inline-flex items-center rounded-full bg-paper-sunk border border-rule-strong px-2.5 py-0.5 text-xs font-medium text-ink-muted">{cap}</span>
                ))}
              </div>
            </div>
          )}

          <!-- Repository URL -->
          {plugin.repositoryUrl && (
            <div>
              <p class="text-xs text-ink-soft uppercase tracking-wide font-semibold mb-1">Repository</p>
              <a href={plugin.repositoryUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-ink-muted hover:text-ink transition-colors break-all">{plugin.repositoryUrl}</a>
            </div>
          )}

          <!-- Homepage URL -->
          {plugin.homepageUrl && (
            <div>
              <p class="text-xs text-ink-soft uppercase tracking-wide font-semibold mb-1">Homepage</p>
              <a href={plugin.homepageUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-ink-muted hover:text-ink transition-colors break-all">{plugin.homepageUrl}</a>
            </div>
          )}

          <!-- GitHub Link Info -->
          {plugin.githubRepoFullName && (
            <div class="md:col-span-2 rounded-lg border border-rule bg-paper-sunk p-4 mt-2">
              <p class="text-xs text-ink-soft uppercase tracking-wide font-semibold mb-3">GitHub Link</p>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
                <div>
                  <p class="text-ink-soft text-xs mb-0.5">Repository</p>
                  <a href={`https://github.com/${plugin.githubRepoFullName}`} target="_blank" rel="noopener noreferrer" class="text-ink-muted hover:text-ink font-mono text-xs transition-colors">{plugin.githubRepoFullName}</a>
                </div>
                <div>
                  <p class="text-ink-soft text-xs mb-0.5">Auto Submit</p>
                  <p class="text-ink-muted text-xs">{plugin.githubAutoSubmit ? 'Yes' : 'No'}</p>
                </div>
                {plugin.githubTagPattern && (
                  <div>
                    <p class="text-ink-soft text-xs mb-0.5">Tag Pattern</p>
                    <p class="text-ink-muted font-mono text-xs">{plugin.githubTagPattern}</p>
                  </div>
                )}
              </div>
            </div>
          )}

          <!-- Dates -->
          <div>
            <p class="text-xs text-ink-soft uppercase tracking-wide font-semibold mb-1">Created</p>
            <p class="text-ink-muted">{formatDate(plugin.createdAt)}</p>
          </div>
          <div>
            <p class="text-xs text-ink-soft uppercase tracking-wide font-semibold mb-1">Updated</p>
            <p class="text-ink-muted">{formatDate(plugin.updatedAt)}</p>
          </div>

        </div>
      </div>

      <!-- Versions -->
      <div>
        <h2 class="text-xl text-ink mb-4">Versions ({versions.length})</h2>
        {versions.length === 0 ? (
          <p class="text-sm text-ink-muted">No versions submitted yet.</p>
        ) : (
          <div class="rounded-xl border border-rule bg-paper-soft overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-rule text-left">
                  <th class="pb-3 pl-6 pr-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Version</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Status</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Verdict</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Risk</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Source</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide text-right" title="Bundle GETs for this version">Downloads</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Retries</th>
                  <th class="pb-3 pl-4 pr-6 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Date</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-rule">
                {versions.map(v => (
                  <tr class="group">
                    <td colspan="8" class="p-0">
                      <details class="w-full">
                        <summary class="cursor-pointer list-none hover:bg-paper-sunk transition-colors">
                          <div class="grid grid-cols-8 items-center w-full">
                            <div class="py-3 pl-6 pr-4 font-mono text-ink">{v.version}</div>
                            <div class="py-3 px-4"><StatusBadge status={v.status} /></div>
                            <div class="py-3 px-4"><AuditBadge verdict={v.verdict} /></div>
                            <div class:list={['py-3 px-4 font-mono font-medium', riskColor(v.riskScore)]}>
                              {v.riskScore !== null ? v.riskScore : '--'}
                            </div>
                            <div class="py-3 px-4">
                              {v.source ? <SourceBadge source={v.source as 'github' | 'upload'} /> : <span class="text-ink-soft text-xs">--</span>}
                            </div>
                            <div class="py-3 px-4 text-right font-mono text-ink-muted tabular-nums">{v.downloadCount.toLocaleString()}</div>
                            <div class="py-3 px-4 text-ink-soft font-mono">{v.retryCount}</div>
                            <div class="py-3 pl-4 pr-6 text-ink-soft">{formatDate(v.createdAt)}</div>
                          </div>
                        </summary>

                        <div class="border-t border-rule bg-paper-sunk px-6 py-5">
                          <div class="flex items-center justify-between mb-4">
                            <p class="text-xs text-ink-soft">
                              Size: <span class="text-ink-muted">{formatBytes(v.compressedSize)}</span>
                              <span class="mx-2 text-rule-strong">|</span>
                              ID: <span class="text-ink-muted font-mono">{v.id}</span>
                            </p>
                            <div class="flex items-center gap-2">
                              <Button
                                variant="secondary"
                                size="sm"
                                data-run-audit
                                data-mode="static"
                                data-plugin-id={encodeURIComponent(plugin.id)}
                                data-version={v.version}
                                title="Static scan only — free, no AI call"
                              >
                                Run static scan
                              </Button>
                              {Object.values(AUDIT_MODELS).map((model) => (
                                <Button
                                  variant="secondary"
                                  size="sm"
                                  data-run-audit={!model.disabled ? '' : undefined}
                                  data-mode="ai"
                                  data-model={model.key}
                                  data-plugin-id={encodeURIComponent(plugin.id)}
                                  data-version={v.version}
                                  disabled={model.disabled}
                                  title={model.disabled
                                    ? `Unavailable: ${model.disabledReason ?? 'disabled'}`
                                    : `${model.description} (${model.estimatedNeurons} neurons)`}
                                >
                                  Run AI: {model.label}{model.key === DEFAULT_AUDIT_MODEL ? ' *' : ''}{model.disabled ? ' (unavailable)' : ''}
                                </Button>
                              ))}
                              {(v.status === 'published' || v.status === 'flagged') && (
                                <Button
                                  variant="destructive"
                                  size="sm"
                                  data-revoke-version
                                  data-plugin-id={encodeURIComponent(plugin.id)}
                                  data-version={v.version}
                                  title="Revoke this version — blocks downloads and surfaces a public tombstone"
                                >
                                  Revoke version
                                </Button>
                              )}
                            </div>
                          </div>

                          <!-- Findings -->
                          {v.findings.length > 0 ? (
                            <div class="mb-4">
                              <p class="text-xs text-ink-soft uppercase tracking-wide font-semibold mb-3">
                                Findings ({v.findings.length})
                              </p>
                              <div class="space-y-2">
                                {v.findings.map(f => (
                                  <div class="rounded-lg border border-rule bg-paper-soft p-3">
                                    <div class="flex items-start gap-2">
                                      <span class:list={['inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium uppercase', severityStyle(f.severity)]}>
                                        {f.severity}
                                      </span>
                                      <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-ink">{f.title}</p>
                                        <p class="text-xs text-ink-muted mt-0.5">{f.description}</p>
                                        <div class="flex items-center gap-2 mt-1.5">
                                          <span class="inline-flex items-center rounded bg-paper-sunk px-1.5 py-0.5 text-[10px] text-ink-soft font-mono">{f.category}</span>
                                          {f.location && (
                                            <span class="text-[10px] text-ink-soft font-mono">{f.location}</span>
                                          )}
                                        </div>
                                      </div>
                                    </div>
                                  </div>
                                ))}
                              </div>
                            </div>
                          ) : (
                            <p class="text-xs text-ink-soft mb-4">No findings recorded.</p>
                          )}

                          <!-- Raw AI Response -->
                          {v.rawResponse && (
                            <div class="mb-4">
                              <p class="text-xs text-ink-soft uppercase tracking-wide font-semibold mb-2">Raw AI Response</p>
                              <pre class="mt-4 p-4 rounded-lg bg-paper-deep text-xs text-ink-muted overflow-x-auto max-h-96 overflow-y-auto whitespace-pre-wrap">{stripCodeFence(v.rawResponse)}</pre>
                            </div>
                          )}

                          <!-- Audit Metadata -->
                          {(v.model || v.promptTokens !== null || v.completionTokens !== null || v.neuronsUsed !== null) && (
                            <div class="flex flex-wrap gap-x-4 gap-y-1 text-[11px] text-ink-soft">
                              {v.model && <span>Model: <span class="text-ink-muted">{v.model}</span></span>}
                              {v.promptTokens !== null && <span>Prompt tokens: <span class="text-ink-muted">{v.promptTokens.toLocaleString()}</span></span>}
                              {v.completionTokens !== null && <span>Completion tokens: <span class="text-ink-muted">{v.completionTokens.toLocaleString()}</span></span>}
                              {v.neuronsUsed !== null && <span>Neurons: <span class="text-ink-muted">{v.neuronsUsed.toLocaleString()}</span></span>}
                            </div>
                          )}
                        </div>
                      </details>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

  </section>

  <script>
document.querySelectorAll('[data-run-audit]').forEach((btn) => {
  btn.addEventListener('click', async () => {
    const el = btn as HTMLButtonElement;
    const pluginId = el.dataset.pluginId;
    const version = el.dataset.version;
    const mode = el.dataset.mode as 'static' | 'ai';
    const model = el.dataset.model;
    if (!pluginId || !version || !mode) return;
    const label =
      mode === 'ai'
        ? `AI audit (${model ?? 'default'}, uses neuron budget)`
        : 'static scan (free)';
    if (!confirm(`Re-run ${decodeURIComponent(pluginId)}@${version} with ${label}?`)) return;
    const original = el.textContent;
    el.disabled = true;
    el.textContent = 'Queuing...';
    const payload =
      mode === 'ai' && model ? { version, mode, model } : { version, mode };
    const res = await fetch(`/api/v1/admin/plugins/${pluginId}/run-audit`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (res.ok) {
      window.location.reload();
    } else {
      const body = await res.json().catch(() => ({ error: 'Unknown error' })) as { error: string };
      alert(`Failed: ${body.error}`);
      el.disabled = false;
      el.textContent = original;
    }
  });
});

document.querySelectorAll('[data-revoke-version]').forEach((btn) => {
  btn.addEventListener('click', async () => {
    const el = btn as HTMLButtonElement;
    const pluginId = el.dataset.pluginId;
    const version = el.dataset.version;
    if (!pluginId || !version) return;
    const reason = prompt(
      `Revoke ${decodeURIComponent(pluginId)}@${version}?\n\nReason (required, visible to author; may be surfaced publicly):`,
    );
    if (reason === null) return;
    if (reason.trim().length < 5) {
      alert('Reason must be at least 5 characters.');
      return;
    }
    const original = el.textContent;
    el.disabled = true;
    el.textContent = 'Revoking...';
    const res = await fetch(`/api/v1/admin/plugins/${pluginId}/revoke-version`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ version, reason: reason.trim() }),
    });
    if (res.ok) {
      window.location.reload();
    } else {
      const body = await res.json().catch(() => ({ error: 'Unknown error' })) as { error: string };
      alert(`Failed: ${body.error}`);
      el.disabled = false;
      el.textContent = original;
    }
  });
});

document.querySelectorAll('[data-admin-action]').forEach((form) => {
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const el = e.currentTarget as HTMLFormElement;
    const action = el.dataset.adminAction;
    const pluginId = el.dataset.pluginId;
    if (!pluginId) return;
    if (action === 'delete' && !confirm(`Permanently delete "${pluginId}"? This cannot be undone.`)) return;
    if (action === 'revoke' && !confirm(`Revoke "${pluginId}"? It will be hidden from public listings.`)) return;
    const url = action === 'delete'
      ? `/api/v1/admin/plugins/${pluginId}`
      : `/api/v1/admin/plugins/${pluginId}/${action}`;
    const method = action === 'delete' ? 'DELETE' : 'POST';
    const res = await fetch(url, { method });
    if (res.ok) {
      window.location.reload();
    } else {
      const body = await res.json().catch(() => ({ error: 'Unknown error' })) as { error: string };
      alert(`Failed: ${body.error}`);
    }
  });
});
</script>
</BaseLayout>
