---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import StatusBadge from '../../../../components/StatusBadge.astro';
import AuditBadge from '../../../../components/AuditBadge.astro';
import SourceBadge from '../../../../components/SourceBadge.astro';
import { isSuperAdmin } from '../../../../lib/auth/admin';
import { getAdminPluginDetail, getAdminPluginVersions } from '../../../../lib/db/admin-queries';

const author = Astro.locals.author;
if (!author || !isSuperAdmin(author.githubId)) {
  return Astro.redirect('/dashboard', 302);
}

const pluginId = Astro.params.id;
if (!pluginId) {
  return Astro.redirect('/dashboard/admin', 302);
}

const plugin = await getAdminPluginDetail(env.DB, pluginId);
if (!plugin) {
  return Astro.redirect('/dashboard/admin', 302);
}

const versions = await getAdminPluginVersions(env.DB, pluginId);

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'short', year: 'numeric',
  });

const formatBytes = (bytes: number) => {
  if (bytes === 0) return '0 B';
  const k = 1024;
  const sizes = ['B', 'KB', 'MB'];
  const i = Math.floor(Math.log(bytes) / Math.log(k));
  return `${parseFloat((bytes / Math.pow(k, i)).toFixed(1))} ${sizes[i]}`;
};

const riskColor = (score: number | null) => {
  if (score === null) return 'text-zinc-500';
  if (score <= 33) return 'text-emerald-400';
  if (score <= 66) return 'text-amber-400';
  return 'text-red-400';
};

const severityStyle = (severity: string) => {
  const s = severity.toLowerCase();
  if (s === 'critical' || s === 'high') return 'bg-red-950/40 text-red-400';
  if (s === 'medium') return 'bg-amber-950/40 text-amber-400';
  return 'bg-zinc-800 text-zinc-400';
};
---
<BaseLayout title={`${plugin.name} - Admin - emdashcms.org`}>
  <section class="pt-24 pb-16 px-6">
    <div class="mx-auto max-w-6xl">

      <!-- Breadcrumb -->
      <nav class="mb-6 flex items-center gap-2 text-sm text-zinc-500">
        <a href="/dashboard/admin" class="hover:text-zinc-300 transition-colors">Admin</a>
        <span>/</span>
        <a href="/dashboard/admin" class="hover:text-zinc-300 transition-colors">Plugins</a>
        <span>/</span>
        <span class="text-zinc-300">{plugin.name}</span>
      </nav>

      <!-- Header -->
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <div>
          <div class="flex items-center gap-3">
            <h1 class="text-3xl font-semibold tracking-tight text-zinc-100">{plugin.name}</h1>
            {plugin.status === 'active' ? (
              <span class="inline-flex items-center rounded-full bg-emerald-950/50 border border-emerald-800/40 px-2 py-0.5 text-[11px] text-emerald-400 font-medium">Active</span>
            ) : (
              <span class="inline-flex items-center rounded-full bg-red-950/50 border border-red-800/40 px-2 py-0.5 text-[11px] text-red-400 font-medium">Revoked</span>
            )}
          </div>
          <p class="text-xs text-zinc-500 font-mono mt-1">{plugin.id}</p>
        </div>
        <div class="flex items-center gap-2">
          {plugin.status === 'active' ? (
            <form method="POST" data-admin-action="revoke" data-plugin-id={plugin.id}>
              <button type="submit" class="rounded-lg border border-amber-800/60 bg-amber-950/40 px-4 py-2 text-sm font-medium text-amber-400 hover:bg-amber-950/60 transition-colors">Revoke</button>
            </form>
          ) : (
            <form method="POST" data-admin-action="restore" data-plugin-id={plugin.id}>
              <button type="submit" class="rounded-lg border border-emerald-800/60 bg-emerald-950/40 px-4 py-2 text-sm font-medium text-emerald-400 hover:bg-emerald-950/60 transition-colors">Restore</button>
            </form>
          )}
          <form method="POST" data-admin-action="delete" data-plugin-id={plugin.id}>
            <button type="submit" class="rounded-lg border border-red-800/60 bg-red-950/40 px-4 py-2 text-sm font-medium text-red-400 hover:bg-red-950/60 transition-colors">Delete</button>
          </form>
        </div>
      </div>

      <!-- Info Card -->
      <div class="rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-6 mb-10">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-5">

          <!-- Author -->
          <div>
            <p class="text-xs text-zinc-500 uppercase tracking-wide font-semibold mb-1">Author</p>
            <a href={`/dashboard/admin/authors/${plugin.authorId}`} class="inline-flex items-center gap-2 text-zinc-100 hover:text-white transition-colors">
              {plugin.authorAvatarUrl ? (
                <img src={plugin.authorAvatarUrl} alt={plugin.authorUsername} class="w-5 h-5 rounded-full" />
              ) : (
                <div class="w-5 h-5 rounded-full bg-zinc-700" />
              )}
              <span class="font-medium">{plugin.authorUsername}</span>
            </a>
          </div>

          <!-- Category -->
          <div>
            <p class="text-xs text-zinc-500 uppercase tracking-wide font-semibold mb-1">Category</p>
            <p class="text-zinc-400">{plugin.category ?? 'Uncategorized'}</p>
          </div>

          <!-- Description -->
          <div class="md:col-span-2">
            <p class="text-xs text-zinc-500 uppercase tracking-wide font-semibold mb-1">Description</p>
            <p class="text-zinc-400">{plugin.description ?? 'No description provided.'}</p>
          </div>

          <!-- License -->
          <div>
            <p class="text-xs text-zinc-500 uppercase tracking-wide font-semibold mb-1">License</p>
            <p class="text-zinc-400">{plugin.license ?? 'Not specified'}</p>
          </div>

          <!-- Install Count -->
          <div>
            <p class="text-xs text-zinc-500 uppercase tracking-wide font-semibold mb-1">Installs</p>
            <p class="text-zinc-400">{plugin.installCount.toLocaleString()}</p>
          </div>

          <!-- Capabilities -->
          {plugin.capabilities.length > 0 && (
            <div class="md:col-span-2">
              <p class="text-xs text-zinc-500 uppercase tracking-wide font-semibold mb-2">Capabilities</p>
              <div class="flex flex-wrap gap-1.5">
                {plugin.capabilities.map(cap => (
                  <span class="inline-flex items-center rounded-full bg-zinc-800/60 border border-zinc-700/60 px-2.5 py-0.5 text-xs font-medium text-zinc-300">{cap}</span>
                ))}
              </div>
            </div>
          )}

          <!-- Repository URL -->
          {plugin.repositoryUrl && (
            <div>
              <p class="text-xs text-zinc-500 uppercase tracking-wide font-semibold mb-1">Repository</p>
              <a href={plugin.repositoryUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-400 hover:text-white transition-colors break-all">{plugin.repositoryUrl}</a>
            </div>
          )}

          <!-- Homepage URL -->
          {plugin.homepageUrl && (
            <div>
              <p class="text-xs text-zinc-500 uppercase tracking-wide font-semibold mb-1">Homepage</p>
              <a href={plugin.homepageUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-400 hover:text-white transition-colors break-all">{plugin.homepageUrl}</a>
            </div>
          )}

          <!-- GitHub Link Info -->
          {plugin.githubRepoFullName && (
            <div class="md:col-span-2 rounded-lg border border-zinc-800/40 bg-zinc-950/40 p-4 mt-2">
              <p class="text-xs text-zinc-500 uppercase tracking-wide font-semibold mb-3">GitHub Link</p>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
                <div>
                  <p class="text-zinc-500 text-xs mb-0.5">Repository</p>
                  <a href={`https://github.com/${plugin.githubRepoFullName}`} target="_blank" rel="noopener noreferrer" class="text-zinc-300 hover:text-white font-mono text-xs transition-colors">{plugin.githubRepoFullName}</a>
                </div>
                <div>
                  <p class="text-zinc-500 text-xs mb-0.5">Auto Submit</p>
                  <p class="text-zinc-300 text-xs">{plugin.githubAutoSubmit ? 'Yes' : 'No'}</p>
                </div>
                {plugin.githubTagPattern && (
                  <div>
                    <p class="text-zinc-500 text-xs mb-0.5">Tag Pattern</p>
                    <p class="text-zinc-300 font-mono text-xs">{plugin.githubTagPattern}</p>
                  </div>
                )}
              </div>
            </div>
          )}

          <!-- Dates -->
          <div>
            <p class="text-xs text-zinc-500 uppercase tracking-wide font-semibold mb-1">Created</p>
            <p class="text-zinc-400">{formatDate(plugin.createdAt)}</p>
          </div>
          <div>
            <p class="text-xs text-zinc-500 uppercase tracking-wide font-semibold mb-1">Updated</p>
            <p class="text-zinc-400">{formatDate(plugin.updatedAt)}</p>
          </div>

        </div>
      </div>

      <!-- Versions -->
      <div>
        <h2 class="text-xl font-semibold text-zinc-100 mb-4">Versions ({versions.length})</h2>
        {versions.length === 0 ? (
          <p class="text-sm text-zinc-400">No versions submitted yet.</p>
        ) : (
          <div class="rounded-xl border border-zinc-800/60 bg-zinc-900/40 overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-zinc-800 text-left">
                  <th class="pb-3 pl-6 pr-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Version</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Status</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Verdict</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Risk Score</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Source</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Retries</th>
                  <th class="pb-3 pl-4 pr-6 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Date</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-zinc-800/60">
                {versions.map(v => (
                  <tr class="group">
                    <td colspan="7" class="p-0">
                      <details class="w-full">
                        <summary class="cursor-pointer list-none hover:bg-zinc-900/30 transition-colors">
                          <div class="grid grid-cols-7 items-center w-full">
                            <div class="py-3 pl-6 pr-4 font-mono text-zinc-100">{v.version}</div>
                            <div class="py-3 px-4"><StatusBadge status={v.status} /></div>
                            <div class="py-3 px-4"><AuditBadge verdict={v.verdict} /></div>
                            <div class:list={['py-3 px-4 font-mono font-medium', riskColor(v.riskScore)]}>
                              {v.riskScore !== null ? v.riskScore : '--'}
                            </div>
                            <div class="py-3 px-4">
                              {v.source ? <SourceBadge source={v.source as 'github' | 'upload'} /> : <span class="text-zinc-500 text-xs">--</span>}
                            </div>
                            <div class="py-3 px-4 text-zinc-500 font-mono">{v.retryCount}</div>
                            <div class="py-3 pl-4 pr-6 text-zinc-500">{formatDate(v.createdAt)}</div>
                          </div>
                        </summary>

                        <div class="border-t border-zinc-800/40 bg-zinc-950/30 px-6 py-5">
                          <div class="flex items-center justify-between mb-4">
                            <p class="text-xs text-zinc-500">
                              Size: <span class="text-zinc-400">{formatBytes(v.compressedSize)}</span>
                              <span class="mx-2 text-zinc-700">|</span>
                              ID: <span class="text-zinc-400 font-mono">{v.id}</span>
                            </p>
                            <button
                              type="button"
                              data-retry-audit
                              data-plugin-id={plugin.id}
                              data-version={v.version}
                              class="rounded-lg border border-amber-800/60 bg-amber-950/40 px-3 py-1.5 text-xs font-medium text-amber-400 hover:bg-amber-950/60 transition-colors"
                            >
                              Re-audit
                            </button>
                          </div>

                          <!-- Findings -->
                          {v.findings.length > 0 ? (
                            <div class="mb-4">
                              <p class="text-xs text-zinc-500 uppercase tracking-wide font-semibold mb-3">
                                Findings ({v.findings.length})
                              </p>
                              <div class="space-y-2">
                                {v.findings.map(f => (
                                  <div class="rounded-lg border border-zinc-800/40 bg-zinc-900/30 p-3">
                                    <div class="flex items-start gap-2">
                                      <span class:list={['inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium uppercase', severityStyle(f.severity)]}>
                                        {f.severity}
                                      </span>
                                      <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-zinc-200">{f.title}</p>
                                        <p class="text-xs text-zinc-400 mt-0.5">{f.description}</p>
                                        <div class="flex items-center gap-2 mt-1.5">
                                          <span class="inline-flex items-center rounded bg-zinc-800/60 px-1.5 py-0.5 text-[10px] text-zinc-500 font-mono">{f.category}</span>
                                          {f.location && (
                                            <span class="text-[10px] text-zinc-600 font-mono">{f.location}</span>
                                          )}
                                        </div>
                                      </div>
                                    </div>
                                  </div>
                                ))}
                              </div>
                            </div>
                          ) : (
                            <p class="text-xs text-zinc-500 mb-4">No findings recorded.</p>
                          )}

                          <!-- Raw AI Response -->
                          {v.rawResponse && (
                            <div class="mb-4">
                              <p class="text-xs text-zinc-500 uppercase tracking-wide font-semibold mb-2">Raw AI Response</p>
                              <pre class="mt-4 p-4 rounded-lg bg-zinc-950 text-xs text-zinc-400 overflow-x-auto max-h-96 overflow-y-auto whitespace-pre-wrap">{v.rawResponse}</pre>
                            </div>
                          )}

                          <!-- Audit Metadata -->
                          {(v.model || v.promptTokens !== null || v.completionTokens !== null || v.neuronsUsed !== null) && (
                            <div class="flex flex-wrap gap-x-4 gap-y-1 text-[11px] text-zinc-600">
                              {v.model && <span>Model: <span class="text-zinc-500">{v.model}</span></span>}
                              {v.promptTokens !== null && <span>Prompt tokens: <span class="text-zinc-500">{v.promptTokens.toLocaleString()}</span></span>}
                              {v.completionTokens !== null && <span>Completion tokens: <span class="text-zinc-500">{v.completionTokens.toLocaleString()}</span></span>}
                              {v.neuronsUsed !== null && <span>Neurons: <span class="text-zinc-500">{v.neuronsUsed.toLocaleString()}</span></span>}
                            </div>
                          )}
                        </div>
                      </details>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

    </div>
  </section>

  <script>
    document.querySelectorAll('[data-retry-audit]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const el = btn as HTMLButtonElement;
        const pluginId = el.dataset.pluginId;
        const version = el.dataset.version;
        if (!pluginId || !version) return;

        if (!confirm(`Re-audit ${pluginId}@${version}? This will re-queue the AI audit.`)) return;

        el.disabled = true;
        el.textContent = 'Queuing...';

        const res = await fetch(`/api/v1/admin/plugins/${pluginId}/retry-audit`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ version }),
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const body = await res.json().catch(() => ({ error: 'Unknown error' })) as { error: string };
          alert(`Failed: ${body.error}`);
          el.disabled = false;
          el.textContent = 'Re-audit';
        }
      });
    });

    document.querySelectorAll('[data-admin-action]').forEach(form => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const el = e.currentTarget as HTMLFormElement;
        const action = el.dataset.adminAction;
        const pluginId = el.dataset.pluginId;
        if (!pluginId) return;

        if (action === 'delete' && !confirm(`Permanently delete "${pluginId}"? This cannot be undone.`)) return;
        if (action === 'revoke' && !confirm(`Revoke "${pluginId}"? It will be hidden from public listings.`)) return;

        const url = action === 'delete'
          ? `/api/v1/admin/plugins/${pluginId}`
          : `/api/v1/admin/plugins/${pluginId}/${action}`;

        const method = action === 'delete' ? 'DELETE' : 'POST';

        const res = await fetch(url, { method });
        if (res.ok) {
          window.location.reload();
        } else {
          const body = await res.json().catch(() => ({ error: 'Unknown error' })) as { error: string };
          alert(`Failed: ${body.error}`);
        }
      });
    });
  </script>
</BaseLayout>
