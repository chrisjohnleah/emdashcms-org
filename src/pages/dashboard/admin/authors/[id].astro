---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { isSuperAdmin } from '../../../../lib/auth/admin';
import {
  getAdminAuthorDetail,
  getAuthorPlugins,
  getAuthorThemes,
  getAuthorSubmissionStats,
} from '../../../../lib/db/admin-queries';

const author = Astro.locals.author;
if (!author || !isSuperAdmin(author.githubId)) {
  return Astro.redirect('/dashboard', 302);
}

const { id } = Astro.params;
if (!id) return Astro.redirect('/dashboard/admin', 302);

const detail = await getAdminAuthorDetail(env.DB, id);
if (!detail) return new Response('Author not found', { status: 404 });

const [plugins, themes, stats] = await Promise.all([
  getAuthorPlugins(env.DB, id),
  getAuthorThemes(env.DB, id),
  getAuthorSubmissionStats(env.DB, id),
]);

const rejectionRate = stats.total > 0
  ? ((stats.rejected / stats.total) * 100).toFixed(1)
  : null;

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'short', year: 'numeric',
  });
---
<BaseLayout title={`${detail.githubUsername} - Admin - emdashcms.org`}>
  <section class="page pt-12 pb-16 md:pt-16">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-ink-soft mb-8">
        <a href="/dashboard/admin" class="hover:text-ink transition-colors">Admin</a>
        <span class="text-rule-strong">/</span>
        <span class="text-ink-soft">Authors</span>
        <span class="text-rule-strong">/</span>
        <span class="text-ink-muted">{detail.githubUsername}</span>
      </nav>

      <!-- Header -->
      <div class="flex items-center gap-4 mb-10">
        {detail.avatarUrl ? (
          <img
            src={detail.avatarUrl}
            alt={detail.githubUsername}
            class="w-10 h-10 rounded-full"
          />
        ) : (
          <div class="w-10 h-10 rounded-full bg-paper-deep" />
        )}
        <div>
          <div class="flex items-center gap-3">
            <a
              href={`https://github.com/${detail.githubUsername}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-2xl font-semibold text-ink hover:underline transition-colors"
            >
              {detail.githubUsername}
            </a>
            <span class="text-xs text-ink-soft font-mono">{detail.githubId}</span>
          </div>
          <p class="text-sm text-ink-soft mt-0.5">Joined {formatDate(detail.createdAt)}</p>
        </div>
      </div>

      <!-- Submission Stats -->
      <div class="mb-10">
        <h2 class="text-lg text-ink mb-4">Submission Stats</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
          <div class="rounded-xl border border-rule bg-paper-soft p-5">
            <p class="text-2xl font-bold text-ink">{stats.total}</p>
            <p class="text-xs text-ink-soft mt-1">Total Versions</p>
          </div>
          <div class="rounded-xl border border-success/30 bg-success-soft p-5">
            <p class="text-2xl font-bold text-success">{stats.published}</p>
            <p class="text-xs text-ink-soft mt-1">Published</p>
          </div>
          <div class="rounded-xl border border-danger/35 bg-danger-soft p-5">
            <p class="text-2xl font-bold text-danger">{stats.rejected}</p>
            <p class="text-xs text-ink-soft mt-1">Rejected</p>
          </div>
          <div class="rounded-xl border border-warn/35 bg-warn-soft p-5">
            <p class="text-2xl font-bold text-warn">{stats.flagged}</p>
            <p class="text-xs text-ink-soft mt-1">Flagged</p>
          </div>
          <div class="rounded-xl border border-rule bg-paper-soft p-5">
            <p class="text-2xl font-bold text-ink-muted">{stats.pending}</p>
            <p class="text-xs text-ink-soft mt-1">Pending</p>
          </div>
        </div>
        {rejectionRate && (
          <p class="text-xs text-ink-soft mt-3">
            Rejection rate: <span class="text-danger font-medium">{rejectionRate}%</span>
          </p>
        )}
      </div>

      <!-- Plugins Table -->
      <div class="mb-12">
        <h2 class="text-lg text-ink mb-4">
          Plugins <span class="text-ink-soft font-normal text-sm">({plugins.length})</span>
        </h2>
        {plugins.length === 0 ? (
          <div class="rounded-xl border border-rule bg-paper-soft p-8 text-center">
            <p class="text-sm text-ink-muted">No plugins registered by this author.</p>
          </div>
        ) : (
          <div class="rounded-xl border border-rule bg-paper-soft overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-rule text-left">
                  <th class="pb-3 pl-6 pr-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Plugin Name</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Status</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Versions</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Rejected</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Installs</th>
                  <th class="pb-3 pl-4 pr-6 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Created</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-rule">
                {plugins.map(plugin => (
                  <tr class="hover:bg-paper-sunk transition-colors">
                    <td class="py-3 pl-6 pr-4">
                      <a
                        href={`/dashboard/admin/plugins/${encodeURIComponent(plugin.id)}`}
                        class="text-ink hover:underline font-medium transition-colors"
                      >
                        {plugin.name}
                      </a>
                    </td>
                    <td class="py-3 px-4">
                      {plugin.status === 'active' ? (
                        <span class="inline-flex items-center rounded-full bg-success-soft border border-success/30 px-2 py-0.5 text-[11px] text-success font-medium">Active</span>
                      ) : (
                        <span class="inline-flex items-center rounded-full bg-danger-soft border border-danger/35 px-2 py-0.5 text-[11px] text-danger font-medium">Revoked</span>
                      )}
                    </td>
                    <td class="py-3 px-4 text-ink-soft font-mono">{plugin.versionCount}</td>
                    <td class="py-3 px-4 text-ink-soft font-mono">{plugin.rejectedCount}</td>
                    <td class="py-3 px-4 text-ink-soft">{plugin.installCount.toLocaleString()}</td>
                    <td class="py-3 pl-4 pr-6 text-ink-soft">{formatDate(plugin.createdAt)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

      <!-- Themes Table -->
      <div>
        <h2 class="text-lg text-ink mb-4">
          Themes <span class="text-ink-soft font-normal text-sm">({themes.length})</span>
        </h2>
        {themes.length === 0 ? (
          <div class="rounded-xl border border-rule bg-paper-soft p-8 text-center">
            <p class="text-sm text-ink-muted">No themes registered by this author.</p>
          </div>
        ) : (
          <div class="rounded-xl border border-rule bg-paper-soft overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-rule text-left">
                  <th class="pb-3 pl-6 pr-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Theme Name</th>
                  <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Description</th>
                  <th class="pb-3 pl-4 pr-6 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Created</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-rule">
                {themes.map(theme => (
                  <tr class="hover:bg-paper-sunk transition-colors">
                    <td class="py-3 pl-6 pr-4 text-ink font-medium">{theme.name}</td>
                    <td class="py-3 px-4 text-ink-muted max-w-xs truncate">{theme.description ?? '--'}</td>
                    <td class="py-3 pl-4 pr-6 text-ink-soft">{formatDate(theme.createdAt)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

  </section>
</BaseLayout>
