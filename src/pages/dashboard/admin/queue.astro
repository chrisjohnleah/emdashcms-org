---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import StatusBadge from '../../../components/StatusBadge.astro';
import AuditBadge from '../../../components/AuditBadge.astro';
import SourceBadge from '../../../components/SourceBadge.astro';
import { isSuperAdmin } from '../../../lib/auth/admin';
import { getModerationQueue } from '../../../lib/db/admin-queries';

const author = Astro.locals.author;
if (!author || !isSuperAdmin(author.githubId)) {
  return Astro.redirect('/dashboard', 302);
}

const queue = await getModerationQueue(env.DB);

const statusFilter = Astro.url.searchParams.get('status');
const filtered = statusFilter
  ? queue.filter((item) => item.status === statusFilter)
  : queue;

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'short', year: 'numeric',
  });

const riskColor = (score: number | null) => {
  if (score === null) return 'text-zinc-500';
  if (score <= 33) return 'text-emerald-400';
  if (score <= 66) return 'text-amber-400';
  return 'text-red-400';
};

type Tab = { label: string; value: string | null };
const tabs: Tab[] = [
  { label: 'All', value: null },
  { label: 'Pending', value: 'pending' },
  { label: 'Flagged', value: 'flagged' },
  { label: 'Rejected', value: 'rejected' },
];
---
<BaseLayout title="Moderation Queue - Admin - emdashcms.org">
  <section class="pt-24 pb-16 px-6">
    <div class="mx-auto max-w-6xl">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-zinc-500 mb-6" aria-label="Breadcrumb">
        <a href="/dashboard/admin" class="hover:text-zinc-300 transition-colors">Admin</a>
        <span aria-hidden="true">/</span>
        <span class="text-zinc-300">Moderation Queue</span>
      </nav>

      <!-- Header -->
      <div class="flex items-center gap-3 mb-8">
        <h1 class="text-3xl font-semibold tracking-tight text-zinc-100">Moderation Queue</h1>
        <span class="rounded-full bg-zinc-800/60 border border-zinc-700/60 px-2.5 py-0.5 text-[11px] text-zinc-400 font-medium tabular-nums">
          {filtered.length}
        </span>
      </div>

      <!-- Filter tabs -->
      <div class="flex items-center gap-2 mb-6" role="tablist">
        {tabs.map((tab) => {
          const isActive = statusFilter === tab.value;
          const href = tab.value
            ? `?status=${tab.value}`
            : Astro.url.pathname;
          return (
            <a
              href={href}
              role="tab"
              aria-selected={isActive}
              class:list={[
                'rounded-lg px-3 py-1.5 text-sm font-medium transition-colors',
                isActive
                  ? 'bg-zinc-100 text-zinc-950'
                  : 'bg-zinc-800 text-zinc-400 hover:text-zinc-200',
              ]}
            >
              {tab.label}
            </a>
          );
        })}
      </div>

      <!-- Queue table -->
      {filtered.length === 0 ? (
        <div class="rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-12 text-center">
          <p class="text-sm text-zinc-400">Nothing needs attention right now.</p>
        </div>
      ) : (
        <div class="rounded-xl border border-zinc-800/60 bg-zinc-900/40 overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-zinc-800 text-left">
                <th class="pb-3 pl-6 pr-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Plugin</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Version</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Status</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Verdict</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Risk Score</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Author</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Source</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide">Submitted</th>
                <th class="pb-3 pl-4 pr-6 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide text-right">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-800/60">
              {filtered.map((item) => (
                <tr class="hover:bg-zinc-900/30 transition-colors">
                  <td class="py-3 pl-6 pr-4">
                    <a
                      href={`/dashboard/admin/plugins/${encodeURIComponent(item.pluginId)}`}
                      class="text-zinc-100 hover:text-white font-medium transition-colors"
                    >
                      {item.pluginName}
                    </a>
                  </td>
                  <td class="py-3 px-4 text-zinc-400 font-mono text-xs">{item.version}</td>
                  <td class="py-3 px-4">
                    <StatusBadge status={item.status} />
                  </td>
                  <td class="py-3 px-4">
                    <AuditBadge verdict={item.verdict} />
                  </td>
                  <td class="py-3 px-4">
                    <span class:list={['font-mono text-xs tabular-nums', riskColor(item.riskScore)]}>
                      {item.riskScore !== null ? item.riskScore : '\u2014'}
                    </span>
                  </td>
                  <td class="py-3 px-4">
                    <a
                      href={`/dashboard/admin/authors/${item.authorId}`}
                      class="text-zinc-400 hover:text-zinc-200 transition-colors"
                    >
                      {item.authorUsername}
                    </a>
                  </td>
                  <td class="py-3 px-4">
                    {item.source ? <SourceBadge source={item.source as 'github' | 'upload'} /> : <span class="text-zinc-500">{'\u2014'}</span>}
                  </td>
                  <td class="py-3 px-4 text-zinc-500">{formatDate(item.createdAt)}</td>
                  <td class="py-3 pl-4 pr-6">
                    {(item.status === 'pending' || item.status === 'flagged') ? (
                      <div class="flex items-center justify-end gap-1.5">
                        <button
                          type="button"
                          data-approve-version
                          data-plugin-id={encodeURIComponent(item.pluginId)}
                          data-version={item.version}
                          class="rounded-md border border-emerald-800/60 bg-emerald-950/40 px-2.5 py-1 text-[11px] font-medium text-emerald-300 hover:bg-emerald-950/60 transition-colors cursor-pointer"
                        >
                          Approve
                        </button>
                        <button
                          type="button"
                          data-reject-version
                          data-plugin-id={encodeURIComponent(item.pluginId)}
                          data-version={item.version}
                          class="rounded-md border border-red-800/60 bg-red-950/40 px-2.5 py-1 text-[11px] font-medium text-red-300 hover:bg-red-950/60 transition-colors cursor-pointer"
                        >
                          Reject
                        </button>
                      </div>
                    ) : (
                      <span class="block text-right text-zinc-600 text-[11px]">{'\u2014'}</span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

    </div>
  </section>

  <script>
    async function callAdminAction(
      url: string,
      body: Record<string, unknown>,
      btn: HTMLButtonElement,
      busyLabel: string,
    ) {
      const original = btn.textContent;
      btn.disabled = true;
      btn.textContent = busyLabel;
      try {
        const res = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (res.ok) {
          window.location.reload();
        } else {
          const data = (await res.json().catch(() => ({ error: 'Unknown error' }))) as { error: string };
          alert(`Failed: ${data.error}`);
          btn.disabled = false;
          btn.textContent = original;
        }
      } catch (err) {
        alert(`Network error: ${err instanceof Error ? err.message : String(err)}`);
        btn.disabled = false;
        btn.textContent = original;
      }
    }

    document.querySelectorAll('[data-approve-version]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const el = btn as HTMLButtonElement;
        const pluginId = el.dataset.pluginId;
        const version = el.dataset.version;
        if (!pluginId || !version) return;
        if (!confirm(`Approve ${decodeURIComponent(pluginId)}@${version} and publish?`)) return;
        await callAdminAction(
          `/api/v1/admin/plugins/${pluginId}/approve-version`,
          { version },
          el,
          'Approving...',
        );
      });
    });

    document.querySelectorAll('[data-reject-version]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const el = btn as HTMLButtonElement;
        const pluginId = el.dataset.pluginId;
        const version = el.dataset.version;
        if (!pluginId || !version) return;
        const reason = prompt(`Reject ${decodeURIComponent(pluginId)}@${version}?\n\nOptional reason (visible to publisher):`);
        if (reason === null) return; // user cancelled
        await callAdminAction(
          `/api/v1/admin/plugins/${pluginId}/reject-version`,
          { version, reason: reason || undefined },
          el,
          'Rejecting...',
        );
      });
    });
  </script>
</BaseLayout>
