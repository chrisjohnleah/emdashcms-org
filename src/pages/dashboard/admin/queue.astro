---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import StatusBadge from '../../../components/StatusBadge.astro';
import AuditBadge from '../../../components/AuditBadge.astro';
import SourceBadge from '../../../components/SourceBadge.astro';
import { isSuperAdmin } from '../../../lib/auth/admin';
import { getModerationQueue } from '../../../lib/db/admin-queries';
import { AUDIT_MODELS, DEFAULT_AUDIT_MODEL } from '../../../lib/audit/prompt';

const author = Astro.locals.author;
if (!author || !isSuperAdmin(author.githubId)) {
  return Astro.redirect('/dashboard', 302);
}

const queue = await getModerationQueue(env.DB);
const auditMode = (env.AUDIT_MODE as 'manual' | 'auto' | 'off' | undefined) ?? 'manual';
const auditModeBlurb: Record<string, string> = {
  manual: 'Manual mode — every upload lands here for human review. AI is skipped by default.',
  auto: 'Auto mode — AI audit runs on every upload, neuron-budget bound. Failures still land here.',
  off: 'Off — AI is disabled. Static scan only. Every upload lands here.',
};
const auditModeStyle: Record<string, string> = {
  manual: 'border-warn/35 bg-warn-soft text-warn',
  auto: 'border-success/30 bg-success-soft text-success',
  off: 'border-rule bg-paper-soft text-ink-muted',
};

const statusFilter = Astro.url.searchParams.get('status');
const filtered = statusFilter
  ? queue.filter((item) => item.status === statusFilter)
  : queue;

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'short', year: 'numeric',
  });

const riskColor = (score: number | null) => {
  if (score === null) return 'text-ink-soft';
  if (score <= 33) return 'text-success';
  if (score <= 66) return 'text-warn';
  return 'text-danger';
};

type Tab = { label: string; value: string | null };
const tabs: Tab[] = [
  { label: 'All', value: null },
  { label: 'Pending', value: 'pending' },
  { label: 'Flagged', value: 'flagged' },
  { label: 'Rejected', value: 'rejected' },
];
---
<BaseLayout title="Moderation Queue - Admin - emdashcms.org">
  <section class="page pt-12 pb-16 md:pt-16">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-ink-soft mb-6" aria-label="Breadcrumb">
        <a href="/dashboard/admin" class="hover:text-ink transition-colors">Admin</a>
        <span aria-hidden="true">/</span>
        <span class="text-ink-muted">Moderation Queue</span>
      </nav>

      <!-- Header -->
      <div class="flex items-center gap-3 mb-4">
        <h1 class="text-3xl text-ink">Moderation Queue</h1>
        <span class="rounded-full bg-paper-sunk border border-rule-strong px-2.5 py-0.5 text-[11px] text-ink-muted font-medium tabular-nums">
          {filtered.length}
        </span>
      </div>

      <!-- Audit mode indicator -->
      <div class:list={['mb-8 rounded-lg border px-4 py-3 text-xs', auditModeStyle[auditMode]]}>
        <span class="font-semibold uppercase tracking-wide">Audit mode: {auditMode}</span>
        <span class="ml-2 opacity-80">{auditModeBlurb[auditMode]}</span>
      </div>

      <!-- Filter tabs -->
      <div class="flex items-center gap-2 mb-6" role="tablist">
        {tabs.map((tab) => {
          const isActive = statusFilter === tab.value;
          const href = tab.value
            ? `?status=${tab.value}`
            : Astro.url.pathname;
          return (
            <a
              href={href}
              role="tab"
              aria-selected={isActive}
              class:list={[
                'rounded-lg px-3 py-1.5 text-sm font-medium transition-colors',
                isActive
                  ? 'bg-ink text-paper'
                  : 'bg-paper-sunk text-ink-muted hover:text-ink',
              ]}
            >
              {tab.label}
            </a>
          );
        })}
      </div>

      <!-- Queue table -->
      {filtered.length === 0 ? (
        <div class="rounded-xl border border-rule bg-paper-soft p-12 text-center">
          <p class="text-sm text-ink-muted">Nothing needs attention right now.</p>
        </div>
      ) : (
        <div class="rounded-xl border border-rule bg-paper-soft overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-rule text-left">
                <th class="pb-3 pl-6 pr-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Plugin</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Version</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Status</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Verdict</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Risk Score</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Author</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Source</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide">Submitted</th>
                <th class="pb-3 pl-4 pr-6 pt-4 text-xs font-semibold text-ink-soft uppercase tracking-wide text-right">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-rule">
              {filtered.map((item) => (
                <tr class="hover:bg-paper-sunk transition-colors">
                  <td class="py-3 pl-6 pr-4">
                    <a
                      href={`/dashboard/admin/plugins/${encodeURIComponent(item.pluginId)}`}
                      class="text-ink hover:underline font-medium transition-colors"
                    >
                      {item.pluginName}
                    </a>
                  </td>
                  <td class="py-3 px-4 text-ink-muted font-mono text-xs">{item.version}</td>
                  <td class="py-3 px-4">
                    <StatusBadge status={item.status} />
                  </td>
                  <td class="py-3 px-4">
                    <AuditBadge verdict={item.verdict} />
                  </td>
                  <td class="py-3 px-4">
                    <span class:list={['font-mono text-xs tabular-nums', riskColor(item.riskScore)]}>
                      {item.riskScore !== null ? item.riskScore : '\u2014'}
                    </span>
                  </td>
                  <td class="py-3 px-4">
                    <a
                      href={`/dashboard/admin/authors/${item.authorId}`}
                      class="text-ink-muted hover:text-ink transition-colors"
                    >
                      {item.authorUsername}
                    </a>
                  </td>
                  <td class="py-3 px-4">
                    {item.source ? <SourceBadge source={item.source as 'github' | 'upload'} /> : <span class="text-ink-soft">{'\u2014'}</span>}
                  </td>
                  <td class="py-3 px-4 text-ink-soft">{formatDate(item.createdAt)}</td>
                  <td class="py-3 pl-4 pr-6">
                    <div class="flex items-center justify-end gap-1.5 flex-wrap">
                      {(item.status === 'pending' || item.status === 'flagged') && (
                        <>
                          <Button
                            variant="primary"
                            size="sm"
                            data-approve-version
                            data-plugin-id={encodeURIComponent(item.pluginId)}
                            data-version={item.version}
                          >
                            Approve
                          </Button>
                          <Button
                            variant="destructive"
                            size="sm"
                            data-reject-version
                            data-plugin-id={encodeURIComponent(item.pluginId)}
                            data-version={item.version}
                          >
                            Reject
                          </Button>
                        </>
                      )}
                      <Button
                        variant="secondary"
                        size="sm"
                        data-run-audit
                        data-mode="static"
                        data-plugin-id={encodeURIComponent(item.pluginId)}
                        data-version={item.version}
                        title="Static scan only — free"
                      >
                        Static
                      </Button>
                      {Object.values(AUDIT_MODELS).map((model) => (
                        <Button
                          variant="secondary"
                          size="sm"
                          data-run-audit={!model.disabled ? '' : undefined}
                          data-mode="ai"
                          data-model={model.key}
                          data-plugin-id={encodeURIComponent(item.pluginId)}
                          data-version={item.version}
                          disabled={model.disabled}
                          title={model.disabled
                            ? `Unavailable: ${model.disabledReason ?? 'disabled'}`
                            : `${model.description} (${model.estimatedNeurons} neurons)`}
                        >
                          AI: {model.label}{model.key === DEFAULT_AUDIT_MODEL ? ' *' : ''}{model.disabled ? ' (unavailable)' : ''}
                        </Button>
                      ))}
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

  </section>

  <script>
    async function callAdminAction(
      url: string,
      body: Record<string, unknown>,
      btn: HTMLButtonElement,
      busyLabel: string,
    ) {
      const original = btn.textContent;
      btn.disabled = true;
      btn.textContent = busyLabel;
      try {
        const res = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (res.ok) {
          window.location.reload();
        } else {
          const data = (await res.json().catch(() => ({ error: 'Unknown error' }))) as { error: string };
          alert(`Failed: ${data.error}`);
          btn.disabled = false;
          btn.textContent = original;
        }
      } catch (err) {
        alert(`Network error: ${err instanceof Error ? err.message : String(err)}`);
        btn.disabled = false;
        btn.textContent = original;
      }
    }

    document.querySelectorAll('[data-approve-version]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const el = btn as HTMLButtonElement;
        const pluginId = el.dataset.pluginId;
        const version = el.dataset.version;
        if (!pluginId || !version) return;
        if (!confirm(`Approve ${decodeURIComponent(pluginId)}@${version} and publish?`)) return;
        await callAdminAction(
          `/api/v1/admin/plugins/${pluginId}/approve-version`,
          { version },
          el,
          'Approving...',
        );
      });
    });

    document.querySelectorAll('[data-reject-version]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const el = btn as HTMLButtonElement;
        const pluginId = el.dataset.pluginId;
        const version = el.dataset.version;
        if (!pluginId || !version) return;
        const reason = prompt(`Reject ${decodeURIComponent(pluginId)}@${version}?\n\nOptional reason (visible to publisher):`);
        if (reason === null) return; // user cancelled
        await callAdminAction(
          `/api/v1/admin/plugins/${pluginId}/reject-version`,
          { version, reason: reason || undefined },
          el,
          'Rejecting...',
        );
      });
    });

    document.querySelectorAll('[data-run-audit]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const el = btn as HTMLButtonElement;
        const pluginId = el.dataset.pluginId;
        const version = el.dataset.version;
        const mode = el.dataset.mode as 'static' | 'ai';
        const model = el.dataset.model;
        if (!pluginId || !version || !mode) return;
        const label =
          mode === 'ai'
            ? `AI audit (${model ?? 'default'}, uses neuron budget)`
            : 'static scan (free)';
        if (!confirm(`Re-run ${decodeURIComponent(pluginId)}@${version} with ${label}?`)) return;
        await callAdminAction(
          `/api/v1/admin/plugins/${pluginId}/run-audit`,
          mode === 'ai' && model ? { version, mode, model } : { version, mode },
          el,
          mode === 'ai' ? 'Queuing AI...' : 'Queuing...',
        );
      });
    });
  </script>
</BaseLayout>
