---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { isSuperAdmin } from '../../../lib/auth/admin';
import {
  listReports,
  countReportsByStatus,
  type ReportStatus,
} from '../../../lib/db/report-queries';

const author = Astro.locals.author;
if (!author || !isSuperAdmin(author.githubId)) {
  return Astro.redirect('/dashboard', 302);
}

const statusFilter = (Astro.url.searchParams.get('status') as ReportStatus | null) ?? null;
const [reports, counts] = await Promise.all([
  listReports(env.DB, statusFilter ?? undefined),
  countReportsByStatus(env.DB),
]);

type Tab = { label: string; value: ReportStatus | null; count: number };
const tabs: Tab[] = [
  { label: 'All', value: null, count: counts.open + counts.investigating + counts.resolved + counts.dismissed },
  { label: 'Open', value: 'open', count: counts.open },
  { label: 'Investigating', value: 'investigating', count: counts.investigating },
  { label: 'Resolved', value: 'resolved', count: counts.resolved },
  { label: 'Dismissed', value: 'dismissed', count: counts.dismissed },
];

const categoryLabels: Record<string, string> = {
  security: 'Security',
  abuse: 'Abuse',
  broken: 'Broken',
  license: 'License',
  other: 'Other',
};

const categoryStyle: Record<string, string> = {
  security: 'bg-red-950/40 border-red-800/60 text-red-400',
  abuse: 'bg-amber-950/40 border-amber-800/60 text-amber-400',
  broken: 'bg-zinc-900 border-zinc-700 text-zinc-400',
  license: 'bg-blue-950/40 border-blue-800/60 text-blue-400',
  other: 'bg-zinc-900 border-zinc-700 text-zinc-400',
};

const statusStyle: Record<ReportStatus, string> = {
  open: 'bg-amber-950/40 border-amber-800/60 text-amber-400',
  investigating: 'bg-blue-950/40 border-blue-800/60 text-blue-400',
  resolved: 'bg-emerald-950/40 border-emerald-800/60 text-emerald-400',
  dismissed: 'bg-zinc-900 border-zinc-700 text-zinc-500',
};

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---
<BaseLayout title="Reports Queue - Admin - emdashcms.org">
  <section class="pt-24 pb-16 px-6">
    <div class="mx-auto max-w-6xl">

      <nav class="flex items-center gap-2 text-sm text-zinc-500 mb-6" aria-label="Breadcrumb">
        <a href="/dashboard/admin" class="hover:text-zinc-300 transition-colors">Admin</a>
        <span aria-hidden="true">/</span>
        <span class="text-zinc-300">Reports</span>
      </nav>

      <div class="flex items-center gap-3 mb-8">
        <h1 class="text-3xl font-semibold tracking-tight text-zinc-100">Reports queue</h1>
        <span class="rounded-full bg-zinc-800/60 border border-zinc-700/60 px-2.5 py-0.5 text-[11px] text-zinc-400 font-medium tabular-nums">
          {reports.length}
        </span>
      </div>

      <div class="flex gap-2 mb-6 border-b border-zinc-800/60">
        {tabs.map((tab) => {
          const href = tab.value ? `?status=${tab.value}` : '?';
          const active = statusFilter === tab.value;
          return (
            <a
              href={href}
              class:list={[
                'px-4 py-2 text-sm font-medium border-b-2 transition-colors -mb-px',
                active
                  ? 'border-zinc-100 text-zinc-100'
                  : 'border-transparent text-zinc-500 hover:text-zinc-300',
              ]}
            >
              {tab.label}
              <span class="ml-1.5 text-[11px] text-zinc-500 tabular-nums">({tab.count})</span>
            </a>
          );
        })}
      </div>

      {reports.length === 0 ? (
        <div class="rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-12 text-center">
          <p class="text-sm text-zinc-400">No reports in this view.</p>
        </div>
      ) : (
        <div class="space-y-3">
          {reports.map((report) => (
            <div class="rounded-xl border border-zinc-800/60 bg-zinc-900/40 p-5">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class:list={['inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide', categoryStyle[report.reasonCategory]]}>
                      {categoryLabels[report.reasonCategory]}
                    </span>
                    <span class:list={['inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide', statusStyle[report.status]]}>
                      {report.status}
                    </span>
                    <a
                      href={`/${report.entityType}s/${report.entityId}`}
                      class="text-sm font-mono text-zinc-300 hover:text-zinc-100 transition-colors"
                    >
                      {report.entityType}/{report.entityId}
                    </a>
                  </div>

                  <p class="mt-3 text-sm text-zinc-300 whitespace-pre-wrap break-words">
                    {report.description}
                  </p>

                  <div class="mt-3 flex items-center gap-3 text-xs text-zinc-500">
                    <span>
                      {report.reporterUsername
                        ? <>by <span class="text-zinc-400">@{report.reporterUsername}</span></>
                        : 'anonymous'}
                    </span>
                    <span aria-hidden="true">•</span>
                    <span>{formatDate(report.createdAt)}</span>
                    {report.resolutionNote && (
                      <>
                        <span aria-hidden="true">•</span>
                        <span class="italic">resolved: {report.resolutionNote}</span>
                      </>
                    )}
                  </div>
                </div>

                {(report.status === 'open' || report.status === 'investigating') && (
                  <div class="flex items-center gap-2 shrink-0">
                    <button
                      data-report-id={report.id}
                      data-action="investigating"
                      class="rounded-md border border-blue-800/60 bg-blue-950/40 px-2.5 py-1 text-[11px] font-medium text-blue-400 hover:bg-blue-950/60 transition-colors"
                    >
                      Investigating
                    </button>
                    <button
                      data-report-id={report.id}
                      data-action="resolved"
                      class="rounded-md border border-emerald-800/60 bg-emerald-950/40 px-2.5 py-1 text-[11px] font-medium text-emerald-400 hover:bg-emerald-950/60 transition-colors"
                    >
                      Resolve
                    </button>
                    <button
                      data-report-id={report.id}
                      data-action="dismissed"
                      class="rounded-md border border-zinc-700 bg-zinc-900 px-2.5 py-1 text-[11px] font-medium text-zinc-400 hover:bg-zinc-800 transition-colors"
                    >
                      Dismiss
                    </button>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      )}

    </div>
  </section>

  <script>
    document.querySelectorAll<HTMLButtonElement>('button[data-report-id]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.reportId!;
        const action = btn.dataset.action!;
        let note: string | null = null;
        if (action === 'resolved' || action === 'dismissed') {
          note = window.prompt(`Resolution note for ${action} (optional):`, '');
          if (note === null) return; // user cancelled
        }
        const res = await fetch(`/api/v1/admin/reports/${id}/status`, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ status: action, resolutionNote: note || undefined }),
        });
        if (res.ok) {
          window.location.reload();
        } else {
          const err = await res.json().catch(() => ({}));
          alert(`Failed: ${(err as { error?: string }).error ?? res.statusText}`);
        }
      });
    });
  </script>
</BaseLayout>
