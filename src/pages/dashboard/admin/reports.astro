---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import { isSuperAdmin } from '../../../lib/auth/admin';
import {
  listReports,
  countReportsByStatus,
  type ReportStatus,
} from '../../../lib/db/report-queries';

const author = Astro.locals.author;
if (!author || !isSuperAdmin(author.githubId)) {
  return Astro.redirect('/dashboard', 302);
}

const statusFilter = (Astro.url.searchParams.get('status') as ReportStatus | null) ?? null;
const [reports, counts] = await Promise.all([
  listReports(env.DB, statusFilter ?? undefined),
  countReportsByStatus(env.DB),
]);

type Tab = { label: string; value: ReportStatus | null; count: number };
const tabs: Tab[] = [
  { label: 'All', value: null, count: counts.open + counts.investigating + counts.resolved + counts.dismissed },
  { label: 'Open', value: 'open', count: counts.open },
  { label: 'Investigating', value: 'investigating', count: counts.investigating },
  { label: 'Resolved', value: 'resolved', count: counts.resolved },
  { label: 'Dismissed', value: 'dismissed', count: counts.dismissed },
];

const categoryLabels: Record<string, string> = {
  security: 'Security',
  abuse: 'Abuse',
  broken: 'Broken',
  license: 'License',
  other: 'Other',
};

const categoryStyle: Record<string, string> = {
  security: 'bg-danger-soft border-danger/35 text-danger',
  abuse: 'bg-warn-soft border-warn/35 text-warn',
  broken: 'bg-paper-soft border-rule-strong text-ink-muted',
  license: 'bg-info-soft border-info/35 text-info',
  other: 'bg-paper-soft border-rule-strong text-ink-muted',
};

const statusStyle: Record<ReportStatus, string> = {
  open: 'bg-warn-soft border-warn/35 text-warn',
  investigating: 'bg-info-soft border-info/35 text-info',
  resolved: 'bg-success-soft border-success/30 text-success',
  dismissed: 'bg-paper-soft border-rule-strong text-ink-soft',
};

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---
<BaseLayout title="Reports Queue - Admin - emdashcms.org">
  <section class="page pt-12 pb-16 md:pt-16">

      <nav class="flex items-center gap-2 text-sm text-ink-soft mb-6" aria-label="Breadcrumb">
        <a href="/dashboard/admin" class="hover:text-ink transition-colors">Admin</a>
        <span aria-hidden="true">/</span>
        <span class="text-ink-muted">Reports</span>
      </nav>

      <div class="flex items-center gap-3 mb-8">
        <h1 class="text-3xl text-ink">Reports queue</h1>
        <span class="rounded-full bg-paper-sunk border border-rule-strong px-2.5 py-0.5 text-[11px] text-ink-muted font-medium tabular-nums">
          {reports.length}
        </span>
      </div>

      <div class="flex gap-2 mb-6 border-b border-rule">
        {tabs.map((tab) => {
          const href = tab.value ? `?status=${tab.value}` : '?';
          const active = statusFilter === tab.value;
          return (
            <a
              href={href}
              class:list={[
                'px-4 py-2 text-sm font-medium border-b-2 transition-colors -mb-px',
                active
                  ? 'border-ink text-ink'
                  : 'border-transparent text-ink-soft hover:text-ink-muted',
              ]}
            >
              {tab.label}
              <span class="ml-1.5 text-[11px] text-ink-soft tabular-nums">({tab.count})</span>
            </a>
          );
        })}
      </div>

      {reports.length === 0 ? (
        <div class="rounded-xl border border-rule bg-paper-soft p-12 text-center">
          <p class="text-sm text-ink-muted">No reports in this view.</p>
        </div>
      ) : (
        <div class="space-y-3">
          {reports.map((report) => (
            <div class="rounded-xl border border-rule bg-paper-soft p-5">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class:list={['inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide', categoryStyle[report.reasonCategory]]}>
                      {categoryLabels[report.reasonCategory]}
                    </span>
                    <span class:list={['inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide', statusStyle[report.status]]}>
                      {report.status}
                    </span>
                    <a
                      href={`/${report.entityType}s/${report.entityId}`}
                      class="text-sm font-mono text-ink-muted hover:text-ink transition-colors"
                    >
                      {report.entityType}/{report.entityId}
                    </a>
                  </div>

                  <p class="mt-3 text-sm text-ink-muted whitespace-pre-wrap break-words">
                    {report.description}
                  </p>

                  <div class="mt-3 flex items-center gap-3 text-xs text-ink-soft">
                    <span>
                      {report.reporterUsername
                        ? <>by <span class="text-ink-muted">@{report.reporterUsername}</span></>
                        : 'anonymous'}
                    </span>
                    <span aria-hidden="true">•</span>
                    <span>{formatDate(report.createdAt)}</span>
                    {report.resolutionNote && (
                      <>
                        <span aria-hidden="true">•</span>
                        <span class="italic">resolved: {report.resolutionNote}</span>
                      </>
                    )}
                  </div>
                </div>

                {(report.status === 'open' || report.status === 'investigating') && (
                  <div class="flex items-center gap-2 shrink-0">
                    <Button
                      variant="secondary"
                      size="sm"
                      data-report-id={report.id}
                      data-action="investigating"
                    >
                      Investigating
                    </Button>
                    <Button
                      variant="primary"
                      size="sm"
                      data-report-id={report.id}
                      data-action="resolved"
                    >
                      Resolve
                    </Button>
                    <Button
                      variant="ghost"
                      size="sm"
                      data-report-id={report.id}
                      data-action="dismissed"
                    >
                      Dismiss
                    </Button>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      )}

  </section>

  <script>
    document.querySelectorAll<HTMLButtonElement>('button[data-report-id]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.reportId!;
        const action = btn.dataset.action!;
        let note: string | null = null;
        if (action === 'resolved' || action === 'dismissed') {
          note = window.prompt(`Resolution note for ${action} (optional):`, '');
          if (note === null) return; // user cancelled
        }
        const res = await fetch(`/api/v1/admin/reports/${id}/status`, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ status: action, resolutionNote: note || undefined }),
        });
        if (res.ok) {
          window.location.reload();
        } else {
          const err = await res.json().catch(() => ({}));
          alert(`Failed: ${(err as { error?: string }).error ?? res.statusText}`);
        }
      });
    });
  </script>
</BaseLayout>
