---
export const prerender = false;

import { env } from 'cloudflare:workers';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import EmptyState from '../../components/EmptyState.astro';
import { getPluginsByAuthor } from '../../lib/db/queries';
import { resolveAuthorId } from '../../lib/publishing/plugin-queries';
import { getThemesByAuthor } from '../../lib/publishing/theme-queries';

const author = Astro.locals.author!;
const authorId = await resolveAuthorId(env.DB, author.githubId);

// If author not in DB yet (first login, no plugins), show empty state
let plugins: Awaited<ReturnType<typeof getPluginsByAuthor>> = [];
let themes: Awaited<ReturnType<typeof getThemesByAuthor>> = [];
if (authorId) {
  plugins = await getPluginsByAuthor(env.DB, authorId);
  themes = await getThemesByAuthor(env.DB, authorId);
}

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'short', year: 'numeric',
  });
---
<BaseLayout title="Dashboard - emdashcms.org">
  <section class="pt-24 pb-16 px-6">
    <div class="mx-auto max-w-5xl">

      <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-semibold tracking-tight leading-[1.15] text-zinc-100">Your Plugins</h1>
        <a href="/dashboard/plugins/new" class="inline-flex items-center rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors">Register Plugin</a>
      </div>

      {plugins.length === 0 ? (
        <EmptyState
          heading="You haven't published any plugins yet"
          body="Register your first plugin to start publishing to the EmDash marketplace."
          linkHref="/dashboard/plugins/new"
          linkText="Register Your First Plugin"
        />
      ) : (
        <div class="rounded-xl border border-zinc-800/60 bg-zinc-900/40 overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-zinc-800 text-left">
                <th class="pb-3 pl-6 pr-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide" scope="col">Plugin</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide" scope="col">Latest Version</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide" scope="col">Status</th>
                <th class="pb-3 px-4 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide" scope="col">Installs</th>
                <th class="pb-3 pl-4 pr-6 pt-4 text-xs font-semibold text-zinc-500 uppercase tracking-wide" scope="col">Updated</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-800/60">
              {plugins.map(plugin => (
                <tr class="hover:bg-zinc-900/30 transition-colors">
                  <th scope="row" class="py-3 pl-6 pr-4">
                    <a href={'/dashboard/plugins/' + encodeURIComponent(plugin.id)} class="text-zinc-100 font-medium hover:text-white hover:underline transition-colors">{plugin.name}</a>
                  </th>
                  <td class="py-3 px-4 font-mono text-zinc-400">{plugin.latestVersion ?? '\u2014'}</td>
                  <td class="py-3 px-4">
                    {plugin.latestStatus ? <StatusBadge status={plugin.latestStatus} /> : <span class="text-zinc-500">{'\u2014'}</span>}
                  </td>
                  <td class="py-3 px-4 text-zinc-500">{plugin.installCount.toLocaleString()}</td>
                  <td class="py-3 pl-4 pr-6 text-zinc-500">{formatDate(plugin.updatedAt)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      <!-- Your Themes section -->
      <div class="mt-12">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-semibold text-zinc-100">Your Themes</h2>
          <a href="/dashboard/themes/new" class="inline-flex items-center rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-white transition-colors">Register Theme</a>
        </div>
        {themes.length === 0 ? (
          <p class="text-sm text-zinc-400">You haven't listed any themes yet. <a href="/dashboard/themes/new" class="text-zinc-300 hover:text-zinc-100 transition-colors underline">List your first theme</a>.</p>
        ) : (
          <a href="/dashboard/themes" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors">Manage {themes.length} theme{themes.length !== 1 ? 's' : ''} &rarr;</a>
        )}
      </div>

    </div>
  </section>
</BaseLayout>
