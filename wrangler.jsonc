{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "emdashcms-org",
  "main": "src/worker.ts",
  "compatibility_date": "2026-04-01",
  "assets": {
    "directory": "./dist/client"
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "emdashcms-org",
      "database_id": "bcf2073c-1006-4b8f-9700-daf3325f63eb"
    }
  ],

  "r2_buckets": [
    {
      "binding": "ARTIFACTS",
      "bucket_name": "emdashcms-org-artifacts"
    }
  ],

  "kv_namespaces": [
    {
      "binding": "CACHE",
      "id": "8986ecd0a90d42a0a4265dc0c2293a7a"
    }
  ],

  "queues": {
    "producers": [
      {
        "binding": "AUDIT_QUEUE",
        "queue": "emdashcms-audit"
      },
      {
        "binding": "NOTIF_QUEUE",
        "queue": "emdashcms-notifications"
      }
    ],
    "consumers": [
      {
        "queue": "emdashcms-audit",
        "max_batch_size": 1,
        "max_batch_timeout": 30,
        "max_retries": 3,
        "dead_letter_queue": "emdashcms-audit-dlq"
      },
      {
        "queue": "emdashcms-notifications",
        "max_batch_size": 1,
        "max_batch_timeout": 30,
        "max_retries": 3,
        "dead_letter_queue": "emdashcms-notifications-dlq"
      }
    ]
  },

  "ai": {
    "binding": "AI",
    // AI bindings always reach Cloudflare's remote inference tier — no
    // local emulation exists. Setting `remote: true` silences the
    // "AI bindings always access remote resources" warning Wrangler
    // emits in dev/test, where the binding is otherwise assumed local.
    "remote": true
  },

  // Edge-cached rate limiters (free tier). Counters live in Cloudflare's
  // local-machine cache, never touching D1. Two namespaces:
  //  - GENERAL: 60 req / 60s — applies to most public API requests
  //  - AUTH:    20 req / 60s — stricter limit for /api/v1/auth/*
  "ratelimits": [
    {
      "name": "GENERAL_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": { "limit": 60, "period": 60 }
    },
    {
      "name": "AUTH_RATE_LIMITER",
      "namespace_id": "1002",
      "simple": { "limit": 20, "period": 60 }
    }
  ],

  // Cron triggers:
  //  - "0 * * * *": hourly cleanup of expired rate_limits rows
  //  - "5 9 * * *": daily notification digest (09:05 UTC — D-09 in 12-CONTEXT.md)
  //  - "*/2 * * * *": Workers AI Async Batch API poller (every 2 min) —
  //    fetches results for pending batch audit rows submitted via
  //    `queueRequest: true`. See src/lib/audit/batch-poller.ts.
  "triggers": {
    "crons": ["0 * * * *", "5 9 * * *", "*/2 * * * *"]
  },

  "placement": {
    "mode": "smart"
  },

  // Raise the CPU time limit from the 30s default to 5 minutes. Queue
  // consumers inherit the Worker CPU limit, and heavy audit models
  // (Gemma 4 26B-A4B, GLM-4.7-Flash reasoning, GPT-OSS-120B) can spend
  // minutes of CPU during inference.
  //
  // Note on what this actually does: "CPU time" per Cloudflare is
  // active processing time only — time spent waiting on `ai.run()`
  // subrequests, KV reads, D1 queries, or R2 gets does NOT count. So
  // in practice we almost never use >100ms of CPU per audit. The 5min
  // limit is purely an insurance policy for the rare audit that
  // happens to be ALSO doing a lot of in-process work (e.g. parsing
  // a huge tarball) while the model thinks. Queue consumer wall-clock
  // stays at the 15-minute platform default.
  //
  // Docs: https://developers.cloudflare.com/queues/platform/limits/#increasing-queue-consumer-worker-cpu-limits
  "limits": {
    "cpu_ms": 300000
  },

  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  },

  // GitHub OAuth App client ID and App ID (not secrets — safe as vars)
  // TURNSTILE_SITE_KEY: create widget at dash.cloudflare.com → Turnstile (Smart placement)
  // AUDIT_MODE: 'manual' (default) | 'auto' | 'off'
  //   - manual: skip AI, leave version status='pending' for human moderation
  //   - auto: run Workers AI audit (cost-bound by daily neuron budget)
  //   - off: skip AI, auto-publish if static checks pass (use only in emergency)
  "vars": {
    "GITHUB_CLIENT_ID": "Ov23liIu0eF3FtxoIcYU",
    "GITHUB_APP_ID": "3345980",
    "SUPERADMIN_GITHUB_IDS": "959104",
    "TURNSTILE_SITE_KEY": "0x4AAAAAAC1FBCZjp5kjJ99c",
    "AUDIT_MODE": "auto"
  },

  // Secrets set via: wrangler secret put <NAME>
  // In dev, provide these in .dev.vars (already gitignored)
  // GITHUB_WEBHOOK_SECRET and GITHUB_APP_PRIVATE_KEY are optional until configured
  "secrets": {
    "required": [
      "GITHUB_CLIENT_SECRET",
      "JWT_SECRET",
      "TURNSTILE_SECRET_KEY",
      "UNOSEND_API_KEY",
      "UNOSEND_WEBHOOK_SECRET"
    ]
  }
}
