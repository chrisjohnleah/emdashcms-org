{
  "id": "link-checker",
  "version": "1.0.0",
  "capabilities": ["network:fetch"],
  "allowedHosts": ["*"],
  "storage": {
    "pages": {}
  },
  "hooks": ["plugin:install", "plugin:activate"],
  "routes": ["admin"],
  "admin": {
    "pages": [
      {
        "path": "/links",
        "label": "Link Checker",
        "icon": "link"
      }
    ]
  }
}
